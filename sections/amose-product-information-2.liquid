{%- liquid
  assign s = section.settings
  assign amose_install_origin = 'https://amosesection1-production.up.railway.app'
  assign amose_status_script_url = amose_install_origin | append: '/amose-section-status.js'
  assign amose_skip_install_mask = false
  if request.design_mode
    assign amose_skip_install_mask = true
  endif
  if theme.role == 'development'
    assign amose_skip_install_mask = true
  endif
  assign selected_product = product
  if s.product_handle != blank and all_products[s.product_handle] != blank
    assign selected_product = all_products[s.product_handle]
  endif
  if selected_product == blank and collections.all != blank and collections.all.products_count > 0
    assign selected_product = collections.all.products.first
  endif
  assign product = selected_product
  assign selected_variant = nil
  assign image_media = blank
  if product
    assign selected_variant = product.selected_or_first_available_variant
    assign image_media = product.media | where: 'media_type', 'image'
  endif
  assign side_benefits_on_left = false
  if s.side_benefits_position == 'left'
    assign side_benefits_on_left = true
  endif
  assign has_variant_picker = false
  for block in section.blocks
    if block.type == 'variant_picker'
      assign has_variant_picker = true
      break
    endif
  endfor
-%}

{%- style -%}
  #shopify-section-{{ section.id }}.amose-product-info-2-root {
    --amose-pi2-bg: {{ s.section_bg }};
    --amose-pi2-text: {{ s.text_color }};
    --amose-pi2-muted: {{ s.muted_text_color }};
    --amose-pi2-border: {{ s.border_color }};
    --amose-heading: clamp(22px, 2.5vw, 30px);
    --amose-lh-heading: 1.15;
    --amose-body: clamp(14px, 1.2vw, 16px);
    padding-top: {{ s.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ s.padding_bottom | times: 0.75 | round: 0 }}px;
    background: var(--amose-pi2-bg);
    color: var(--amose-pi2-text);
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }}.amose-product-info-2-root {
      padding-top: {{ s.padding_top }}px;
      padding-bottom: {{ s.padding_bottom }}px;
    }
  }

  #shopify-section-{{ section.id }} .amose-pi2__wrap {
    max-width: {{ s.max_width }}px;
    margin: 0 auto;
    padding: 0 clamp(16px, 4vw, 40px);
    font-size: 16px;
  }

  #shopify-section-{{ section.id }} .amose-pi2__layout {
    display: grid;
    gap: clamp(20px, 3.5vw, 34px);
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    #shopify-section-{{ section.id }} .amose-pi2__layout {
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
      align-items: start;
      gap: 22px;
    }

    #shopify-section-{{ section.id }} .amose-pi2__wrap {
      padding: 0 clamp(20px, 3.2vw, 30px);
    }

    #shopify-section-{{ section.id }} .amose-pi2__media-grid {
      grid-template-columns: 1fr;
    }

    #shopify-section-{{ section.id }} .amose-pi2__thumbs {
      grid-auto-columns: calc((100% - (5 * 8px)) / 6);
      scroll-snap-type: x mandatory;
    }

    #shopify-section-{{ section.id }} .amose-pi2__thumb {
      width: 100%;
      height: auto;
      aspect-ratio: 1 / 1;
      scroll-snap-align: start;
    }
  }

  @media screen and (min-width: 990px) {
    #shopify-section-{{ section.id }} .amose-pi2__layout {
      grid-template-columns: minmax(0, 1.25fr) minmax(0, 0.85fr);
      align-items: start;
    }
  }

  #shopify-section-{{ section.id }} .amose-pi2__media-grid {
    display: grid;
    gap: 12px;
  }

  @media screen and (min-width: 990px) {
    #shopify-section-{{ section.id }} .amose-pi2__media-grid {
      grid-template-columns: 60px minmax(0, 1fr) 116px;
      align-items: stretch;
    }
  }

  #shopify-section-{{ section.id }} .amose-pi2__thumbs {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 54px;
    gap: 8px;
    overflow-x: auto;
    scrollbar-width: none;
  }

  #shopify-section-{{ section.id }} .amose-pi2__main {
    order: 1;
  }

  #shopify-section-{{ section.id }} .amose-pi2__thumbs {
    order: 3;
  }

  #shopify-section-{{ section.id }} .amose-pi2__thumbs::-webkit-scrollbar {
    display: none;
  }

  #shopify-section-{{ section.id }} .amose-pi2__thumb {
    width: 54px;
    height: 54px;
    border: 1px solid var(--amose-pi2-border);
    border-radius: {{ s.thumbnail_radius | default: 10 }}px;
    overflow: hidden;
    background: #fff;
    padding: 0;
    cursor: pointer;
  }

  #shopify-section-{{ section.id }} .amose-pi2__thumb.is-active {
    border-color: #000000;
  }

  #shopify-section-{{ section.id }} .amose-pi2__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .amose-pi2__thumbs {
      grid-auto-columns: calc((100% - ({{ s.mobile_thumbnail_columns | default: 5 | minus: 1 }} * 8px)) / {{ s.mobile_thumbnail_columns | default: 5 }});
      scroll-snap-type: x mandatory;
    }

    #shopify-section-{{ section.id }} .amose-pi2__thumb {
      width: 100%;
      height: auto;
      aspect-ratio: 1 / 1;
      scroll-snap-align: start;
    }
  }

  #shopify-section-{{ section.id }} .amose-pi2__main {
    border-radius: {{ s.media_radius }}px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    background: rgba(0, 0, 0, 0.04);
  }

  #shopify-section-{{ section.id }} .amose-pi2__main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .amose-pi2__benefit-rail {
    display: grid;
    order: 2;
    grid-template-columns: 1fr;
    gap: 6px;
  }

  #shopify-section-{{ section.id }} .amose-pi2__benefit-card {
    border: 0;
    border-radius: {{ s.benefit_radius | default: 12 }}px;
    padding: 10px;
    display: grid;
    align-content: center;
    justify-items: center;
    row-gap: 6px;
    text-align: center;
    font-size: 13px;
    font-weight: 600;
    background: {{ s.benefit_bg_color | default: '#f3f3f3' }};
    color: {{ s.benefit_text_color | default: '#000000' }};
    height: 100%;
  }

  #shopify-section-{{ section.id }} .amose-pi2__benefit-icon {
    width: 20px;
    height: 20px;
    color: inherit;
  }

  #shopify-section-{{ section.id }} .amose-pi2__benefit-icon--ph {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    line-height: 1;
    color: inherit;
  }

  #shopify-section-{{ section.id }} .amose-pi2__benefit-icon--ph i {
    font-size: 20px;
    line-height: 1;
    color: inherit;
  }

  #shopify-section-{{ section.id }} .amose-pi2__benefit-text {
    margin: 0;
    line-height: 1.25;
  }

  #shopify-section-{{ section.id }} .amose-pi2__review {
    margin-top: 12px;
    border: 1px solid var(--amose-pi2-border);
    border-radius: 12px;
    padding: 12px;
    background: #fdfefc;
    display: none;
  }

  #shopify-section-{{ section.id }} .amose-pi2__faq-under-image {
    display: none;
    margin-top: 0;
  }

  #shopify-section-{{ section.id }} .amose-pi2__review-title {
    margin: 0 0 4px;
    font-size: 18px;
    font-weight: 700;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .amose-pi2__review-text {
    margin: 0;
    color: var(--amose-pi2-muted);
    font-size: 14px;
    line-height: 1.4;
  }

  #shopify-section-{{ section.id }} .amose-pi2__review-name {
    margin: 8px 0 0;
    font-size: 14px;
    font-weight: 600;
  }

  @media screen and (min-width: 990px) {
    #shopify-section-{{ section.id }} .amose-pi2__media-grid {
      grid-template-columns: minmax(0, 1fr) minmax(104px, 22%);
      align-items: stretch;
      column-gap: 12px;
      row-gap: 12px;
    }

    #shopify-section-{{ section.id }} .amose-pi2__main {
      grid-column: 1;
      grid-row: 1;
      width: 100%;
      min-width: 0;
    }

    #shopify-section-{{ section.id }} .amose-pi2__benefit-rail {
      grid-column: 2;
      grid-row: 1;
      grid-template-rows: repeat(3, minmax(0, 1fr));
      height: 100%;
      align-self: stretch;
    }

    #shopify-section-{{ section.id }} .amose-pi2__thumbs {
      grid-column: 1 / -1;
      grid-row: 2;
      order: initial;
      grid-auto-flow: column;
      grid-auto-columns: calc((100% - ({{ s.mobile_thumbnail_columns | default: 6 | minus: 1 }} * 8px)) / {{ s.mobile_thumbnail_columns | default: 6 }});
      grid-auto-rows: unset;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
    }

    #shopify-section-{{ section.id }} .amose-pi2__thumb {
      width: 100%;
      height: auto;
      aspect-ratio: 1 / 1;
      scroll-snap-align: start;
    }

    #shopify-section-{{ section.id }} .amose-pi2__review {
      display: none;
    }

    #shopify-section-{{ section.id }} .amose-pi2__benefit-card {
      aspect-ratio: auto;
      height: 100%;
      min-height: 0;
    }

    #shopify-section-{{ section.id }} .amose-pi2__faq-under-image {
      display: block;
      grid-column: 1 / -1;
      grid-row: 3;
      margin-top: 4px;
    }

    #shopify-section-{{ section.id }} .amose-pi2__faq-main-col {
      display: none;
    }

    #shopify-section-{{ section.id }} .amose-pi2__media-grid--benefits-left {
      grid-template-columns: minmax(104px, 22%) minmax(0, 1fr);
    }

    #shopify-section-{{ section.id }} .amose-pi2__media-grid--benefits-left .amose-pi2__main {
      grid-column: 2;
      grid-row: 1;
      order: initial;
    }

    #shopify-section-{{ section.id }} .amose-pi2__media-grid--benefits-left .amose-pi2__benefit-rail {
      grid-column: 1;
      grid-row: 1;
      order: initial;
    }
  }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .amose-pi2__media-grid {
      grid-template-columns: minmax(0, 1fr) minmax(80px, 24%);
      align-items: stretch;
      column-gap: 12px;
      row-gap: 12px;
    }

    #shopify-section-{{ section.id }} .amose-pi2__main {
      grid-column: 1;
      grid-row: 1;
      width: 100%;
      min-width: 0;
    }

    #shopify-section-{{ section.id }} .amose-pi2__benefit-rail {
      grid-column: 2;
      grid-row: 1;
      grid-template-rows: repeat(3, minmax(0, 1fr));
      height: 100%;
      align-self: stretch;
    }

    #shopify-section-{{ section.id }} .amose-pi2__thumbs {
      grid-column: 1 / -1;
      grid-row: 2;
    }

    #shopify-section-{{ section.id }} .amose-pi2__benefit-card {
      padding: 2px;
    }

    #shopify-section-{{ section.id }} .amose-pi2__benefit-text {
      font-size: 10px;
    }

    #shopify-section-{{ section.id }} .amose-pi2__media-grid--benefits-left {
      grid-template-columns: minmax(80px, 24%) minmax(0, 1fr);
    }

    #shopify-section-{{ section.id }} .amose-pi2__media-grid--benefits-left .amose-pi2__main {
      grid-column: 2;
      grid-row: 1;
      order: initial;
    }

    #shopify-section-{{ section.id }} .amose-pi2__media-grid--benefits-left .amose-pi2__benefit-rail {
      grid-column: 1;
      grid-row: 1;
      order: initial;
    }
  }

  #shopify-section-{{ section.id }} .amose-pi2__title {
    margin: 0 0 8px;
    font-size: var(--amose-heading);
    font-weight: 700;
    line-height: var(--amose-lh-heading);
  }

  #shopify-section-{{ section.id }} .amose-pi2__price {
    margin: 0 0 12px;
    font-size: clamp(15px, 1.5vw, 18px);
    font-weight: 700;
    display: flex;
    align-items: baseline;
    gap: 10px;
  }

  #shopify-section-{{ section.id }} .amose-pi2__price-compare {
    color: var(--amose-pi2-muted);
    text-decoration: line-through;
    font-size: 0.9em;
    font-weight: 400;
  }

  #shopify-section-{{ section.id }} .amose-pi2__summary {
    margin: 25px 0 16px;
    font-size: 14px;
    line-height: 1.35;
    color: var(--amose-pi2-text);
  }

  #shopify-section-{{ section.id }} .amose-pi2__summary-highlight {
    background: var(--amose-pi2-summary-hl-bg, {{ s.summary_highlight_bg | default: '#e9e9e9' }});
    color: var(--amose-pi2-summary-hl-color, {{ s.summary_highlight_color | default: '#000000' }});
    padding: 0.08em 0.26em;
    border-radius: 3px;
  }

  #shopify-section-{{ section.id }} .amose-pi2__tpbar {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: flex-start;
    gap: clamp(8px, 1.7vw, 14px);
    width: 100%;
    margin-bottom: 10px;
    color: #0a0a0a;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .amose-pi2__tp-label {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .amose-pi2__tp-stars {
    display: flex;
    align-items: center;
    line-height: 0;
  }

  #shopify-section-{{ section.id }} .amose-pi2__tp-badge {
    width: min(100px, 100%);
    max-width: 100%;
    height: auto;
    display: block;
  }

  #shopify-section-{{ section.id }} .amose-pi2__tp-count {
    margin: 0;
    font-size: 14px;
    line-height: 1.2;
    color: #0a0a0a;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .amose-pi2__tp-count strong {
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .amose-pi2__tp-count span {
    font-weight: 400;
  }

  #shopify-section-{{ section.id }} .amose-pi2__desc,
  #shopify-section-{{ section.id }} .amose-pi2__desc p,
  #shopify-section-{{ section.id }} .amose-pi2__accordion-content,
  #shopify-section-{{ section.id }} .amose-pi2__accordion-content p {
    margin: 0;
    font-size: var(--amose-body);
    color: var(--amose-pi2-muted);
    line-height: 1.5;
  }

  #shopify-section-{{ section.id }} .amose-pi2__field {
    margin-bottom: 14px;
    display: grid;
    gap: 8px;
  }

  #shopify-section-{{ section.id }} .amose-pi2__label {
    font-size: 14px;
    font-weight: 600;
  }

  #shopify-section-{{ section.id }} .amose-pi2__select,
  #shopify-section-{{ section.id }} .amose-pi2__qty {
    width: 100%;
    min-height: 50px;
    border: 1px solid var(--amose-pi2-border);
    border-radius: 12px;
    background: #fff;
    padding: 0 14px;
  }

  #shopify-section-{{ section.id }} .amose-pi2__variant-picker.amose-pi2__field {
    gap: 8px;
    margin-bottom: 12px;
  }

  #shopify-section-{{ section.id }} .amose-pi2__variant-options {
    display: grid;
    gap: 10px;
  }

  #shopify-section-{{ section.id }} .amose-pi2__option-group {
    display: grid;
    gap: 8px;
  }

  #shopify-section-{{ section.id }} .amose-pi2__option-values {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  #shopify-section-{{ section.id }} .amose-pi2__variant-picker {
    --amose-vp-btn-radius: 20px;
    --amose-vp-dropdown-radius: 12px;
    --amose-vp-control-size: 15px;
    --amose-vp-control-weight: 500;
    --amose-vp-control-line-height: 1.3;
    --amose-vp-label-gap: 8px;
  }

  #shopify-section-{{ section.id }} .amose-pi2__variant-picker .amose-pi2__label {
    margin: 0;
    padding: 0;
    font-size: var(--amose-vp-control-size);
    font-weight: var(--amose-vp-control-weight);
    line-height: var(--amose-vp-control-line-height);
    color: var(--amose-vp-label-color, var(--amose-pi2-text));
  }

  #shopify-section-{{ section.id }} .amose-pi2__variant-picker .amose-pi2__option-group {
    gap: var(--amose-vp-label-gap);
  }

  #shopify-section-{{ section.id }} .amose-pi2__select-wrap {
    position: relative;
    display: block;
  }

  #shopify-section-{{ section.id }} .amose-pi2__variant-picker .amose-pi2__select {
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    width: 100%;
    min-height: 48px;
    padding: 0 44px 0 16px;
    border: 1px solid var(--amose-vp-border, var(--amose-pi2-border));
    border-radius: var(--amose-vp-dropdown-radius);
    background-color: var(--amose-vp-dropdown-bg, #fff);
    color: var(--amose-vp-dropdown-text, var(--amose-pi2-text));
    font-size: var(--amose-vp-control-size);
    font-weight: var(--amose-vp-control-weight);
    line-height: var(--amose-vp-control-line-height);
    cursor: pointer;
    box-shadow: none;
  }

  #shopify-section-{{ section.id }} .amose-pi2__variant-picker .amose-pi2__select:hover,
  #shopify-section-{{ section.id }} .amose-pi2__variant-picker .amose-pi2__select:focus,
  #shopify-section-{{ section.id }} .amose-pi2__variant-picker .amose-pi2__select:focus-visible,
  #shopify-section-{{ section.id }} .amose-pi2__variant-picker .amose-pi2__select:active {
    outline: none;
    box-shadow: none;
    border-color: var(--amose-vp-border, var(--amose-pi2-border));
  }

  #shopify-section-{{ section.id }} .amose-pi2__variant-picker .amose-pi2__select-wrap::after {
    content: '';
    position: absolute;
    right: 18px;
    top: 50%;
    width: 8px;
    height: 8px;
    border-right: 2px solid var(--amose-vp-label-color, var(--amose-pi2-muted));
    border-bottom: 2px solid var(--amose-vp-label-color, var(--amose-pi2-muted));
    transform: translateY(-70%) rotate(45deg);
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .amose-pi2__variant-picker .amose-pi2__option-btn {
    min-height: 0;
    padding: 5px 12px;
    border: 1px solid var(--amose-vp-border, var(--amose-pi2-border));
    border-radius: var(--amose-vp-btn-radius);
    background: var(--amose-vp-btn-bg, #fff);
    color: var(--amose-vp-btn-text, var(--amose-pi2-text));
    font-size: var(--amose-vp-control-size);
    font-weight: var(--amose-vp-control-weight);
    line-height: var(--amose-vp-control-line-height);
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease, color 0.15s ease, box-shadow 0.15s ease;
  }

  #shopify-section-{{ section.id }} .amose-pi2__variant-picker .amose-pi2__option-btn:hover:not(:disabled):not(.is-selected) {
    border-color: color-mix(in srgb, var(--amose-vp-border, var(--amose-pi2-border)) 50%, var(--amose-vp-btn-text, var(--amose-pi2-text)));
  }

  #shopify-section-{{ section.id }} .amose-pi2__variant-picker .amose-pi2__option-btn.is-selected {
    border-color: var(--amose-vp-btn-selected-bg, var(--amose-pi2-text));
    background: var(--amose-vp-btn-selected-bg, var(--amose-pi2-text));
    color: var(--amose-vp-btn-selected-text, #fff);
    box-shadow: 0 2px 8px color-mix(in srgb, var(--amose-vp-btn-selected-bg, var(--amose-pi2-text)) 22%, transparent);
  }

  #shopify-section-{{ section.id }} .amose-pi2__variant-picker .amose-pi2__option-btn.is-unavailable {
    opacity: 0.45;
    cursor: not-allowed;
    text-decoration: line-through;
  }

  #shopify-section-{{ section.id }} .amose-pi2__qty-wrap {
    display: grid;
    grid-template-columns: 42px 1fr 42px;
    min-height: 50px;
    border: 1px solid var(--amose-pi2-border);
    border-radius: 12px;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .amose-pi2__qty-btn {
    border: 0;
    background: #f5f5f5;
    cursor: pointer;
    font-size: 19px;
  }

  #shopify-section-{{ section.id }} .amose-pi2__qty {
    border: 0;
    text-align: center;
    border-radius: 0;
  }

  #shopify-section-{{ section.id }} .amose-pi2__add-row {
    display: grid;
    margin-top: 20px;
  }

  #shopify-section-{{ section.id }} .amose-pi2__cta {
    width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 55px;
    border: 0;
    border-radius: var(--amose-pi2-cta-radius, 15px);
    background: var(--amose-pi2-cta-bg, #000000);
    color: var(--amose-pi2-cta-text, #ffffff);
    font-size: 18px;
    font-weight: 700;
    cursor: pointer;
  }

  #shopify-section-{{ section.id }} .amose-pi2__cta-price {
    font-size: 0.95em;
    font-weight: 600;
    opacity: 0.95;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .amose-pi2__trust-block {
    width: 100%;
    margin-top: 0;
    margin-bottom: 0;
    --trust-bg: #ffffff;
    --trust-border: #e8e8ec;
    --trust-text: #0a0a0a;
    --trust-rating: #0a0a0a;
    --trust-divider: #e8e8ec;
    --trust-star: #000000;
    --trust-star-size: 16px;
    --trust-star-gap: 8px;
  }

  #shopify-section-{{ section.id }} .amose-pi2__ship {
    margin-top: 14px;
    --ship-muted: #525252;
    --ship-fg: #171717;
    font-size: 14px;
  }

  #shopify-section-{{ section.id }} .amose-pi2__ship-text {
    margin: 0;
    line-height: 1.5;
    color: var(--ship-muted);
    text-align: center;
  }

  #shopify-section-{{ section.id }} .amose-pi2__ship-lead,
  #shopify-section-{{ section.id }} .amose-pi2__ship-date {
    color: var(--ship-fg);
    font-weight: 400;
  }

  #shopify-section-{{ section.id }} .amose-track {
    width: 100%;
    box-sizing: border-box;
    margin-top: 12px;
  }

  #shopify-section-{{ section.id }} .amose-track__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    width: 100%;
    align-items: flex-start;
  }

  #shopify-section-{{ section.id }} .amose-track__item {
    flex: 1 1 0;
    position: relative;
    text-align: center;
    min-width: 0;
    padding: 0;
  }

  #shopify-section-{{ section.id }} .amose-track__item:not(:last-child)::after {
    content: "";
    position: absolute;
    top: calc(var(--track-icon-size) / 2);
    left: calc(50% + var(--track-icon-size) / 2);
    width: calc(100% - var(--track-icon-size));
    height: 2px;
    background: var(--track-line);
    z-index: 0;
    transform: translateY(-50%);
  }

  #shopify-section-{{ section.id }} .amose-track__icon-ring {
    position: relative;
    z-index: 1;
    width: var(--track-icon-size);
    height: var(--track-icon-size);
    margin: 0 auto 0.65em;
    border-radius: 50%;
    background: var(--track-icon-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--track-accent);
  }

  #shopify-section-{{ section.id }} .amose-track__icon-ring svg {
    width: 55%;
    height: 55%;
    display: block;
  }

  #shopify-section-{{ section.id }} .amose-track__icon-ring .ph-duotone {
    font-size: 22px;
    line-height: 1;
    color: var(--track-accent);
  }

  #shopify-section-{{ section.id }} .amose-track__date {
    margin: 0;
    font-size: 0.92em;
    font-weight: 500;
    color: var(--track-text, #171717);
    line-height: 1.25;
  }

  #shopify-section-{{ section.id }} .amose-track__status {
    margin: 0.15em 0 0;
    font-size: 1.05em;
    font-weight: 700;
    color: var(--track-text, #171717);
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .amose-stock-urgency {
    width: 100%;
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .amose-stock-urgency__description {
    margin: 0;
    line-height: 1.45;
    flex: 1 1 auto;
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .amose-stock-urgency__meta-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
  }

  #shopify-section-{{ section.id }} .amose-stock-urgency__meta-row--status-only {
    justify-content: flex-end;
  }

  #shopify-section-{{ section.id }} .amose-stock-urgency__bar {
    width: 100%;
    overflow: hidden;
    display: block;
  }

  #shopify-section-{{ section.id }} .amose-stock-urgency__bar-fill {
    display: block;
    height: 100%;
    width: var(--su-fill, 93%);
    transition: width 0.35s ease;
  }

  #shopify-section-{{ section.id }} .amose-stock-urgency__status {
    margin: 0;
    line-height: 1.3;
    flex: 0 0 auto;
    white-space: nowrap;
    text-align: right;
  }

  #shopify-section-{{ section.id }} .amose-pi2__announce-banner {
    width: 100%;
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .amose-pi2__announce-banner__inner {
    display: flex;
    align-items: center;
    gap: var(--ab-gap, 12px);
    background: var(--ab-bg, #f1e9fd);
    border-radius: var(--ab-radius, 8px);
    padding: var(--ab-pad-y, 14px) var(--ab-pad-x, 16px);
  }

  #shopify-section-{{ section.id }} .amose-pi2__announce-banner__icon {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--ab-icon, #111111);
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .amose-pi2__announce-banner__icon .ph-duotone {
    font-size: var(--ab-icon-size, 32px);
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .amose-pi2__announce-banner__text {
    margin: 0;
    flex: 1 1 auto;
    min-width: 0;
    color: var(--ab-text, #111111);
    font-size: var(--ab-text-size, 14px);
    font-weight: var(--ab-text-weight, 400);
    line-height: 1.35;
  }

  #shopify-section-{{ section.id }} .amose-pi2__trust {
    max-width: 600px;
    margin: 0 auto;
    padding: 18px;
    background: var(--trust-bg);
    border: 1px solid var(--trust-border);
    border-radius: 12px;
    box-shadow: 0 1px 3px rgba(10, 10, 10, 0.06);
    font-size: 14px;
    line-height: 1.5;
    color: var(--trust-text);
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .amose-pi2__trust-score {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--trust-star-gap);
    margin: 0;
  }

  #shopify-section-{{ section.id }} .amose-pi2__trust-stars {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    gap: 2px;
  }

  #shopify-section-{{ section.id }} .amose-pi2__trust-stars img {
    height: var(--trust-star-size);
    width: auto;
    display: block;
  }

  #shopify-section-{{ section.id }} .amose-pi2__trust-star-svg {
    width: var(--trust-star-size);
    height: var(--trust-star-size);
    flex-shrink: 0;
    display: block;
    fill: var(--trust-star);
  }

  #shopify-section-{{ section.id }} .amose-pi2__trust-meta {
    display: flex;
    align-items: center;
    gap: 5px;
    flex-wrap: wrap;
    color: var(--trust-rating);
    line-height: 1.35;
  }

  #shopify-section-{{ section.id }} .amose-pi2__trust-meta strong {
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  #shopify-section-{{ section.id }} .amose-pi2__trust-sep {
    opacity: 0.45;
    font-weight: 300;
  }

  #shopify-section-{{ section.id }} .amose-pi2__trust hr {
    height: 1px;
    border: 0;
    background: var(--trust-divider);
    margin: 20px 0;
  }

  #shopify-section-{{ section.id }} .amose-pi2__trust p {
    margin: 0;
    color: var(--trust-text);
  }

  #shopify-section-{{ section.id }} .amose-pi2__trust p strong {
    font-weight: 600;
  }

  #shopify-section-{{ section.id }} .amose-pi2__payment-icons {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .amose-pi2__payment-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .amose-pi2__payment-icon img {
    width: 32px;
    height: 20px;
    max-width: 32px;
    max-height: 20px;
    object-fit: contain;
    display: block;
  }

  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .amose-pi2__trust {
      max-width: 100%;
      padding: 15px;
      font-size: 12.6px;
    }

    #shopify-section-{{ section.id }} .amose-pi2__trust hr {
      margin: 16px 0;
    }
  }

  #shopify-section-{{ section.id }} .amose-pi2__accordion details {
    border-bottom: 1px solid var(--amose-pi2-border);
  }

  #shopify-section-{{ section.id }} .amose-pi2__accordion summary {
    list-style: none;
    cursor: pointer;
    padding: 14px 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: 500;
  }

  #shopify-section-{{ section.id }} .amose-pi2__accordion summary::-webkit-details-marker {
    display: none;
  }

  #shopify-section-{{ section.id }} .amose-pi2__accordion-icon::before {
    content: "+";
  }

  #shopify-section-{{ section.id }} .amose-pi2__accordion details[open] .amose-pi2__accordion-icon::before {
    content: "-";
  }

  #shopify-section-{{ section.id }} .amose-pi2__accordion-content {
    padding: 0 0 14px;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .amose-pi2__accordion summary,
    #shopify-section-{{ section.id }} .amose-pi2__accordion-content,
    #shopify-section-{{ section.id }} .amose-pi2__accordion-content p {
      font-size: 13px;
    }
  }
{%- endstyle -%}

{%- unless amose_skip_install_mask -%}
{%- comment -%} Install check: hide only after API says uninstalled (amose-section-status.js). {%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }}.amose-section-checking {
    display: none !important;
  }
{%- endstyle -%}
{%- endunless -%}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@phosphor-icons/web@2.1.1/src/regular/style.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@phosphor-icons/web@2.1.1/src/duotone/style.css">

<div class="amose-pi2__wrap">
  <div class="amose-pi2__layout">
    <div>
      <div class="amose-pi2__media-grid{% if side_benefits_on_left %} amose-pi2__media-grid--benefits-left{% endif %}">
        {% if image_media.size > 0 %}
          <div class="amose-pi2__thumbs">
            {% for media in image_media %}
              <button
                type="button"
                class="amose-pi2__thumb{% if forloop.first %} is-active{% endif %}"
                data-amose-pi2-thumb
                data-media-id="{{ media.id }}"
                data-full-src="{{ media | image_url: width: 1600 }}"
                data-alt="{{ media.alt | default: product.title | escape }}"
              >
                {{ media | image_url: width: 180 | image_tag: loading: 'lazy', alt: '' }}
              </button>
            {% endfor %}
          </div>
        {% endif %}

        <div class="amose-pi2__main">
          {% if product.featured_media %}
            <img
              class="amose-pi2__main-img"
              src="{{ product.featured_media | image_url: width: 1600 }}"
              alt="{{ product.featured_media.alt | default: product.title | escape }}"
              loading="eager"
            >
          {% endif %}
        </div>

        <div class="amose-pi2__benefit-rail">
          {%- capture amose_pi2_badge_icon -%}
            <svg class="amose-pi2__benefit-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M9.5924 3.20027C9.34888 3.4078 9.22711 3.51158 9.09706 3.59874C8.79896 3.79854 8.46417 3.93721 8.1121 4.00672C7.95851 4.03705 7.79903 4.04977 7.48008 4.07522C6.6787 4.13918 6.278 4.17115 5.94371 4.28923C5.17051 4.56233 4.56233 5.17051 4.28923 5.94371C4.17115 6.278 4.13918 6.6787 4.07522 7.48008C4.04977 7.79903 4.03705 7.95851 4.00672 8.1121C3.93721 8.46417 3.79854 8.79896 3.59874 9.09706C3.51158 9.22711 3.40781 9.34887 3.20027 9.5924C2.67883 10.2043 2.4181 10.5102 2.26522 10.8301C1.91159 11.57 1.91159 12.43 2.26522 13.1699C2.41811 13.4898 2.67883 13.7957 3.20027 14.4076C3.40778 14.6511 3.51158 14.7729 3.59874 14.9029C3.79854 15.201 3.93721 15.5358 4.00672 15.8879C4.03705 16.0415 4.04977 16.201 4.07522 16.5199C4.13918 17.3213 4.17115 17.722 4.28923 18.0563C4.56233 18.8295 5.17051 19.4377 5.94371 19.7108C6.278 19.8288 6.6787 19.8608 7.48008 19.9248C7.79903 19.9502 7.95851 19.963 8.1121 19.9933C8.46417 20.0628 8.79896 20.2015 9.09706 20.4013C9.22711 20.4884 9.34887 20.5922 9.5924 20.7997C10.2043 21.3212 10.5102 21.5819 10.8301 21.7348C11.57 22.0884 12.43 22.0884 13.1699 21.7348C13.4898 21.5819 13.7957 21.3212 14.4076 20.7997C14.6511 20.5922 14.7729 20.4884 14.9029 20.4013C15.201 20.2015 15.5358 20.0628 15.8879 19.9933C16.0415 19.963 16.201 19.9502 16.5199 19.9248C17.3213 19.8608 17.722 19.8288 18.0563 19.7108C18.8295 19.4377 19.4377 18.8295 19.7108 18.0563C19.8288 17.722 19.8608 17.3213 19.9248 16.5199C19.9502 16.201 19.963 16.0415 19.9933 15.8879C20.0628 15.5358 20.2015 15.201 20.4013 14.9029C20.4884 14.7729 20.5922 14.6511 20.7997 14.4076C21.3212 13.7957 21.5819 13.4898 21.7348 13.1699C22.0884 12.43 22.0884 11.57 21.7348 10.8301C21.5819 10.5102 21.3212 10.2043 20.7997 9.5924C20.5922 9.34887 20.4884 9.22711 20.4013 9.09706C20.2015 8.79896 20.0628 8.46417 19.9933 8.1121C19.963 7.95851 19.9502 7.79903 19.9248 7.48008C19.8608 6.6787 19.8288 6.278 19.7108 5.94371C19.4377 5.17051 18.8295 4.56233 18.0563 4.28923C17.722 4.17115 17.3213 4.13918 16.5199 4.07522C16.201 4.04977 16.0415 4.03705 15.8879 4.00672C15.5358 3.93721 15.201 3.79854 14.9029 3.59874C14.7729 3.51158 14.6511 3.40781 14.4076 3.20027C13.7957 2.67883 13.4898 2.41811 13.1699 2.26522C12.43 1.91159 11.57 1.91159 10.8301 2.26522C10.5102 2.4181 10.2043 2.67883 9.5924 3.20027ZM16.3735 9.86314C16.6913 9.5453 16.6913 9.03 16.3735 8.71216C16.0557 8.39433 15.5403 8.39433 15.2225 8.71216L10.3723 13.5624L8.77746 11.9676C8.45963 11.6498 7.94432 11.6498 7.62649 11.9676C7.30866 12.2854 7.30866 12.8007 7.62649 13.1186L9.79678 15.2889C10.1146 15.6067 10.6299 15.6067 10.9478 15.2889L16.3735 9.86314Z" fill="currentColor"/>
            </svg>
          {%- endcapture -%}
          {% if s.side_benefit_1 != blank %}
            <div class="amose-pi2__benefit-card">
              {% assign side_benefit_icon_1 = s.side_benefit_icon_1 | default: 'default' %}
              {% if side_benefit_icon_1 != 'default' and side_benefit_icon_1 != 'none' and side_benefit_icon_1 != blank %}
                <span class="amose-pi2__benefit-icon amose-pi2__benefit-icon--ph" aria-hidden="true">
                  <i class="ph ph-{{ side_benefit_icon_1 }}"></i>
                </span>
              {% elsif side_benefit_icon_1 != 'none' %}
                {{ amose_pi2_badge_icon }}
              {% endif %}
              <p class="amose-pi2__benefit-text">{{ s.side_benefit_1 | replace: '.', '' }}</p>
            </div>
          {% endif %}
          {% if s.side_benefit_2 != blank %}
            <div class="amose-pi2__benefit-card">
              {% assign side_benefit_icon_2 = s.side_benefit_icon_2 | default: 'default' %}
              {% if side_benefit_icon_2 != 'default' and side_benefit_icon_2 != 'none' and side_benefit_icon_2 != blank %}
                <span class="amose-pi2__benefit-icon amose-pi2__benefit-icon--ph" aria-hidden="true">
                  <i class="ph ph-{{ side_benefit_icon_2 }}"></i>
                </span>
              {% elsif side_benefit_icon_2 != 'none' %}
                {{ amose_pi2_badge_icon }}
              {% endif %}
              <p class="amose-pi2__benefit-text">{{ s.side_benefit_2 | replace: '.', '' }}</p>
            </div>
          {% endif %}
          {% if s.side_benefit_3 != blank %}
            <div class="amose-pi2__benefit-card">
              {% assign side_benefit_icon_3 = s.side_benefit_icon_3 | default: 'default' %}
              {% if side_benefit_icon_3 != 'default' and side_benefit_icon_3 != 'none' and side_benefit_icon_3 != blank %}
                <span class="amose-pi2__benefit-icon amose-pi2__benefit-icon--ph" aria-hidden="true">
                  <i class="ph ph-{{ side_benefit_icon_3 }}"></i>
                </span>
              {% elsif side_benefit_icon_3 != 'none' %}
                {{ amose_pi2_badge_icon }}
              {% endif %}
              <p class="amose-pi2__benefit-text">{{ s.side_benefit_3 | replace: '.', '' }}</p>
            </div>
          {% endif %}
        </div>

        <div class="amose-pi2__faq-under-image">
          {% for block in section.blocks %}
            {% if block.type == 'collapsible_row' and block.settings.title != blank %}
              <div class="amose-pi2__accordion">
                <details>
                  <summary><span>{{ block.settings.title | escape }}</span><span class="amose-pi2__accordion-icon"></span></summary>
                  <div class="amose-pi2__accordion-content rte">{{ block.settings.content }}</div>
                </details>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      {% if s.review_title != blank or s.review_text != blank %}
        <div class="amose-pi2__review">
          {% if s.review_title != blank %}<p class="amose-pi2__review-title">{{ s.review_title }}</p>{% endif %}
          {% if s.review_text != blank %}<p class="amose-pi2__review-text">{{ s.review_text }}</p>{% endif %}
          {% if s.review_name != blank %}<p class="amose-pi2__review-name">— {{ s.review_name }}</p>{% endif %}
        </div>
      {% endif %}

    </div>

    <div>
      {% if product %}
      {% form 'product', product %}
        {% if has_variant_picker == false %}
          <input type="hidden" name="id" value="{{ selected_variant.id }}">
        {% endif %}

        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'trustpilot_row' %}
              <div class="amose-pi2__tpbar" {{ block.shopify_attributes }}>
                <span class="amose-pi2__tp-label" style="font-size: {{ block.settings.label_size | default: 14 }}px; font-weight: {{ block.settings.label_weight | default: '600' }};">{{ block.settings.label | default: 'Excellent' }}</span>
                <div class="amose-pi2__tp-stars" role="img" aria-label="{{ block.settings.rating | default: '4.8' }} out of 5 stars">
                  <img
                    class="amose-pi2__tp-badge"
                    src="{{ block.settings.badge_image | default: 'https://i.imgur.com/EHjNmTM.png' }}"
                    width="100"
                    height="20"
                    alt=""
                    loading="lazy"
                    decoding="async"
                  >
                </div>
                <p class="amose-pi2__tp-count">
                  <strong>{{ block.settings.review_count | default: '20,921' }}</strong>
                  <span> {{ block.settings.reviews_label | default: 'reviews' }}</span>
                </p>
              </div>
            {% when 'title' %}
              <h1
                class="amose-pi2__title"
                style="font-size: {{ block.settings.font_size | default: 28 }}px; color: {{ block.settings.text_color | default: s.text_color }};"
                {{ block.shopify_attributes }}
              >{{ product.title | escape }}</h1>
            {% when 'price' %}
              <p
                class="amose-pi2__price"
                style="font-size: {{ block.settings.font_size | default: 17 }}px; color: {{ block.settings.text_color | default: s.text_color }};"
                {{ block.shopify_attributes }}
              >
                <span>{{ selected_variant.price | money }}</span>
                {% if selected_variant.compare_at_price > selected_variant.price %}
                  <span
                    class="amose-pi2__price-compare"
                    style="color: {{ block.settings.compare_color | default: s.muted_text_color }};"
                  >{{ selected_variant.compare_at_price | money }}</span>
                {% endif %}
              </p>
            {% when 'summary_line' %}
              {% assign summary_sentence = block.settings.summary_text | default: block.settings.suffix %}
              {% if summary_sentence == blank and block.settings.prefix != blank %}
                {% assign summary_sentence = block.settings.prefix %}
              {% endif %}
              {% if summary_sentence != blank %}
                {% assign summary_markup = summary_sentence %}
                {% if block.settings.highlight != blank %}
                  {% assign highlight_markup = '<span class="amose-pi2__summary-highlight">' | append: block.settings.highlight | append: '</span>' %}
                  {% if summary_markup contains block.settings.highlight %}
                    {% assign summary_markup = summary_markup | replace_first: block.settings.highlight, highlight_markup %}
                  {% endif %}
                {% endif %}
                <p
                  class="amose-pi2__summary"
                  style="
                    margin-top: {{ block.settings.margin_top | default: 16 }}px;
                    margin-bottom: {{ block.settings.margin_bottom | default: 16 }}px;
                  "
                >
                  <span
                    style="
                      --amose-pi2-summary-hl-bg: {{ block.settings.highlight_bg | default: s.summary_highlight_bg | default: '#e9e9e9' }};
                      --amose-pi2-summary-hl-color: {{ block.settings.highlight_text_color | default: s.summary_highlight_color | default: '#000000' }};
                    "
                  >{{ summary_markup }}</span>
                </p>
              {% endif %}
            {% when 'low_stock' %}
              {% if block.settings.show %}
                {%- liquid
                  assign day_seed = 'now' | date: '%j' | plus: 0
                  assign stk_min = block.settings.stock_min | default: 4
                  assign stk_max = block.settings.stock_max | default: 22
                  assign stock_left = day_seed | modulo: 11 | plus: 5
                  if stock_left < stk_min
                    assign stock_left = stk_min
                  endif
                  if stock_left > stk_max
                    assign stock_left = stk_max
                  endif
                  assign stk_uid = block.id | handleize | default: 'stk'
                  assign stk_lead = block.settings.lead | default: 'Low stock, only '
                  assign stk_tail = block.settings.tail | default: ' left'
                -%}
                <div
                  class="amose-stk amose-stk--{{ stk_uid }}"
                  data-min="{{ stk_min }}"
                  data-max="{{ stk_max }}"
                  data-tick-min-ms="{{ block.settings.tick_min_sec | default: 15 | times: 1000 }}"
                  data-tick-max-ms="{{ block.settings.tick_max_sec | default: 30 | times: 1000 }}"
                  data-pause-min-ms="{{ block.settings.pause_min_sec | default: 45 | times: 1000 }}"
                  data-pause-extra-ms="{{ block.settings.pause_extra_sec | default: 60 | times: 1000 }}"
                  style="
                    --stk-accent: {{ block.settings.accent_color | default: '#dc2626' }};
                    --stk-text: {{ block.settings.text_color | default: '#171717' }};
                    font-size: {{ block.settings.font_size | default: 14 }}px;
                    margin-top: {{ block.settings.margin_top | default: 6 }}px;
                    margin-bottom: {{ block.settings.margin_bottom | default: 0 }}px;
                  "
                  {{ block.shopify_attributes }}
                >
                  <style>
                    @keyframes amose-stk-pulse--{{ stk_uid }} {
                      0% {
                        box-shadow:
                          0 0 0 0 color-mix(in srgb, var(--stk-accent) 36%, transparent),
                          0 0 1px 1px rgba(0, 0, 0, 0.1);
                      }
                      100% {
                        box-shadow:
                          0 0 0 0.42em color-mix(in srgb, var(--stk-accent) 0%, transparent),
                          0 0 1px 1px rgba(0, 0, 0, 0.1);
                      }
                    }
                    .amose-stk--{{ stk_uid }} .amose-stk__inner {
                      display: flex;
                      align-items: center;
                      gap: 0.72em;
                      flex-wrap: wrap;
                    }
                    .amose-stk--{{ stk_uid }} .amose-stk__dot {
                      flex-shrink: 0;
                      width: 0.74em;
                      height: 0.74em;
                      border-radius: 50%;
                      background: var(--stk-accent);
                      margin-inline-end: 0.06em;
                      will-change: box-shadow;
                      animation: amose-stk-pulse--{{ stk_uid }} 2s infinite;
                    }
                    @media (prefers-reduced-motion: reduce) {
                      .amose-stk--{{ stk_uid }} .amose-stk__dot {
                        animation: none;
                        opacity: 1;
                        box-shadow: none;
                      }
                    }
                    .amose-stk--{{ stk_uid }} .amose-stk__line {
                      margin: 0;
                      color: var(--stk-text);
                      line-height: 1.45;
                    }
                    .amose-stk--{{ stk_uid }} .amose-stk__num {
                      font-weight: 700;
                      color: var(--stk-accent);
                      font-variant-numeric: tabular-nums;
                      margin-inline: 0.18em;
                    }
                  </style>
                  <div class="amose-stk__inner">
                    <span class="amose-stk__dot" aria-hidden="true"></span>
                    <p class="amose-stk__line">
                      <span class="amose-stk__lead">{{ stk_lead | escape }}</span>{% if block.settings.show_number %}<span class="amose-stk__num" data-amose-stk>{{ stock_left }}</span><span class="amose-stk__tail">{{ stk_tail | escape }}</span>{% endif %}
                    </p>
                  </div>
                  <script>
                    (function () {
                      var root = document.currentScript && document.currentScript.closest('.amose-stk--{{ stk_uid }}');
                      if (!root) return;
                      var el = root.querySelector('[data-amose-stk]');
                      if (!el) return;
                      var min = parseInt(root.getAttribute('data-min'), 10) || 4;
                      var max = parseInt(root.getAttribute('data-max'), 10) || 22;
                      if (max < min) max = min;
                      var tickMin = parseInt(root.getAttribute('data-tick-min-ms'), 10) || 15000;
                      var tickMax = parseInt(root.getAttribute('data-tick-max-ms'), 10) || 30000;
                      if (tickMax < tickMin) tickMax = tickMin;
                      var pauseMin = parseInt(root.getAttribute('data-pause-min-ms'), 10) || 45000;
                      var pauseExtra = parseInt(root.getAttribute('data-pause-extra-ms'), 10) || 60000;
                      var current = parseInt(String(el.textContent).replace(/\D/g, ''), 10);
                      if (isNaN(current)) current = Math.round((min + max) / 2);
                      current = Math.min(max, Math.max(min, current));
                      el.textContent = String(current);
                      var target = current;
                      var idleUntil = 0;
                      var resting = true;
                      function pickTarget() {
                        if (current <= min) {
                          target = current;
                          return;
                        }
                        var hi = current - 1;
                        if (hi < min) {
                          target = current;
                          return;
                        }
                        target = min + Math.floor(Math.random() * (hi - min + 1));
                      }
                      function nextTickDelay() {
                        return tickMin + Math.random() * (tickMax - tickMin);
                      }
                      function schedule(ms) {
                        setTimeout(tick, Math.max(0, Math.round(ms)));
                      }
                      function tick() {
                        var now = Date.now();
                        if (current === target) {
                          if (resting && now >= idleUntil) {
                            pickTarget();
                            if (current === target) {
                              idleUntil = now + 2000;
                              schedule(Math.max(250, idleUntil - now));
                            } else {
                              resting = false;
                              schedule(nextTickDelay());
                            }
                          } else if (resting) {
                            schedule(Math.max(250, idleUntil - now));
                          } else {
                            schedule(250);
                          }
                          return;
                        }
                        if (current > target) {
                          current--;
                          el.textContent = String(current);
                        }
                        if (current === target) {
                          idleUntil = now + pauseMin + Math.random() * pauseExtra;
                          resting = true;
                          schedule(Math.max(250, idleUntil - now));
                        } else {
                          schedule(nextTickDelay());
                        }
                      }
                      tick();
                    })();
                  </script>
                </div>
              {% endif %}
