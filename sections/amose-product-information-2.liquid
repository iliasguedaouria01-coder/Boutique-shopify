            {% when 'description' %}
              <div
                class="amose-pi2__desc rte"
                style="
                  margin-top: {{ block.settings.margin_top | default: 0 }}px;
                  margin-bottom: {{ block.settings.margin_bottom | default: 0 }}px;
                "
                {{ block.shopify_attributes }}
              >
                {{ product.description }}
              </div>
            {% when 'stock_urgency' %}
              {% if block.settings.su_show != false %}
                {%- liquid
                  assign su_uid = block.id | handleize | default: 'su'
                  assign sold_pct = block.settings.su_sold_percent | default: block.settings.sold_percent | default: 93
                  if sold_pct < 1
                    assign sold_pct = 1
                  endif
                  if sold_pct > 100
                    assign sold_pct = 100
                  endif
                  assign su_status_raw = block.settings.su_status_text | default: block.settings.status_text | strip
                  if su_status_raw != blank
                    assign status_line = su_status_raw | replace: '{percent}', sold_pct
                  else
                    assign status_line = ''
                  endif
                  assign su_bar_radius = block.settings.su_bar_radius | default: block.settings.bar_radius | default: 50
                  if su_bar_radius >= 50
                    assign su_bar_radius_css = '9999px'
                  else
                    assign su_bar_radius_css = su_bar_radius | append: 'px'
                  endif
                  assign su_description = block.settings.su_description | default: block.settings.description
                  assign su_aria_label = status_line
                  if su_aria_label == blank
                    assign su_aria_label = su_description
                  endif
                  if su_aria_label == blank
                    assign su_aria_label = 'Stock availability'
                  endif
                -%}
                <div
                  class="amose-stock-urgency amose-stock-urgency--{{ su_uid }}"
                  style="
                    --su-fill: {{ sold_pct }}%;
                    --su-bar-fill: {{ block.settings.su_bar_fill_color | default: block.settings.bar_fill_color | default: '#9f4a54' }};
                    --su-bar-track: {{ block.settings.su_bar_track_color | default: block.settings.bar_track_color | default: '#e5e5e5' }};
                    --su-desc: {{ block.settings.su_description_color | default: block.settings.description_color | default: '#111111' }};
                    --su-status: {{ block.settings.su_status_color | default: block.settings.status_color | default: '#111111' }};
                    margin-top: {{ block.settings.su_margin_top | default: block.settings.margin_top | default: 20 }}px;
                    margin-bottom: {{ block.settings.su_margin_bottom | default: block.settings.margin_bottom | default: 12 }}px;
                  "
                  {{ block.shopify_attributes }}
                >
                  {% assign su_has_desc = false %}
                  {% if su_description != blank %}
                    {% assign su_has_desc = true %}
                  {% endif %}
                  {% assign su_has_status = false %}
                  {% if status_line != blank %}
                    {% assign su_has_status = true %}
                  {% endif %}
                  {% if su_has_desc or su_has_status %}
                    <div
                      class="amose-stock-urgency__meta-row{% unless su_has_desc %} amose-stock-urgency__meta-row--status-only{% endunless %}"
                      style="margin-bottom: {{ block.settings.su_bar_margin_top | default: block.settings.bar_margin_top | default: 10 }}px;"
                    >
                      {% if su_has_desc %}
                        <p
                          class="amose-stock-urgency__description"
                          style="
                            color: var(--su-desc);
                            font-size: {{ block.settings.su_description_size | default: block.settings.description_size | default: 14 }}px;
                            font-weight: {{ block.settings.su_description_weight | default: block.settings.description_weight | default: 400 }};
                          "
                        >
                          {{ su_description | escape }}
                        </p>
                      {% endif %}
                      {% if su_has_status %}
                        <p
                          class="amose-stock-urgency__status"
                          style="
                            color: var(--su-status);
                            font-size: {{ block.settings.su_status_size | default: block.settings.status_size | default: 14 }}px;
                            font-weight: {{ block.settings.su_status_weight | default: block.settings.status_weight | default: 700 }};
                          "
                        >
                          {{ status_line | escape }}
                        </p>
                      {% endif %}
                    </div>
                  {% endif %}
                  <div
                    class="amose-stock-urgency__bar"
                    role="progressbar"
                    aria-valuemin="0"
                    aria-valuemax="100"
                    aria-valuenow="{{ sold_pct }}"
                    aria-label="{{ su_aria_label | escape }}"
                    style="
                      height: {{ block.settings.su_bar_height | default: block.settings.bar_height | default: 8 }}px;
                      border-radius: {{ su_bar_radius_css }};
                      background: var(--su-bar-track);
                      margin-bottom: {{ block.settings.su_bar_margin_bottom | default: block.settings.bar_margin_bottom | default: 0 }}px;
                    "
                  >
                    <span
                      class="amose-stock-urgency__bar-fill"
                      style="
                        background: var(--su-bar-fill);
                        border-radius: {{ su_bar_radius_css }};
                      "
                    ></span>
                  </div>
                </div>
              {% endif %}
            {% when 'star_badge' %}
              {% assign rating_value = block.settings.rating_value | default: 4.7 | plus: 0 %}
              {% assign rating_width = rating_value | times: 20 %}
              <div
                class="kodu-star-badge-wrapper"
                style="margin-top: {{ block.settings.wrapper_margin_top }}px; margin-bottom: {{ block.settings.wrapper_margin_bottom }}px;"
                {{ block.shopify_attributes }}
              >
                <div
                  class="kodu-star-badge-row"
                  style="display:flex; align-items:center; flex-wrap:wrap; justify-content: {{ block.settings.align_web }}; gap: {{ block.settings.gap }}px;"
                >
                  <div class="kodu-star-badge-stars" style="position:relative; display:inline-flex;">
                    <div class="kodu-star-badge-empty" style="display:flex; gap:2px;">
                      {% for i in (1..5) %}
                        <svg class="kodu-star-svg" style="width: {{ block.settings.star_size }}px; height: {{ block.settings.star_size }}px; fill: {{ block.settings.empty_star_color }};" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l2.9 6.6L22 9.2l-5 4.9 1.2 7L12 17.8 5.8 21l1.2-7-5-4.9 7.1-0.6z"/></svg>
                      {% endfor %}
                    </div>
                    <div class="kodu-star-badge-full" style="position:absolute; top:0; left:0; overflow:hidden; height:100%; width: {{ rating_width }}%; display:flex; gap:2px;">
                      {% for i in (1..5) %}
                        <svg class="kodu-star-svg" style="width: {{ block.settings.star_size }}px; height: {{ block.settings.star_size }}px; fill: {{ block.settings.star_color }};" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l2.9 6.6L22 9.2l-5 4.9 1.2 7L12 17.8 5.8 21l1.2-7-5-4.9 7.1-0.6z"/></svg>
                      {% endfor %}
                    </div>
                  </div>
                  <div class="kodu-star-badge-text" style="font-size: {{ block.settings.text_size }}px; color: {{ block.settings.text_color }};">
                    <strong>{{ block.settings.rating_label }} {{ block.settings.rating_value }}</strong>
                    <span style="color: {{ block.settings.count_color }}; margin-left: 2px;">({{ block.settings.reviews_count }})</span>
                  </div>
                  {% if block.settings.show_badge %}
                    <div style="background: {{ block.settings.badge_bg }}; color: {{ block.settings.badge_text_color }}; padding: 2px 6px; border-radius: {{ block.settings.badge_radius }}px; font-size: {{ block.settings.badge_size }}px;">
                      {{ block.settings.badge_text }}
                    </div>
                  {% endif %}
                </div>
              </div>
            {% when 'benefits_list' %}
              <div
                class="amose-ben amose-ben--{{ block.id | handleize }}"
                style="
                  --ben-gap: {{ block.settings.row_gap }}px;
                  --ben-icon: {{ block.settings.icon_color }};
                  --ben-text: {{ block.settings.text_color }};
                  font-size: {{ block.settings.font_size }}px;
                  margin-top: {{ block.settings.wrapper_margin_top }}px;
                  margin-bottom: {{ block.settings.wrapper_margin_bottom }}px;
                "
                {{ block.shopify_attributes }}
              >
                <ul class="amose-ben__list" role="list" style="list-style:none; margin:0; padding:0; display:grid; gap:var(--ben-gap); width:fit-content; max-width:100%; margin-inline:0;">
                  {% if block.settings.benefit_1 != blank %}
                    <li class="amose-ben__row" style="display:grid; grid-template-columns:1.15em minmax(0, 1fr); column-gap:0.55em; align-items:start;">
                      <svg class="amose-ben__check" viewBox="0 0 24 24" fill="none" stroke="var(--ben-icon)" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="width:1.15em; height:1.15em; margin-top:0.14em;"><path d="M20 6L9 17l-5-5"/></svg>
                      <p class="amose-ben__text" style="color:var(--ben-text); line-height:1.45; margin:0;">{{ block.settings.benefit_1 }}</p>
                    </li>
                  {% endif %}
                  {% if block.settings.benefit_2 != blank %}
                    <li class="amose-ben__row" style="display:grid; grid-template-columns:1.15em minmax(0, 1fr); column-gap:0.55em; align-items:start;">
                      <svg class="amose-ben__check" viewBox="0 0 24 24" fill="none" stroke="var(--ben-icon)" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="width:1.15em; height:1.15em; margin-top:0.14em;"><path d="M20 6L9 17l-5-5"/></svg>
                      <p class="amose-ben__text" style="color:var(--ben-text); line-height:1.45; margin:0;">{{ block.settings.benefit_2 }}</p>
                    </li>
                  {% endif %}
                  {% if block.settings.benefit_3 != blank %}
                    <li class="amose-ben__row" style="display:grid; grid-template-columns:1.15em minmax(0, 1fr); column-gap:0.55em; align-items:start;">
                      <svg class="amose-ben__check" viewBox="0 0 24 24" fill="none" stroke="var(--ben-icon)" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="width:1.15em; height:1.15em; margin-top:0.14em;"><path d="M20 6L9 17l-5-5"/></svg>
                      <p class="amose-ben__text" style="color:var(--ben-text); line-height:1.45; margin:0;">{{ block.settings.benefit_3 }}</p>
                    </li>
                  {% endif %}
                </ul>
              </div>
            {% when 'shipping_timeline' %}
              {% assign timeline_date_locale = block.settings.date_locale | strip %}
              {% if timeline_date_locale == blank %}
                {% assign timeline_date_locale = request.locale.iso_code | default: 'en' %}
              {% endif %}
              <div
                class="amose-track"
                data-amose-track-root
                data-locale="{{ timeline_date_locale | escape }}"
                data-format="{{ block.settings.date_format | default: 'month_long_day' }}"
                data-step1-offset="{{ block.settings.step1_offset | default: 0 }}"
                data-step2-offset="{{ block.settings.step2_offset | default: 1 }}"
                data-step3-offset="{{ block.settings.step3_offset | default: 3 }}"
                data-dynamic-dates="{% if block.settings.use_dynamic_dates %}true{% else %}false{% endif %}"
                style="
                  --track-accent: {{ block.settings.accent_color }};
                  --track-icon-bg: {{ block.settings.icon_bg_color }};
                  --track-line: {{ block.settings.line_color }};
                  --track-text: {{ block.settings.text_color | default: '#171717' }};
                  --track-icon-size: {{ block.settings.icon_size }}px;
                  font-size: {{ block.settings.font_size }}px;
                "
                {{ block.shopify_attributes }}
              >
                <ol class="amose-track__list" role="list">
                  <li class="amose-track__item">
                    <div class="amose-track__icon-ring" aria-hidden="true"><i class="ph-duotone ph-calendar-check"></i></div>
                    <p class="amose-track__date" data-amose-track-date data-offset="{{ block.settings.step1_offset | default: 0 }}">{{ block.settings.step1_date }}</p>
                    <p class="amose-track__status">{{ block.settings.step1_label }}</p>
                  </li>
                  <li class="amose-track__item">
                    <div class="amose-track__icon-ring" aria-hidden="true"><i class="ph-duotone ph-package"></i></div>
                    <p class="amose-track__date" data-amose-track-date data-offset="{{ block.settings.step2_offset | default: 1 }}">{{ block.settings.step2_date }}</p>
                    <p class="amose-track__status">{{ block.settings.step2_label }}</p>
                  </li>
                  <li class="amose-track__item">
                    <div class="amose-track__icon-ring" aria-hidden="true"><i class="ph-duotone ph-truck"></i></div>
                    <p class="amose-track__date" data-amose-track-date data-offset="{{ block.settings.step3_offset | default: 3 }}">{{ block.settings.step3_date }}</p>
                    <p class="amose-track__status">{{ block.settings.step3_label }}</p>
                  </li>
                </ol>
                <script>
                  (function () {
                    var root = document.currentScript && document.currentScript.closest('[data-amose-track-root]');
                    if (!root) return;
                    if (root.getAttribute('data-dynamic-dates') !== 'true') return;
                    var locale = root.getAttribute('data-locale') || 'en';
                    var format = root.getAttribute('data-format') || 'month_long_day';
                    var optionMap = {
                      month_long_day: { month: 'long', day: 'numeric' },
                      month_short_day: { month: 'short', day: 'numeric' }
                    };
                    var dateOptions = optionMap[format] || optionMap.month_long_day;
                    var today = new Date();
                    var current = new Date(today.getFullYear(), today.getMonth(), today.getDate());
                    root.querySelectorAll('[data-amose-track-date]').forEach(function(node, idx) {
                      var fallbackOffset = parseInt(root.getAttribute('data-step' + (idx + 1) + '-offset'), 10);
                      var offset = parseInt(node.getAttribute('data-offset'), 10);
                      if (!Number.isFinite(offset)) offset = Number.isFinite(fallbackOffset) ? fallbackOffset : idx;
                      var eta = new Date(current.getFullYear(), current.getMonth(), current.getDate() + offset);
                      try {
                        node.textContent = new Intl.DateTimeFormat(locale, dateOptions).format(eta);
                      } catch (e) {
                        node.textContent = eta.toLocaleDateString(undefined, dateOptions);
                      }
                    });
                  })();
                </script>
              </div>
            {% when 'collapsible_row' %}
              <div class="amose-pi2__accordion amose-pi2__faq-main-col" {{ block.shopify_attributes }}>
                {% if block.settings.title != blank %}
                  <details>
                    <summary><span>{{ block.settings.title | escape }}</span><span class="amose-pi2__accordion-icon"></span></summary>
                    <div class="amose-pi2__accordion-content rte">{{ block.settings.content }}</div>
                  </details>
                {% endif %}
              </div>
            {% when '@app' %}
              <div {{ block.shopify_attributes }}>{% render block %}</div>
            {% when 'custom_liquid' %}
              <div {{ block.shopify_attributes }}>
                {{ block.settings.custom_liquid }}
              </div>
          {% endcase %}
        {% endfor %}
      {% endform %}
      {% endif %}
    </div>
  </div>
</div>

<script>
  (function() {
    var root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root) return;

    var variantPicker = root.querySelector('[data-amose-variant-picker]');
    if (variantPicker) {
      var variantsDataEl = variantPicker.querySelector('[data-amose-variants-data]');
      var variants = [];
      try {
        variants = JSON.parse(variantsDataEl && variantsDataEl.textContent || '[]');
      } catch (err) {
        variants = [];
      }

      var mainImg = root.querySelector('.amose-pi2__main-img');
      var thumbs = root.querySelectorAll('[data-amose-pi2-thumb]');
      var priceEl = root.querySelector('.amose-pi2__price > span:first-child');
      var compareEl = root.querySelector('.amose-pi2__price-compare');
      var idInput = variantPicker.querySelector('[name="id"]');
      var combinedSelect = variantPicker.querySelector('[data-amose-variant-select]');
      var optionSelects = variantPicker.querySelectorAll('[data-amose-option-select]');
      var optionBtns = variantPicker.querySelectorAll('[data-amose-option-btn]');
      function getSelectedOptions() {
        if (combinedSelect) return null;
        var count = optionSelects.length || (optionBtns.length ? Math.max.apply(null, Array.prototype.map.call(optionBtns, function(btn) {
          return parseInt(btn.getAttribute('data-option-index'), 10) + 1;
        })) : 0);
        var options = new Array(count);
        optionSelects.forEach(function(sel) {
          var idx = parseInt(sel.getAttribute('data-option-index'), 10);
          options[idx] = sel.value;
        });
        optionBtns.forEach(function(btn) {
          if (!btn.classList.contains('is-selected')) return;
          var idx = parseInt(btn.getAttribute('data-option-index'), 10);
          options[idx] = btn.getAttribute('data-option-value');
        });
        return options;
      }

      function findVariant() {
        if (combinedSelect) {
          var id = parseInt(combinedSelect.value, 10);
          return variants.find(function(v) { return v.id === id; }) || null;
        }
        var options = getSelectedOptions();
        if (!options || !options.length) return null;
        return variants.find(function(v) {
          if (!v.options || v.options.length < options.length) return false;
          for (var i = 0; i < options.length; i++) {
            if (v.options[i] !== options[i]) return false;
          }
          return true;
        }) || null;
      }

      function setMainImage(variant) {
        if (!mainImg || !variant || !variant.featured_image_src) return;
        mainImg.src = variant.featured_image_src;
        mainImg.alt = variant.featured_image_alt || mainImg.alt || '';
        if (thumbs.length) {
          thumbs.forEach(function(thumb) {
            var mediaId = thumb.getAttribute('data-media-id');
            var isMatch = mediaId && variant.featured_media_id && String(mediaId) === String(variant.featured_media_id);
            thumb.classList.toggle('is-active', isMatch);
          });
        }
      }

      function updateAvailability() {
        if (combinedSelect || !variants.length) return;
        var selected = getSelectedOptions();
        if (!selected) return;
        optionBtns.forEach(function(btn) {
          var idx = parseInt(btn.getAttribute('data-option-index'), 10);
          var value = btn.getAttribute('data-option-value');
          var testOptions = selected.slice();
          testOptions[idx] = value;
          var match = variants.find(function(v) {
            if (!v.options) return false;
            for (var i = 0; i < testOptions.length; i++) {
              if (v.options[i] !== testOptions[i]) return false;
            }
            return true;
          });
          btn.classList.toggle('is-unavailable', !match || !match.available);
          btn.disabled = !match || !match.available;
        });
      }

      function applyVariant(variant) {
        if (!variant) return;
        if (idInput) idInput.value = variant.id;
        if (combinedSelect) combinedSelect.value = String(variant.id);
        if (priceEl) priceEl.textContent = variant.price_formatted || priceEl.textContent;
        if (compareEl) {
          if (variant.compare_at_price && variant.price && variant.compare_at_price > variant.price) {
            compareEl.textContent = variant.compare_at_price_formatted;
            compareEl.style.display = '';
          } else {
            compareEl.style.display = 'none';
          }
        }
        setMainImage(variant);
        updateAvailability();
      }

      function onVariantChange() {
        var variant = findVariant();
        if (variant) applyVariant(variant);
      }

      if (combinedSelect) {
        combinedSelect.addEventListener('change', onVariantChange);
      }
      optionSelects.forEach(function(sel) {
        sel.addEventListener('change', onVariantChange);
      });
      optionBtns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          if (btn.disabled) return;
          var idx = btn.getAttribute('data-option-index');
          variantPicker.querySelectorAll('[data-amose-option-btn][data-option-index="' + idx + '"]').forEach(function(other) {
            other.classList.remove('is-selected');
          });
          btn.classList.add('is-selected');
          onVariantChange();
        });
      });

      updateAvailability();
    }

    var mainImg = root.querySelector('.amose-pi2__main-img');
    var thumbs = root.querySelectorAll('[data-amose-pi2-thumb]');
    if (mainImg && thumbs.length) {
      thumbs.forEach(function(thumb) {
        thumb.addEventListener('click', function() {
          var url = thumb.getAttribute('data-full-src');
          var alt = thumb.getAttribute('data-alt') || '';
          if (!url) return;
          mainImg.src = url;
          mainImg.alt = alt;
          thumbs.forEach(function(t) { t.classList.remove('is-active'); });
          thumb.classList.add('is-active');
        });
      });
    }

    var qtyInput = root.querySelector('.amose-pi2__qty');
    var minus = root.querySelector('[data-amose-pi2-qty-minus]');
    var plus = root.querySelector('[data-amose-pi2-qty-plus]');
    if (qtyInput && minus && plus) {
      minus.addEventListener('click', function() {
        qtyInput.value = Math.max(1, (parseInt(qtyInput.value || '1', 10) || 1) - 1);
      });
      plus.addEventListener('click', function() {
        qtyInput.value = (parseInt(qtyInput.value || '1', 10) || 1) + 1;
      });
    }

    var atcPriceTargets = root.querySelectorAll('[data-amose-atc-price]');
    if (atcPriceTargets.length) {
      var priceTextNode = root.querySelector('.amose-pi2__price > span:first-child');
      var syncAtcPrice = function() {
        if (!priceTextNode) return;
        var text = (priceTextNode.textContent || '').trim();
        if (!text) return;
        atcPriceTargets.forEach(function(node) {
          node.textContent = text;
        });
      };
      syncAtcPrice();
      if (priceTextNode && window.MutationObserver) {
        var obs = new MutationObserver(syncAtcPrice);
        obs.observe(priceTextNode, { characterData: true, childList: true, subtree: true });
      }
    }

    var shipRoots = root.querySelectorAll('[data-amose-ship-root]');
    shipRoots.forEach(function(shipRoot) {
      var out = shipRoot.querySelector('[data-amose-ship-date]');
      if (!out) return;
      var minD = parseInt(shipRoot.getAttribute('data-transit-min'), 10) || 3;
      var maxD = parseInt(shipRoot.getAttribute('data-transit-max'), 10) || 6;
      if (maxD < minD) maxD = minD;
      var today = new Date();
      today.setHours(0, 0, 0, 0);
      var seed = today.getFullYear() * 10000 + (today.getMonth() + 1) * 100 + today.getDate();
      var span = minD + (seed % ((maxD - minD + 1) || 1));
      var d = new Date(today);
      var added = 0;
      while (added < span) {
        d.setDate(d.getDate() + 1);
        var wd = d.getDay();
        if (wd !== 0 && wd !== 6) added++;
      }
      var locale = shipRoot.getAttribute('data-locale') || 'en';
      var opts = { weekday: 'long', month: 'long', day: 'numeric' };
      try {
        out.textContent = ' ' + d.toLocaleDateString(locale, opts);
      } catch (e) {
        out.textContent = ' ' + d.toDateString();
      }
    });
  })();
</script>

{%- unless amose_skip_install_mask -%}
<script>
  window.__AmoseInstallCheckPageStart = window.__AmoseInstallCheckPageStart || Date.now();
  window.__AmoseInstallCheckOrigin = {{ amose_install_origin | json }};
  window.AmoseSectionStatus = window.AmoseSectionStatus || [];
  window.AmoseSectionStatus.push({
    shop: {{ shop.permanent_domain | json }},
    sectionId: {{ section.id | json }},
    sectionType: "product-information-2"
  });

  window.AmoseStatusLoaderInserted = window.AmoseStatusLoaderInserted || false;

  if (!window.AmoseStatusLoaderInserted) {
    window.AmoseStatusLoaderInserted = true;
    var script = document.createElement("script");
    script.src = {{ amose_status_script_url | json }};
    script.defer = true;
    document.head.appendChild(script);
  }
</script>
{%- endunless -%}

