{%- liquid
  assign s = section.settings
  assign amose_install_origin = 'https://amosesection1-production.up.railway.app'
  assign amose_status_script_url = amose_install_origin | append: '/amose-section-status.js'
  assign amose_skip_install_mask = false
  if request.design_mode
    assign amose_skip_install_mask = true
  endif
  if theme.role == 'development'
    assign amose_skip_install_mask = true
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }}[class*="amose-"] {
    font-size: 16px;
  }
  #shopify-section-{{ section.id }}.amose-announcement-banner-root {
    --amose-ab-bg: {{ s.banner_bg }};
    --amose-ab-text: {{ s.text_color }};
    background: var(--amose-ab-bg);
    color: var(--amose-ab-text);
    padding-top: {{ s.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ s.padding_bottom | times: 0.75 | round: 0 }}px;
    margin: 0 !important;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }}.amose-announcement-banner-root {
      padding-top: {{ s.padding_top }}px;
      padding-bottom: {{ s.padding_bottom }}px;
    }
  }

  #shopify-section-{{ section.id }} .amose-ab__wrap {
    max-width: {{ s.max_width }}px;
    margin: 0 auto;
    padding: 0 clamp(16px, 4vw, 32px);
    box-sizing: border-box;
    text-align: {{ s.text_alignment | default: 'center' }};
  }

  #shopify-section-{{ section.id }} .amose-ab__message {
    margin: 0;
    font-size: clamp(14px, 1.1vw, 17px);
    line-height: 1.45;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--amose-ab-text);
  }
{%- endstyle -%}

{%- unless amose_skip_install_mask -%}
{%- style -%}
  #shopify-section-{{ section.id }}.amose-section-checking {
    display: none !important;
  }
{%- endstyle -%}
{%- endunless -%}

<div class="amose-ab__wrap">
  {% if s.message != blank %}
    <p class="amose-ab__message">{{ s.message | escape }}</p>
  {% endif %}
</div>

{%- unless amose_skip_install_mask -%}
<script>
  window.__AmoseInstallCheckPageStart = window.__AmoseInstallCheckPageStart || Date.now();
  window.__AmoseInstallCheckOrigin = {{ amose_install_origin | json }};
  window.AmoseSectionStatus = window.AmoseSectionStatus || [];
  window.AmoseSectionStatus.push({
    shop: {{ shop.permanent_domain | json }},
    sectionId: {{ section.id | json }},
    sectionType: "announcement-banner"
  });

  window.AmoseStatusLoaderInserted = window.AmoseStatusLoaderInserted || false;

  if (!window.AmoseStatusLoaderInserted) {
    window.AmoseStatusLoaderInserted = true;
    var script = document.createElement("script");
    script.src = {{ amose_status_script_url | json }};
    script.defer = true;
    document.head.appendChild(script);
  }
</script>
{%- endunless -%}

{% schema %}
{
  "name": "Announcement banner",
  "tag": "section",
  "class": "amose-announcement-banner-root",
  "settings": [
    {
      "type": "text",
      "id": "message",
      "label": "Message",
      "default": "A focused formula designed for consistent daily use and practical results you can feel over time."
    },
    {
      "type": "color",
      "id": "banner_bg",
      "label": "Background",
      "default": "#785aaf"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 960,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Max width",
      "default": 1400
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 14
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 14
    }
  ],
  "presets": [
    {
      "name": "Announcement banner"
    }
  ]
}
{% endschema %}
