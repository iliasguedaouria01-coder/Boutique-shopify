{%- liquid
  assign s = section.settings
  # App URLs for storefront install check (hardcoded; not theme settings).
  assign amose_install_origin = 'https://amosesection1-production.up.railway.app'
  assign amose_status_script_url = amose_install_origin | append: '/amose-section-status.js'
  # Theme editor + CLI dev themes: skip install-check masking JS.
  assign amose_skip_install_mask = false
  if request.design_mode
    assign amose_skip_install_mask = true
  endif
  if theme.role == 'development'
    assign amose_skip_install_mask = true
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }}[class*="amose-"] {
    font-size: 16px;
  }
  #shopify-section-{{ section.id }}.amose-faq-root {
    --amose-heading: clamp(22px, 2.5vw, 30px);
    --amose-body: clamp(14px, 1.2vw, 16px);
    --amose-lh-heading: 1.15;
    --amose-lh-body: 1.55;
    --amose-faq-bg: {{ s.section_bg }};
    --amose-faq-text: {{ s.text_color }};
    --amose-faq-muted: {{ s.muted_color }};
    --amose-faq-divider: {{ s.divider_color }};
    --amose-faq-badge-bg: {{ s.badge_bg }};
    --amose-faq-badge-text: {{ s.badge_text_color }};
    padding-top: {{ s.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ s.padding_bottom | times: 0.75 | round: 0 }}px;
    background: var(--amose-faq-bg);
    color: var(--amose-faq-text);
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }}.amose-faq-root {
      padding-top: {{ s.padding_top }}px;
      padding-bottom: {{ s.padding_bottom }}px;
    }
  }

  #shopify-section-{{ section.id }} .amose-faq__wrap {
    max-width: {{ s.max_width }}px;
    margin: 0 auto;
    padding: 0 clamp(16px, 4vw, 40px);
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .amose-faq__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(28px, 5vw, 48px);
    align-items: start;
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    #shopify-section-{{ section.id }} .amose-faq__wrap {
      padding: 0 clamp(20px, 3.2vw, 30px);
    }

    #shopify-section-{{ section.id }} .amose-faq__grid {
      grid-template-columns: minmax(0, 0.45fr) minmax(0, 1fr);
      gap: clamp(24px, 4vw, 36px);
    }
  }

  @media screen and (min-width: 900px) {
    #shopify-section-{{ section.id }} .amose-faq__grid {
      grid-template-columns: minmax(0, 0.42fr) minmax(0, 1fr);
      gap: clamp(40px, 6vw, 80px);
    }
  }

  #shopify-section-{{ section.id }} .amose-faq__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px 6px 10px;
    border-radius: 999px;
    background: var(--amose-faq-badge-bg);
    color: var(--amose-faq-badge-text);
    font-size: var(--amose-body);
    line-height: 1.3;
    font-weight: 500;
    margin: 0 0 16px;
  }

  #shopify-section-{{ section.id }} .amose-faq__badge-icon {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--amose-faq-badge-text);
    opacity: 0.85;
  }

  #shopify-section-{{ section.id }} .amose-faq__badge-icon svg {
    width: 14px;
    height: 14px;
    display: block;
  }

  #shopify-section-{{ section.id }} .amose-faq__heading {
    margin: 0;
    font-size: var(--amose-heading);
    font-weight: 700;
    line-height: var(--amose-lh-heading);
    letter-spacing: -0.02em;
    color: var(--amose-faq-text);
    max-width: min(100%, 36ch);
  }

  #shopify-section-{{ section.id }} .amose-faq__list {
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--amose-faq-divider);
  }

  #shopify-section-{{ section.id }} .amose-faq__item {
    margin: 0;
    padding: 0;
    border-bottom: 1px solid var(--amose-faq-divider);
  }

  #shopify-section-{{ section.id }} .amose-faq__item summary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: clamp(16px, 2vw, 20px) 0;
    cursor: pointer;
    font-size: var(--amose-body);
    line-height: var(--amose-lh-body);
    font-weight: 500;
    color: var(--amose-faq-text);
    -webkit-tap-highlight-color: transparent;
    outline: none;
  }

  #shopify-section-{{ section.id }} .amose-faq__item summary:focus-visible {
    outline: 2px solid var(--amose-faq-text);
    outline-offset: 4px;
    border-radius: 2px;
  }

  #shopify-section-{{ section.id }} .amose-faq__item summary::-webkit-details-marker {
    display: none;
  }

  #shopify-section-{{ section.id }} .amose-faq__question {
    flex: 1;
    text-align: left;
    padding-right: 8px;
  }

  #shopify-section-{{ section.id }} .amose-faq__toggle {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    position: relative;
    color: var(--amose-faq-text);
    opacity: 0.75;
  }

  #shopify-section-{{ section.id }} .amose-faq__toggle::before,
  #shopify-section-{{ section.id }} .amose-faq__toggle::after {
    content: "";
    position: absolute;
    background: currentColor;
    border-radius: 1px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  #shopify-section-{{ section.id }} .amose-faq__toggle::before {
    width: 12px;
    height: 2px;
  }

  #shopify-section-{{ section.id }} .amose-faq__toggle::after {
    width: 2px;
    height: 12px;
  }

  #shopify-section-{{ section.id }} .amose-faq__item[open] .amose-faq__toggle::after {
    transform: translate(-50%, -50%) scaleY(0);
    opacity: 0;
  }

  #shopify-section-{{ section.id }} .amose-faq__answer {
    padding: 0 32px clamp(16px, 2vw, 20px) 0;
    margin-top: -4px;
    font-size: var(--amose-body);
    line-height: var(--amose-lh-body);
    color: var(--amose-faq-muted);
  }

  #shopify-section-{{ section.id }} .amose-faq__answer p {
    margin: 0 0 0.75em;
  }

  #shopify-section-{{ section.id }} .amose-faq__answer p:last-child {
    margin-bottom: 0;
  }
{%- endstyle -%}

{%- unless amose_skip_install_mask -%}
{%- comment -%} Live storefront: section stays visible until JS confirms uninstall (then .amose-section-checking hides after a short delay). Skipped in editor & CLI dev themes. {%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }}.amose-section-checking {
    display: none !important;
  }
{%- endstyle -%}
{%- endunless -%}

<div class="amose-faq-visible-shell" data-amose-faq-visible>
<div class="amose-faq__wrap">
  <div class="amose-faq__grid">
    <div class="amose-faq__intro">
      {% if s.show_badge and s.badge_label != blank %}
        <div class="amose-faq__badge">
          <span class="amose-faq__badge-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round">
              <path d="M12 2l8 4.5v9L12 20l-8-4.5v-9L12 2z"></path>
              <path d="M12 12l8-4.5M12 12v9M12 12L4 7.5"></path>
            </svg>
          </span>
          <span>{{ s.badge_label | escape }}</span>
        </div>
      {% endif %}
      {% if s.heading != blank %}
        <h2 class="amose-faq__heading">{{ s.heading | escape }}</h2>
      {% endif %}
    </div>

    <div class="amose-faq__list">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'item' %}
            <details class="amose-faq__item" {{ block.shopify_attributes }}>
              <summary>
                <span class="amose-faq__question">{{ block.settings.question | escape }}</span>
                <span class="amose-faq__toggle" aria-hidden="true"></span>
              </summary>
              {% if block.settings.answer != blank %}
                <div class="amose-faq__answer rte">{{ block.settings.answer }}</div>
              {% endif %}
            </details>
        {% endcase %}
      {% endfor %}
    </div>
  </div>
</div>
</div>

{%- unless amose_skip_install_mask -%}
<script>
  window.__AmoseInstallCheckPageStart = window.__AmoseInstallCheckPageStart || Date.now();
  window.__AmoseInstallCheckOrigin = {{ amose_install_origin | json }};
  window.AmoseSectionStatus = window.AmoseSectionStatus || [];
  window.AmoseSectionStatus.push({
    shop: {{ shop.permanent_domain | json }},
    sectionId: {{ section.id | json }},
    sectionType: "faq"
  });

  window.AmoseStatusLoaderInserted = window.AmoseStatusLoaderInserted || false;

  if (!window.AmoseStatusLoaderInserted) {
    window.AmoseStatusLoaderInserted = true;
    var script = document.createElement("script");
    script.src = {{ amose_status_script_url | json }};
    script.defer = true;
    document.head.appendChild(script);
  }
</script>
{%- endunless -%}

{% schema %}
{
  "name": "Amose FAQ",
  "tag": "section",
  "class": "amose-faq-root",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 1000,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Max width",
      "default": 1400
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 56
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading & questions",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Answer text",
      "default": "#444444"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Dividers",
      "default": "#e8e8e8"
    },
    {
      "type": "color",
      "id": "badge_bg",
      "label": "Badge background",
      "default": "#f2f2f2"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge text",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show badge",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_label",
      "label": "Badge label",
      "default": "FAQs"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is included with my order?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Add a clear, helpful answer for your customers.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Amose FAQ",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "question": "How do I use this product?",
            "answer": "<p>Follow the directions on the label or as advised by your healthcare professional.</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "question": "What is your return policy?",
            "answer": "<p>We accept returns within the timeframe stated in our store policy. Contact support for help with your order.</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "question": "How long does shipping take?",
            "answer": "<p>Delivery times vary by region. You will receive tracking information once your order ships.</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "question": "Is this product right for me?",
            "answer": "<p>Please review the ingredients and consult a professional if you have specific health questions.</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "question": "Where are orders shipped from?",
            "answer": "<p>We ship from our fulfillment centers. Exact origin may appear on your tracking details.</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "question": "How can I contact support?",
            "answer": "<p>Reach us through the contact page or reply to your order confirmation email.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
