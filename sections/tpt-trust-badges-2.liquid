
{% comment %} Section layout style {% endcomment %}
{{ 'tpt-trust-badges-2.css' | asset_url | stylesheet_tag }}

{% assign original = section.settings.target %}
{% assign converted = original | replace: "-target", "-template" %}

{% style %}
  .{{ converted }}.tpt-trust-badges-2 {
    --badge-padding: {{ section.settings.badge_padding }}px;
    --icon-size: {{ section.settings.icon_size }}px;
    --title-font-size: {{ section.settings.title_font_size }}px;
    --subtitle-font-size: {{ section.settings.subtitle_font_size }}px;
    --title-color: {{ section.settings.title_color }};
    --subtitle-color: {{ section.settings.subtitle_color }};
    --border-color: {{ section.settings.border_color }};
  }
{% endstyle %}

<script>
  document.addEventListener('DOMContentLoaded', function () {
    {% comment %} const template = document.querySelector('[{{ converted }}]');
    const target = document.querySelector('[{{ original }}]'); {% endcomment %}
    const template = document.getElementById('{{ converted }}');
    const target = document.getElementById('{{ original }}');
    if (target && template) {
      target.appendChild(template.content.cloneNode(true));
    }
  });
</script>

{%- comment -%}
  Add this to target location:
  <div data-tpt-trust-badges-2-target></div>
{%- endcomment -%}

<template id="{{ converted }}">
  <div class="tpt-trust-badges-2 {{ converted }}">
    <div class="tpt-trust-badges-2_container">
      <div class="tpt-trust-badges-2_grid">
        {%- for block in section.blocks -%}
          <div class="tpt-trust-badges-2_item" {{ block.shopify_attributes }}>
            {%- if block.settings.badge_url != blank -%}
              <a href="{{ block.settings.badge_url }}" class="tpt-trust-badges-2_link"
                {%- assign mtm_link = block.settings.badge_url -%}
                {%- if mtm_link contains 'http' -%}
                  {% unless mtm_link contains shop.domain %} rel="nofollow" {% endunless %}
                {%- endif -%}
              >
            {%- endif -%}
            
            <div class="tpt-trust-badges-2_content">
              {%- if block.settings.badge_icon != blank -%}
                <div class="tpt-trust-badges-2_icon">
                  {%- assign image_alt = block.settings.badge_icon.alt | default: block.settings.badge_title -%}
                  {{
                    block.settings.badge_icon
                    | image_url: width: 120
                    | image_tag: alt: image_alt, loading: 'lazy'
                  }}
                </div>
              {%- endif -%}
              
              <div class="tpt-trust-badges-2_text">
                {%- if block.settings.badge_title != blank -%}
                  <div class="tpt-trust-badges-2_title">
                    {{ block.settings.badge_title }}
                  </div>
                {%- endif -%}
                
                {%- if block.settings.badge_subtitle != blank -%}
                  <div class="tpt-trust-badges-2_subtitle">
                    {{ block.settings.badge_subtitle }}
                  </div>
                {%- endif -%}
              </div>
            </div>
            
            {%- if block.settings.badge_url != blank -%}
              </a>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</template>{% style %}#shopify-section-{{ section.id }}{display: none !important;}{% endstyle %}


{% schema %}
{
  "name": "TptBLK-Trust Badges #2",
  "class": "section tpt-trust-badges-2",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Target"
    },
    {
      "type": "textarea",
      "id": "target",
      "label": "Target",
      "default": "data-tpt-trust-badges-2-target",
      "info": "Copy this code into the target area where you want to display the trust badges."
    },
    {
      "type": "header",
      "content": "Layout settings"
    },
    {
      "type": "header",
      "content": "Badge settings"
    },
    {
      "type": "range",
      "id": "badge_padding",
      "min": 10,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Badge padding",
      "default": 10
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#E5E5E5"
    },
    {
      "type": "header",
      "content": "Icon settings"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Icon size",
      "default": 40
    },
    {
      "type": "header",
      "content": "Text settings"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Title font size",
      "default": 12
    },
    {
      "type": "range",
      "id": "subtitle_font_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Subtitle font size",
      "default": 10
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle color",
      "default": "#666666"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "image_picker",
          "id": "badge_icon",
          "label": "Badge icon"
        },
        {
          "type": "text",
          "id": "badge_title",
          "label": "Badge title",
          "default": "Ships Free + Saves"
        },
        {
          "type": "text",
          "id": "badge_subtitle",
          "label": "Badge subtitle",
          "default": "Subscribe and save"
        },
        {
          "type": "url",
          "id": "badge_url",
          "label": "Badge link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "category": "Tpt block",
      "name": "TptBLK-Trust Badges #2",
      "blocks": [
        {
          "type": "badge",
          "settings": {
            "badge_title": "Vet-Approved Quality",
            "badge_subtitle": "Subscribe and save"
          }
        },
        {
          "type": "badge",
          "settings": {
            "badge_title": "Secure Checkout",
            "badge_subtitle": "Refillable tip jar"
          }
        },
        {
          "type": "badge",
          "settings": {
            "badge_title": "Easy Returns",
            "badge_subtitle": ""
          }
        },
        {
          "type": "badge",
          "settings": {
            "badge_title": "Fast Shipping",
            "badge_subtitle": ""
          }
        }
      ]
    }
  ]
} 
{% endschema %}