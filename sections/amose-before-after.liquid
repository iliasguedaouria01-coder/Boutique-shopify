{%- liquid
  assign s = section.settings
  assign amose_install_origin = 'https://amosesection1-production.up.railway.app'
  assign amose_status_script_url = amose_install_origin | append: '/amose-section-status.js'
  assign amose_skip_install_mask = false
  if request.design_mode
    assign amose_skip_install_mask = true
  endif
  if theme.role == 'development'
    assign amose_skip_install_mask = true
  endif
  assign ba_slider_start = s.slider_initial | default: 50
  assign img_before = s.image_before
  if img_before == blank
    assign img_before = s.image
  endif
  assign img_after = s.image_after
  assign show_compare = false
  if img_before != blank and img_after != blank
    assign show_compare = true
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }}[class*="amose-"] {
    font-size: 16px;
  }
  #shopify-section-{{ section.id }}.amose-before-after-root {
    --ba-bg: {{ s.section_bg }};
    --ba-text: {{ s.text_color }};
    --ba-muted: {{ s.muted_text_color }};
    --ba-handle: {{ s.handle_color | default: '#171717' }};
    --ba-slider-bar: {{ s.slider_bar_color | default: '#ffffff' }};
    --ba-badge-bg: {{ s.badge_bg | default: '#ffffff' }};
    --ba-badge-text: {{ s.badge_text_color | default: '#171717' }};
    --ba-badge-radius: {{ s.badge_radius | default: 6 }}px;
    --ba-pos: {{ ba_slider_start }}%;
    padding-top: {{ s.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ s.padding_bottom | times: 0.75 | round: 0 }}px;
    background: var(--ba-bg);
    color: var(--ba-text);
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }}.amose-before-after-root {
      padding-top: {{ s.padding_top }}px;
      padding-bottom: {{ s.padding_bottom }}px;
    }
  }

  #shopify-section-{{ section.id }} .amose-ba__wrap {
    max-width: {{ s.max_width }}px;
    margin: 0 auto;
    padding: 0 clamp(16px, 4vw, 40px);
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .amose-ba__intro {
    margin-bottom: clamp(18px, 3vw, 28px);
  }

  #shopify-section-{{ section.id }} .amose-ba__heading {
    margin: 0 0 8px;
    text-align: center;
    font-size: clamp(22px, 2.5vw, 30px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .amose-ba__subtitle {
    margin: 0;
    text-align: center;
    font-size: clamp(14px, 1.5vw, 17px);
    line-height: 1.45;
    color: var(--ba-muted);
    font-weight: 400;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .amose-ba__heading,
    #shopify-section-{{ section.id }} .amose-ba__subtitle {
      text-align: {{ s.mobile_heading_alignment | default: 'left' }};
    }
  }

  #shopify-section-{{ section.id }} .amose-ba__intro .amose-ba__heading:last-child {
    margin-bottom: 0;
  }

  #shopify-section-{{ section.id }} .amose-ba__layout {
    display: grid;
    gap: clamp(20px, 3vw, 32px);
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    #shopify-section-{{ section.id }} .amose-ba__wrap {
      padding: 0 clamp(20px, 3.2vw, 30px);
    }

    #shopify-section-{{ section.id }} .amose-ba__layout {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      align-items: center;
      gap: 22px;
    }

    #shopify-section-{{ section.id }} .amose-ba__steps,
    #shopify-section-{{ section.id }} .amose-ba__media {
      order: 0;
    }
  }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .amose-ba__steps {
      order: 1;
    }

    #shopify-section-{{ section.id }} .amose-ba__media {
      order: 2;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    #shopify-section-{{ section.id }} .amose-ba__steps,
    #shopify-section-{{ section.id }} .amose-ba__media {
      order: 0;
    }
  }

  @media screen and (min-width: 990px) {
    #shopify-section-{{ section.id }} .amose-ba__layout {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      align-items: center;
    }

    #shopify-section-{{ section.id }} .amose-ba__steps,
    #shopify-section-{{ section.id }} .amose-ba__media {
      order: 0;
    }
  }

  #shopify-section-{{ section.id }} .amose-ba__media {
    border-radius: {{ s.image_radius }}px;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.04);
    position: relative;
  }

  #shopify-section-{{ section.id }} .amose-ba__compare {
    position: relative;
    aspect-ratio: {{ s.image_aspect_ratio }};
    border-radius: inherit;
    touch-action: none;
    user-select: none;
    -webkit-user-select: none;
  }

  #shopify-section-{{ section.id }} .amose-ba__compare-single {
    aspect-ratio: {{ s.image_aspect_ratio }};
    border-radius: inherit;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .amose-ba__compare-single img,
  #shopify-section-{{ section.id }} .amose-ba__compare-single .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .amose-ba__compare-after {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .amose-ba__before-clip {
    position: absolute;
    inset: 0;
    clip-path: inset(0 calc(100% - var(--ba-pos, 50%)) 0 0);
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .amose-ba__before-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .amose-ba__handle {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--ba-pos, 50%);
    width: 44px;
    margin-left: -22px;
    z-index: 2;
    cursor: ew-resize;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 0;
    padding: 0;
    color: var(--ba-handle);
  }

  #shopify-section-{{ section.id }} .amose-ba__handle:focus-visible {
    outline: 2px solid var(--ba-text);
    outline-offset: 2px;
  }

  #shopify-section-{{ section.id }} .amose-ba__handle-line {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 5px;
    transform: translateX(-50%);
    background: var(--ba-slider-bar);
    border-radius: 2px;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.9),
      0 0 12px rgba(0, 0, 0, 0.18);
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .amose-ba__handle-knob {
    position: relative;
    width: 40px;
    height: 40px;
    border-radius: 999px;
    background: #fff;
    color: var(--ba-handle);
    box-shadow: none;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .amose-ba__handle-icon {
    font-size: 22px;
    line-height: 1;
    display: inline-block;
    color: var(--ba-handle);
  }

  #shopify-section-{{ section.id }} .amose-ba__ba-labels {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .amose-ba__ba-label {
    position: absolute;
    bottom: 10px;
    padding: 4px 10px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: var(--ba-badge-radius, 6px);
    background: var(--ba-badge-bg);
    color: var(--ba-badge-text);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
  }

  #shopify-section-{{ section.id }} .amose-ba__ba-label--before {
    left: 10px;
  }

  #shopify-section-{{ section.id }} .amose-ba__ba-label--after {
    right: 10px;
  }

  #shopify-section-{{ section.id }} .amose-ba__steps {
    display: grid;
    gap: clamp(12px, 2vw, 18px);
  }

  #shopify-section-{{ section.id }} .amose-ba__step {
    display: block;
  }

  #shopify-section-{{ section.id }} .amose-ba__kicker {
    margin: 0 0 2px;
    font-size: 13px;
    color: var(--ba-muted);
    line-height: 1.25;
    font-weight: 500;
  }

  #shopify-section-{{ section.id }} .amose-ba__title {
    margin: 0 0 3px;
    font-size: clamp(18px, 2vw, 24px);
    line-height: 1.12;
    letter-spacing: -0.02em;
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .amose-ba__text,
  #shopify-section-{{ section.id }} .amose-ba__text p {
    margin: 0;
    color: var(--ba-muted);
    line-height: 1.45;
    font-size: 14px;
  }
{%- endstyle -%}

{%- unless amose_skip_install_mask -%}
{%- comment -%} Install check: hide only after API says uninstalled (amose-section-status.js). {%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }}.amose-section-checking {
    display: none !important;
  }
{%- endstyle -%}
{%- endunless -%}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@phosphor-icons/web@2.1.1/src/regular/style.css">

<div class="amose-ba__wrap">
  {% if s.heading != blank or s.subtitle != blank %}
    <div class="amose-ba__intro">
      {% if s.heading != blank %}
        <h2 class="amose-ba__heading">{{ s.heading | escape }}</h2>
      {% endif %}
      {% if s.subtitle != blank %}
        <p class="amose-ba__subtitle">{{ s.subtitle | escape | newline_to_br }}</p>
      {% endif %}
    </div>
  {% endif %}
  <div class="amose-ba__layout">
    <div class="amose-ba__media">
      {% if show_compare %}
        <div
          class="amose-ba__compare"
          data-amose-ba-compare
          data-section-id="{{ section.id }}"
          data-initial="{{ ba_slider_start }}"
        >
          <img
            class="amose-ba__compare-after"
            src="{{ img_after | image_url: width: 1400 }}"
            alt="{{ img_after.alt | default: s.after_label | default: 'After' | escape }}"
            width="{{ img_after.width }}"
            height="{{ img_after.height }}"
            loading="lazy"
          >
          <div class="amose-ba__before-clip">
            <img
              class="amose-ba__before-img"
              src="{{ img_before | image_url: width: 1400 }}"
              alt="{{ img_before.alt | default: s.before_label | default: 'Before' | escape }}"
              width="{{ img_before.width }}"
              height="{{ img_before.height }}"
              loading="lazy"
            >
          </div>
          {% if s.before_label != blank or s.after_label != blank %}
            <div class="amose-ba__ba-labels" aria-hidden="true">
              {% if s.before_label != blank %}
                <span class="amose-ba__ba-label amose-ba__ba-label--before">{{ s.before_label | escape }}</span>
              {% endif %}
              {% if s.after_label != blank %}
                <span class="amose-ba__ba-label amose-ba__ba-label--after">{{ s.after_label | escape }}</span>
              {% endif %}
            </div>
          {% endif %}
          <button
            type="button"
            class="amose-ba__handle"
            aria-label="Drag to compare before and after"
            data-amose-ba-handle
          >
            <span class="amose-ba__handle-line" aria-hidden="true"></span>
            <span class="amose-ba__handle-knob" aria-hidden="true">
              <i class="ph ph-arrows-out-line-horizontal amose-ba__handle-icon" aria-hidden="true"></i>
            </span>
          </button>
        </div>
      {% elsif img_before != blank %}
        <div class="amose-ba__compare-single">
          <img
            src="{{ img_before | image_url: width: 1400 }}"
            alt="{{ img_before.alt | default: s.heading | escape }}"
            width="{{ img_before.width }}"
            height="{{ img_before.height }}"
            loading="lazy"
          >
        </div>
      {% elsif img_after != blank %}
        <div class="amose-ba__compare-single">
          <img
            src="{{ img_after | image_url: width: 1400 }}"
            alt="{{ img_after.alt | default: s.heading | escape }}"
            width="{{ img_after.width }}"
            height="{{ img_after.height }}"
            loading="lazy"
          >
        </div>
      {% else %}
        <div class="amose-ba__compare-single">
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {% endif %}
    </div>

    <div class="amose-ba__steps">
      {% for block in section.blocks %}
        {% if block.type == 'step' %}
          <div class="amose-ba__step" {{ block.shopify_attributes }}>
            <div>
              {% if block.settings.kicker != blank %}
                <p class="amose-ba__kicker">{{ block.settings.kicker | escape }}</p>
              {% endif %}
              {% if block.settings.title != blank %}
                <h3 class="amose-ba__title">{{ block.settings.title | escape }}</h3>
              {% endif %}
              {% if block.settings.text != blank %}
                <div class="amose-ba__text rte">{{ block.settings.text }}</div>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

{% if show_compare %}
  <script>
    (function () {
      var sectionId = {{ section.id | json }};
      var sel = '#shopify-section-' + sectionId + ' [data-amose-ba-compare]';

      function clamp(n, min, max) {
        return Math.min(max, Math.max(min, n));
      }

      function readPct(str) {
        var n = parseFloat(String(str || '').replace('%', ''));
        return isNaN(n) ? 50 : n;
      }

      function setPos(root, pct) {
        pct = clamp(pct, 0, 100);
        root.style.setProperty('--ba-pos', pct + '%');
        var btn = root.querySelector('[data-amose-ba-handle]');
        if (btn) btn.setAttribute('aria-valuenow', String(Math.round(pct)));
      }

      function initCompare(root) {
        if (!root || root.getAttribute('data-amose-ba-ready')) return;
        root.setAttribute('data-amose-ba-ready', '1');
        var handle = root.querySelector('[data-amose-ba-handle]');
        if (handle) {
          handle.setAttribute('role', 'slider');
          handle.setAttribute('aria-valuemin', '0');
          handle.setAttribute('aria-valuemax', '100');
          var ini = readPct(root.getAttribute('data-initial'));
          setPos(root, ini);
        }

        function pctFromClientX(clientX) {
          var r = root.getBoundingClientRect();
          if (r.width <= 0) return 50;
          return ((clientX - r.left) / r.width) * 100;
        }

        var dragging = false;

        function onPointerMove(e) {
          if (!dragging) return;
          e.preventDefault();
          setPos(root, pctFromClientX(e.clientX));
        }

        function onPointerUp() {
          dragging = false;
          document.removeEventListener('pointermove', onPointerMove);
          document.removeEventListener('pointerup', onPointerUp);
          document.removeEventListener('pointercancel', onPointerUp);
        }

        root.addEventListener('pointerdown', function (e) {
          if (e.target.closest('[data-amose-ba-handle]')) return;
          dragging = true;
          root.setPointerCapture(e.pointerId);
          setPos(root, pctFromClientX(e.clientX));
          document.addEventListener('pointermove', onPointerMove, { passive: false });
          document.addEventListener('pointerup', onPointerUp);
          document.addEventListener('pointercancel', onPointerUp);
        });

        if (handle) {
          handle.addEventListener('pointerdown', function (e) {
            e.stopPropagation();
            dragging = true;
            handle.setPointerCapture(e.pointerId);
            document.addEventListener('pointermove', onPointerMove, { passive: false });
            document.addEventListener('pointerup', onPointerUp);
            document.addEventListener('pointercancel', onPointerUp);
          });

          handle.addEventListener('keydown', function (e) {
            var cur = readPct(getComputedStyle(root).getPropertyValue('--ba-pos'));
            var step = e.shiftKey ? 10 : 3;
            if (e.key === 'ArrowLeft' || e.key === 'ArrowDown') {
              e.preventDefault();
              setPos(root, cur - step);
            } else if (e.key === 'ArrowRight' || e.key === 'ArrowUp') {
              e.preventDefault();
              setPos(root, cur + step);
            } else if (e.key === 'Home') {
              e.preventDefault();
              setPos(root, 0);
            } else if (e.key === 'End') {
              e.preventDefault();
              setPos(root, 100);
            }
          });
        }
      }

      function run() {
        var el = document.querySelector(sel);
        if (el) initCompare(el);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', run);
      } else {
        run();
      }

      document.addEventListener('shopify:section:load', function (e) {
        if (e.detail && String(e.detail.sectionId) === String(sectionId)) {
          var el = document.querySelector(sel);
          if (el) {
            el.removeAttribute('data-amose-ba-ready');
            initCompare(el);
          }
        }
      });
    })();
  </script>
{% endif %}

{%- unless amose_skip_install_mask -%}
<script>
  window.__AmoseInstallCheckPageStart = window.__AmoseInstallCheckPageStart || Date.now();
  window.__AmoseInstallCheckOrigin = {{ amose_install_origin | json }};
  window.AmoseSectionStatus = window.AmoseSectionStatus || [];
  window.AmoseSectionStatus.push({
    shop: {{ shop.permanent_domain | json }},
    sectionId: {{ section.id | json }},
    sectionType: "before-after"
  });

  window.AmoseStatusLoaderInserted = window.AmoseStatusLoaderInserted || false;

  if (!window.AmoseStatusLoaderInserted) {
    window.AmoseStatusLoaderInserted = true;
    var script = document.createElement("script");
    script.src = {{ amose_status_script_url | json }};
    script.defer = true;
    document.head.appendChild(script);
  }
</script>
{%- endunless -%}

{% schema %}
{
  "name": "Before-after",
  "tag": "section",
  "class": "amose-before-after-root",
  "max_blocks": 6,
  "settings": [
    { "type": "range", "id": "max_width", "min": 1000, "max": 1600, "step": 20, "unit": "px", "label": "Max width", "default": 1200 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top", "default": 56 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 56 },
    { "type": "range", "id": "image_radius", "min": 0, "max": 28, "step": 2, "unit": "px", "label": "Image radius", "default": 14 },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        { "value": "4 / 3", "label": "Landscape" },
        { "value": "1 / 1", "label": "Square" },
        { "value": "3 / 4", "label": "Portrait" }
      ],
      "default": "4 / 3"
    },
    { "type": "text", "id": "heading", "label": "Heading", "default": "A Healthier Gut, Step by Step" },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "See how consistent care can support your gut over time.",
      "info": "Shown below the heading."
    },
    {
      "type": "select",
      "id": "mobile_heading_alignment",
      "label": "Mobile heading alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    { "type": "image_picker", "id": "image_before", "label": "Before image" },
    { "type": "image_picker", "id": "image_after", "label": "After image" },
    { "type": "image_picker", "id": "image", "label": "Image (legacy)", "info": "Used only if Before image is empty." },
    { "type": "text", "id": "before_label", "label": "Before label", "default": "Before" },
    { "type": "text", "id": "after_label", "label": "After label", "default": "After" },
    { "type": "color", "id": "badge_bg", "label": "Before/After badge background", "default": "#ffffff" },
    { "type": "color", "id": "badge_text_color", "label": "Before/After badge text", "default": "#171717" },
    { "type": "range", "id": "badge_radius", "min": 0, "max": 28, "step": 1, "unit": "px", "label": "Before/After badge radius", "default": 6 },
    { "type": "range", "id": "slider_initial", "min": 5, "max": 95, "step": 1, "unit": "%", "label": "Slider start position", "default": 50 },
    { "type": "color", "id": "slider_bar_color", "label": "Slider bar (vertical line)", "default": "#ffffff" },
    { "type": "color", "id": "handle_color", "label": "Slider knob & icons", "default": "#171717" },
    { "type": "color", "id": "section_bg", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#171717" },
    { "type": "color", "id": "muted_text_color", "label": "Muted text", "default": "#525252" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "kicker", "label": "Small label", "default": "Weeks 1-2" },
        { "type": "text", "id": "title", "label": "Title", "default": "Gut Adjustment Begins" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Your microbiome begins adapting to the probiotic strains. Some users notice less digestive discomfort as beneficial bacteria begin to balance the gut.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Before-after",
      "blocks": [
        { "type": "step" },
        {
          "type": "step",
          "settings": {
            "kicker": "Weeks 3-4",
            "title": "Improved Digestive Balance",
            "text": "<p>As microbial diversity improves, digestion may feel smoother and occasional bloating may decrease with consistent use.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "kicker": "Months 2-3+",
            "title": "Stronger Gut Support",
            "text": "<p>With continued daily use, the microbiome becomes more balanced, helping support digestion, immune health, and overall gut wellness.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
