{%- liquid
  assign s = section.settings
  assign amose_install_origin = 'https://amosesection1-production.up.railway.app'
  assign amose_status_script_url = amose_install_origin | append: '/amose-section-status.js'
  assign amose_skip_install_mask = false
  if request.design_mode
    assign amose_skip_install_mask = true
  endif
  if theme.role == 'development'
    assign amose_skip_install_mask = true
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }}.amose-comp2-root {
    --amose-comp2-bg: {{ s.section_bg }};
    --amose-comp2-text: {{ s.text_color }};
    --amose-comp2-muted: {{ s.subtext_color }};
    --amose-comp2-line: {{ s.line_color }};
    --amose-comp2-product-bg: {{ s.product_column_bg }};
    --amose-comp2-product-border: {{ s.product_column_border }};
    --amose-comp2-others-bg: {{ s.others_column_bg }};
    --amose-comp2-check-bg: {{ s.check_bg }};
    --amose-comp2-check-icon: {{ s.check_icon }};
    --amose-comp2-cross-bg: {{ s.cross_bg }};
    --amose-comp2-cross-icon: {{ s.cross_icon }};
    --amose-comp2-btn-bg: {{ s.button_bg }};
    --amose-comp2-btn-text: {{ s.button_text }};
    --amose-heading: clamp(22px, 2.5vw, 30px);
    --amose-body: clamp(14px, 1.2vw, 16px);
    padding-top: {{ s.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ s.padding_bottom | times: 0.75 | round: 0 }}px;
    background: var(--amose-comp2-bg);
    color: var(--amose-comp2-text);
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }}.amose-comp2-root {
      padding-top: {{ s.padding_top }}px;
      padding-bottom: {{ s.padding_bottom }}px;
    }
  }

  #shopify-section-{{ section.id }} .amose-comp2 {
    max-width: {{ s.max_width }}px;
    margin: 0 auto;
    padding: 0 clamp(16px, 4vw, 40px);
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .amose-comp2__title {
    margin: 0;
    text-align: center;
    font-size: var(--amose-heading);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .amose-comp2__sub {
    margin: 14px auto 0;
    text-align: center;
    max-width: 56ch;
    color: var(--amose-comp2-muted);
    font-size: var(--amose-body);
    line-height: 1.55;
  }

  #shopify-section-{{ section.id }} .amose-comp2__sub p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .amose-comp2__panel {
    margin-top: clamp(24px, 4vw, 34px);
    border: 1px solid var(--amose-comp2-line);
    border-radius: 16px;
    overflow: hidden;
    background: #ffffff;
  }

  #shopify-section-{{ section.id }} .amose-comp2__head,
  #shopify-section-{{ section.id }} .amose-comp2__row {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(88px, 0.82fr) minmax(88px, 0.82fr);
    align-items: stretch;
  }

  #shopify-section-{{ section.id }} .amose-comp2__head {
    border-bottom: 1px solid var(--amose-comp2-line);
    background: rgba(255, 255, 255, 0.92);
  }

  #shopify-section-{{ section.id }} .amose-comp2__head-feature {
    padding: 14px 16px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--amose-comp2-muted);
    display: flex;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .amose-comp2__head-col {
    padding: 12px 10px;
    text-align: center;
    font-size: clamp(13px, 1.2vw, 15px);
    line-height: 1.25;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    border-left: 1px solid var(--amose-comp2-line);
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  #shopify-section-{{ section.id }} .amose-comp2__head-col--product {
    background: var(--amose-comp2-product-bg);
    color: var(--amose-comp2-text);
  }

  #shopify-section-{{ section.id }} .amose-comp2__head-col--others {
    background: var(--amose-comp2-others-bg);
    color: var(--amose-comp2-muted);
  }

  #shopify-section-{{ section.id }} .amose-comp2__row + .amose-comp2__row {
    border-top: 1px solid var(--amose-comp2-line);
  }

  #shopify-section-{{ section.id }} .amose-comp2__feature {
    padding: 14px 16px;
    font-size: var(--amose-body);
    line-height: 1.4;
    font-weight: 500;
    display: flex;
    align-items: center;
    min-height: 52px;
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .amose-comp2__cell {
    display: flex;
    align-items: center;
    justify-content: center;
    border-left: 1px solid var(--amose-comp2-line);
    min-height: 52px;
    padding: 10px 8px;
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .amose-comp2__cell--product {
    background: color-mix(in srgb, var(--amose-comp2-product-bg) 72%, #ffffff);
  }

  #shopify-section-{{ section.id }} .amose-comp2__cell--others {
    background: color-mix(in srgb, var(--amose-comp2-others-bg) 55%, #ffffff);
  }

  #shopify-section-{{ section.id }} .amose-comp2__icon {
    display: inline-flex;
    width: 30px;
    height: 30px;
    border-radius: 999px;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .amose-comp2__icon svg {
    width: 16px;
    height: 16px;
  }

  #shopify-section-{{ section.id }} .amose-comp2__icon--check {
    background: var(--amose-comp2-check-bg);
    color: var(--amose-comp2-check-icon);
  }

  #shopify-section-{{ section.id }} .amose-comp2__icon--cross {
    background: var(--amose-comp2-cross-bg);
    color: var(--amose-comp2-cross-icon);
  }

  #shopify-section-{{ section.id }} .amose-comp2__cta-wrap {
    margin-top: 24px;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .amose-comp2__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    background: var(--amose-comp2-btn-bg);
    color: var(--amose-comp2-btn-text);
    border-radius: 999px;
    min-height: 48px;
    padding: 0 28px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .amose-comp2__head,
    #shopify-section-{{ section.id }} .amose-comp2__row {
      grid-template-columns: minmax(0, 1.2fr) minmax(72px, 0.9fr) minmax(72px, 0.9fr);
    }

    #shopify-section-{{ section.id }} .amose-comp2__head-feature {
      font-size: 11px;
      padding: 12px 10px;
    }

    #shopify-section-{{ section.id }} .amose-comp2__head-col {
      font-size: 12px;
      padding: 10px 6px;
    }

    #shopify-section-{{ section.id }} .amose-comp2__feature {
      font-size: 14px;
      padding: 12px 10px;
    }

    #shopify-section-{{ section.id }} .amose-comp2__icon {
      width: 26px;
      height: 26px;
    }

    #shopify-section-{{ section.id }} .amose-comp2__icon svg {
      width: 14px;
      height: 14px;
    }
  }
{%- endstyle -%}

{%- unless amose_skip_install_mask -%}
{%- style -%}
  #shopify-section-{{ section.id }}.amose-section-checking {
    display: none !important;
  }
{%- endstyle -%}
{%- endunless -%}

<div class="amose-comp2">
  {% if s.heading != blank %}
    <h2 class="amose-comp2__title">{{ s.heading | escape }}</h2>
  {% endif %}
  {% if s.subtext != blank %}
    <div class="amose-comp2__sub rte">{{ s.subtext }}</div>
  {% endif %}

  <div class="amose-comp2__panel" role="region" aria-label="{{ s.heading | default: 'Product comparison' | escape }}">
    <div class="amose-comp2__head">
      <div class="amose-comp2__head-feature">{{ s.feature_column_label | default: 'What matters' | escape }}</div>
      <div class="amose-comp2__head-col amose-comp2__head-col--product">{{ s.left_column_heading | escape }}</div>
      <div class="amose-comp2__head-col amose-comp2__head-col--others">{{ s.right_column_heading | escape }}</div>
    </div>

    {% for block in section.blocks %}
      {% if block.type == 'row' %}
        <div class="amose-comp2__row" {{ block.shopify_attributes }}>
          <div class="amose-comp2__feature">{{ block.settings.feature | escape }}</div>
          <div class="amose-comp2__cell amose-comp2__cell--product">
            <span class="amose-comp2__icon {% if block.settings.left_included %}amose-comp2__icon--check{% else %}amose-comp2__icon--cross{% endif %}">
              {% if block.settings.left_included %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 13l4 4L19 7"></path>
                </svg>
              {% else %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true">
                  <path d="M7 7l10 10M17 7L7 17"></path>
                </svg>
              {% endif %}
            </span>
          </div>
          <div class="amose-comp2__cell amose-comp2__cell--others">
            <span class="amose-comp2__icon {% if block.settings.right_included %}amose-comp2__icon--check{% else %}amose-comp2__icon--cross{% endif %}">
              {% if block.settings.right_included %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 13l4 4L19 7"></path>
                </svg>
              {% else %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true">
                  <path d="M7 7l10 10M17 7L7 17"></path>
                </svg>
              {% endif %}
            </span>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% if s.button_label != blank %}
    <div class="amose-comp2__cta-wrap">
      <a
        class="amose-comp2__cta"
        data-amose-comp2-cta
        {% if s.button_link != blank %}
          href="{{ s.button_link }}"
        {% else %}
          href="#amose-product-information-top"
          data-scroll-to-product-info="true"
        {% endif %}
      >
        {{ s.button_label | escape }}
      </a>
    </div>
  {% endif %}
</div>

<script>
  (function () {
    var root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root) return;
    var cta = root.querySelector('[data-amose-comp2-cta]');
    if (!cta || cta.getAttribute('data-scroll-to-product-info') !== 'true') return;
    cta.addEventListener('click', function (event) {
      event.preventDefault();
      var target = document.getElementById('amose-product-information-top');
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        return;
      }
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  })();
</script>

{%- unless amose_skip_install_mask -%}
<script>
  window.__AmoseInstallCheckPageStart = window.__AmoseInstallCheckPageStart || Date.now();
  window.__AmoseInstallCheckOrigin = {{ amose_install_origin | json }};
  window.AmoseSectionStatus = window.AmoseSectionStatus || [];
  window.AmoseSectionStatus.push({
    shop: {{ shop.permanent_domain | json }},
    sectionId: {{ section.id | json }},
    sectionType: "comparison-table-2"
  });

  window.AmoseStatusLoaderInserted = window.AmoseStatusLoaderInserted || false;

  if (!window.AmoseStatusLoaderInserted) {
    window.AmoseStatusLoaderInserted = true;
    var script = document.createElement("script");
    script.src = {{ amose_status_script_url | json }};
    script.defer = true;
    document.head.appendChild(script);
  }
</script>
{%- endunless -%}

{% schema %}
{
  "name": "Comparison table 2",
  "tag": "section",
  "class": "amose-comp2-root",
  "settings": [
    { "type": "header", "content": "Layout" },
    {
      "type": "range",
      "id": "max_width",
      "min": 1000,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Max width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 52
    },
    { "type": "header", "content": "Content" },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How this product compares"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "<p>See what you get with a thoughtful formula versus typical alternatives.</p>"
    },
    {
      "type": "text",
      "id": "feature_column_label",
      "label": "Feature column label",
      "default": "What matters"
    },
    {
      "type": "text",
      "id": "left_column_heading",
      "label": "Your product column",
      "default": "This product"
    },
    {
      "type": "text",
      "id": "right_column_heading",
      "label": "Comparison column",
      "default": "Others"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Choose this product"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    { "type": "header", "content": "Colors" },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Main text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Border color",
      "default": "#e5e7eb"
    },
    {
      "type": "color",
      "id": "product_column_bg",
      "label": "Product column background",
      "default": "#f1e9fd"
    },
    {
      "type": "color",
      "id": "product_column_border",
      "label": "Product column accent",
      "default": "#785aaf"
    },
    {
      "type": "color",
      "id": "others_column_bg",
      "label": "Others column background",
      "default": "#f8fafc"
    },
    {
      "type": "color",
      "id": "check_bg",
      "label": "Check icon background",
      "default": "#785aaf"
    },
    {
      "type": "color",
      "id": "check_icon",
      "label": "Check icon color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "cross_bg",
      "label": "Cross icon background",
      "default": "rgba(0,0,0,0.12)"
    },
    {
      "type": "color",
      "id": "cross_icon",
      "label": "Cross icon color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#785aaf"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button text color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Comparison row",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "Feature",
          "default": "Clear ingredient label"
        },
        {
          "type": "checkbox",
          "id": "left_included",
          "label": "Included in your product column",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "right_included",
          "label": "Included in comparison column",
          "default": false
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Comparison table 2",
      "blocks": [
        { "type": "row", "settings": { "feature": "Clear ingredient label", "left_included": true, "right_included": false } },
        { "type": "row", "settings": { "feature": "Simple daily routine", "left_included": true, "right_included": false } },
        { "type": "row", "settings": { "feature": "Comfort-first format", "left_included": true, "right_included": false } },
        { "type": "row", "settings": { "feature": "Consistent quality", "left_included": true, "right_included": false } },
        { "type": "row", "settings": { "feature": "Fast to apply", "left_included": true, "right_included": false } },
        { "type": "row", "settings": { "feature": "Routine-friendly fit", "left_included": true, "right_included": false } }
      ]
    }
  ]
}
{% endschema %}
