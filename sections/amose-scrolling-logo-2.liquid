{%- liquid
  assign s = section.settings
  assign amose_install_origin = 'https://amosesection1-production.up.railway.app'
  assign amose_status_script_url = amose_install_origin | append: '/amose-section-status.js'
  assign amose_skip_install_mask = false
  if request.design_mode
    assign amose_skip_install_mask = true
  endif
  if theme.role == 'development'
    assign amose_skip_install_mask = true
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }}.amose-sl2-root {
    --sl2-bg: {{ s.section_bg }};
    --sl2-gap: {{ s.logo_gap }}px;
    --sl2-logo-height: {{ s.logo_height }}px;
    --sl2-duration: {{ s.scroll_speed }}s;
    background: var(--sl2-bg);
    padding-top: {{ s.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ s.padding_bottom | times: 0.75 | round: 0 }}px;
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }}.amose-sl2-root {
      padding-top: {{ s.padding_top }}px;
      padding-bottom: {{ s.padding_bottom }}px;
    }
  }

  #shopify-section-{{ section.id }} .amose-sl2__wrap {
    width: 100%;
    max-width: {{ s.max_width }}px;
    margin: 0 auto;
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .amose-sl2__rail {
    overflow: hidden;
    width: 100%;
    -webkit-mask-image: linear-gradient(to right, transparent 0, #000 6%, #000 94%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0, #000 6%, #000 94%, transparent 100%);
  }

  #shopify-section-{{ section.id }} .amose-sl2__track {
    display: flex;
    width: max-content;
    gap: var(--sl2-gap);
    animation: amose-sl2-scroll-{{ section.id }} var(--sl2-duration) linear infinite;
    will-change: transform;
  }

  #shopify-section-{{ section.id }} .amose-sl2__group {
    display: flex;
    align-items: center;
    gap: var(--sl2-gap);
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .amose-sl2__item {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: clamp(100px, 14vw, 180px);
    min-height: calc(var(--sl2-logo-height) + 8px);
    opacity: 0.98;
  }

  #shopify-section-{{ section.id }} .amose-sl2__item img {
    width: auto;
    height: auto;
    max-width: min(200px, 20vw);
    max-height: var(--sl2-logo-height);
    object-fit: contain;
    display: block;
    filter: grayscale(1) contrast(1.1);
  }

  #shopify-section-{{ section.id }} .amose-sl2__fallback-logo {
    margin: 0;
    font-size: clamp(24px, 2.8vw, 48px);
    line-height: 1;
    letter-spacing: -0.02em;
    font-weight: 700;
    white-space: nowrap;
    color: #171717;
  }

  @keyframes amose-sl2-scroll-{{ section.id }} {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(calc(-50% - (var(--sl2-gap) / 2)));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .amose-sl2__track {
      animation: none;
    }
  }
{%- endstyle -%}

{%- unless amose_skip_install_mask -%}
{%- style -%}
  #shopify-section-{{ section.id }}.amose-section-checking {
    display: none !important;
  }
{%- endstyle -%}
{%- endunless -%}

<div class="amose-sl2__wrap">
  <div class="amose-sl2__rail" aria-label="Scrolling logos">
    <div class="amose-sl2__track" role="presentation">
      <div class="amose-sl2__group">
        {% for block in section.blocks %}
          <div class="amose-sl2__item" {{ block.shopify_attributes }}>
            {% if block.settings.logo_image != blank %}
              <img
                src="{{ block.settings.logo_image | image_url: width: 500 }}"
                alt="{{ block.settings.logo_alt | default: block.settings.logo_text | escape }}"
                loading="lazy"
                width="{{ block.settings.logo_image.width }}"
                height="{{ block.settings.logo_image.height }}"
              >
            {% elsif block.settings.logo_text != blank %}
              <p class="amose-sl2__fallback-logo">{{ block.settings.logo_text | escape }}</p>
            {% endif %}
          </div>
        {% endfor %}
      </div>

      <div class="amose-sl2__group" aria-hidden="true">
        {% for block in section.blocks %}
          <div class="amose-sl2__item">
            {% if block.settings.logo_image != blank %}
              <img
                src="{{ block.settings.logo_image | image_url: width: 500 }}"
                alt=""
                loading="lazy"
                width="{{ block.settings.logo_image.width }}"
                height="{{ block.settings.logo_image.height }}"
              >
            {% elsif block.settings.logo_text != blank %}
              <p class="amose-sl2__fallback-logo">{{ block.settings.logo_text | escape }}</p>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{%- unless amose_skip_install_mask -%}
<script>
  window.__AmoseInstallCheckPageStart = window.__AmoseInstallCheckPageStart || Date.now();
  window.__AmoseInstallCheckOrigin = {{ amose_install_origin | json }};
  window.AmoseSectionStatus = window.AmoseSectionStatus || [];
  window.AmoseSectionStatus.push({
    shop: {{ shop.permanent_domain | json }},
    sectionId: {{ section.id | json }},
    sectionType: "scrolling-logo-2"
  });

  window.AmoseStatusLoaderInserted = window.AmoseStatusLoaderInserted || false;

  if (!window.AmoseStatusLoaderInserted) {
    window.AmoseStatusLoaderInserted = true;
    var script = document.createElement("script");
    script.src = {{ amose_status_script_url | json }};
    script.defer = true;
    document.head.appendChild(script);
  }
</script>
{%- endunless -%}

{% schema %}
{
  "name": "Scrolling logo 2",
  "tag": "section",
  "class": "amose-sl2-root",
  "max_blocks": 16,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 1000,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Max width",
      "default": 1400
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 20,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Logo max height",
      "default": 48
    },
    {
      "type": "range",
      "id": "logo_gap",
      "min": 12,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Gap between logos",
      "default": 48
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "min": 12,
      "max": 90,
      "step": 1,
      "unit": "s",
      "label": "Scroll duration",
      "default": 32
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo_image",
          "label": "Logo image"
        },
        {
          "type": "text",
          "id": "logo_alt",
          "label": "Image alt text",
          "default": "Brand logo"
        },
        {
          "type": "text",
          "id": "logo_text",
          "label": "Fallback text (if no image)",
          "info": "Shown only when no logo image is uploaded."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scrolling logo 2",
      "blocks": [
        { "type": "logo", "settings": { "logo_text": "VOGUE", "logo_alt": "Vogue logo" } },
        { "type": "logo", "settings": { "logo_text": "Forbes", "logo_alt": "Forbes logo" } },
        { "type": "logo", "settings": { "logo_text": "ELLE", "logo_alt": "Elle logo" } },
        { "type": "logo", "settings": { "logo_text": "GQ", "logo_alt": "GQ logo" } },
        { "type": "logo", "settings": { "logo_text": "WIRED", "logo_alt": "Wired logo" } }
      ]
    }
  ]
}
{% endschema %}
