{%- liquid
  assign s = section.settings
  assign amose_install_origin = 'https://amosesection1-production.up.railway.app'
  assign amose_status_script_url = amose_install_origin | append: '/amose-section-status.js'
  assign amose_skip_install_mask = false
  if request.design_mode
    assign amose_skip_install_mask = true
  endif
  if theme.role == 'development'
    assign amose_skip_install_mask = true
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }}.amose-comparison-root {
    --amose-comp-bg: {{ s.section_bg }};
    --amose-comp-text: {{ s.text_color }};
    --amose-comp-muted: {{ s.subtext_color }};
    --amose-comp-line: {{ s.line_color }};
    --amose-comp-highlight: {{ s.highlight_bg }};
    --amose-comp-check-bg: {{ s.check_bg }};
    --amose-comp-check-icon: {{ s.check_icon }};
    --amose-comp-cross-bg: {{ s.cross_bg }};
    --amose-comp-cross-icon: {{ s.cross_icon }};
    --amose-comp-btn-bg: {{ s.button_bg }};
    --amose-comp-btn-text: {{ s.button_text }};
    --amose-heading: clamp(22px, 2.5vw, 30px);
    --amose-body: clamp(14px, 1.2vw, 16px);
    padding-top: {{ s.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ s.padding_bottom | times: 0.75 | round: 0 }}px;
    background: var(--amose-comp-bg);
    color: var(--amose-comp-text);
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }}.amose-comparison-root {
      padding-top: {{ s.padding_top }}px;
      padding-bottom: {{ s.padding_bottom }}px;
    }
  }

  #shopify-section-{{ section.id }} .amose-comp {
    max-width: {{ s.max_width }}px;
    margin: 0 auto;
    padding: 0 clamp(16px, 4vw, 40px);
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .amose-comp__title {
    margin: 0;
    text-align: center;
    font-size: var(--amose-heading);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .amose-comp__sub {
    margin: 14px auto 0;
    text-align: center;
    max-width: 56ch;
    color: var(--amose-comp-muted);
    font-size: var(--amose-body);
    line-height: 1.55;
  }

  #shopify-section-{{ section.id }} .amose-comp__sub p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .amose-comp__table-wrap {
    margin-top: clamp(24px, 4vw, 34px);
    overflow-x: auto;
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    #shopify-section-{{ section.id }} .amose-comp {
      padding: 0 clamp(20px, 3.2vw, 30px);
    }

    #shopify-section-{{ section.id }} .amose-comp__table thead th {
      font-size: clamp(15px, 1.9vw, 18px);
      padding: 12px 10px;
    }

    #shopify-section-{{ section.id }} .amose-comp__table tbody td {
      padding: 11px 10px;
    }
  }

  #shopify-section-{{ section.id }} .amose-comp__table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }

  #shopify-section-{{ section.id }} .amose-comp__table thead th {
    font-size: clamp(16px, 1.4vw, 24px);
    line-height: 1.2;
    font-weight: 700;
    padding: 16px 12px;
    text-align: center;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  #shopify-section-{{ section.id }} .amose-comp__table thead th:first-child {
    text-align: left;
    width: 34%;
  }

  #shopify-section-{{ section.id }} .amose-comp__table thead th:nth-child(2),
  #shopify-section-{{ section.id }} .amose-comp__table thead th:nth-child(3) {
    width: 33%;
  }

  #shopify-section-{{ section.id }} .amose-comp__table thead th:nth-child(2),
  #shopify-section-{{ section.id }} .amose-comp__table tbody td:nth-child(2) {
    background: var(--amose-comp-highlight);
  }

  #shopify-section-{{ section.id }} .amose-comp__table thead th:nth-child(2) {
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
  }

  #shopify-section-{{ section.id }} .amose-comp__table tbody td {
    border-top: 1px solid var(--amose-comp-line);
    padding: 12px 12px;
    vertical-align: middle;
  }

  #shopify-section-{{ section.id }} .amose-comp__feature {
    font-size: var(--amose-body);
    line-height: 1.4;
    font-weight: 500;
  }

  #shopify-section-{{ section.id }} .amose-comp__icon-cell {
    text-align: center;
  }

  #shopify-section-{{ section.id }} .amose-comp__icon {
    display: inline-flex;
    width: 28px;
    height: 28px;
    border-radius: 999px;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .amose-comp__icon svg {
    width: 16px;
    height: 16px;
  }

  #shopify-section-{{ section.id }} .amose-comp__icon--check {
    background: var(--amose-comp-check-bg);
    color: var(--amose-comp-check-icon);
  }

  #shopify-section-{{ section.id }} .amose-comp__icon--cross {
    background: var(--amose-comp-cross-bg);
    color: var(--amose-comp-cross-icon);
  }

  #shopify-section-{{ section.id }} .amose-comp__cta-wrap {
    margin-top: 20px;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .amose-comp__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    background: var(--amose-comp-btn-bg);
    color: var(--amose-comp-btn-text);
    border-radius: 10px;
    min-height: 48px;
    padding: 0 24px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .amose-comp__table-wrap {
      overflow-x: visible;
    }

    #shopify-section-{{ section.id }} .amose-comp__table thead th {
      font-size: 15px;
      line-height: 1.3;
      padding: 10px 6px;
    }

    #shopify-section-{{ section.id }} .amose-comp__table thead th:first-child {
      width: 50%;
    }

    #shopify-section-{{ section.id }} .amose-comp__table thead th:nth-child(2),
    #shopify-section-{{ section.id }} .amose-comp__table thead th:nth-child(3) {
      width: 25%;
    }

    #shopify-section-{{ section.id }} .amose-comp__table thead th:nth-child(2) {
      border-top-left-radius: 8px;
      border-top-right-radius: 8px;
    }

    #shopify-section-{{ section.id }} .amose-comp__table tbody td {
      padding: 10px 8px;
    }

    #shopify-section-{{ section.id }} .amose-comp__feature {
      font-size: 14px;
      line-height: 1.35;
    }

    #shopify-section-{{ section.id }} .amose-comp__icon {
      width: 24px;
      height: 24px;
    }

    #shopify-section-{{ section.id }} .amose-comp__icon svg {
      width: 14px;
      height: 14px;
    }
  }
{%- endstyle -%}

{%- unless amose_skip_install_mask -%}
{%- comment -%} Install check: hide only after API says uninstalled (amose-section-status.js). {%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }}.amose-section-checking {
    display: none !important;
  }
{%- endstyle -%}
{%- endunless -%}

<div class="amose-comp">
  {% if s.heading != blank %}
    <h2 class="amose-comp__title">{{ s.heading | escape }}</h2>
  {% endif %}
  {% if s.subtext != blank %}
    <div class="amose-comp__sub rte">{{ s.subtext }}</div>
  {% endif %}

  <div class="amose-comp__table-wrap">
    <table class="amose-comp__table" role="table">
      <thead>
        <tr>
          <th scope="col"></th>
          <th scope="col">{{ s.left_column_heading | escape }}</th>
          <th scope="col">{{ s.right_column_heading | escape }}</th>
        </tr>
      </thead>
      <tbody>
        {% for block in section.blocks %}
          {% if block.type == 'row' %}
            <tr {{ block.shopify_attributes }}>
              <td class="amose-comp__feature">{{ block.settings.feature | escape }}</td>
              <td class="amose-comp__icon-cell">
                <span class="amose-comp__icon {% if block.settings.left_included %}amose-comp__icon--check{% else %}amose-comp__icon--cross{% endif %}">
                  {% if block.settings.left_included %}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M5 13l4 4L19 7"></path>
                    </svg>
                  {% else %}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" aria-hidden="true">
                      <path d="M7 7l10 10M17 7L7 17"></path>
                    </svg>
                  {% endif %}
                </span>
              </td>
              <td class="amose-comp__icon-cell">
                <span class="amose-comp__icon {% if block.settings.right_included %}amose-comp__icon--check{% else %}amose-comp__icon--cross{% endif %}">
                  {% if block.settings.right_included %}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M5 13l4 4L19 7"></path>
                    </svg>
                  {% else %}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" aria-hidden="true">
                      <path d="M7 7l10 10M17 7L7 17"></path>
                    </svg>
                  {% endif %}
                </span>
              </td>
            </tr>
          {% endif %}
        {% endfor %}
      </tbody>
    </table>
  </div>

  {% if s.button_label != blank %}
    <div class="amose-comp__cta-wrap">
      <a
        class="amose-comp__cta"
        data-amose-comp-cta
        {% if s.button_link != blank %}
          href="{{ s.button_link }}"
        {% else %}
          href="#amose-product-information-top"
          data-scroll-to-product-info="true"
        {% endif %}
      >
        {{ s.button_label | escape }}
      </a>
    </div>
  {% endif %}
</div>

<script>
  (function () {
    var root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root) return;
    var cta = root.querySelector('[data-amose-comp-cta]');
    if (!cta || cta.getAttribute('data-scroll-to-product-info') !== 'true') return;
    cta.addEventListener('click', function (event) {
      event.preventDefault();
      var target = document.getElementById('amose-product-information-top');
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        return;
      }
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  })();
</script>

{%- unless amose_skip_install_mask -%}
<script>
  window.__AmoseInstallCheckPageStart = window.__AmoseInstallCheckPageStart || Date.now();
  window.__AmoseInstallCheckOrigin = {{ amose_install_origin | json }};
  window.AmoseSectionStatus = window.AmoseSectionStatus || [];
  window.AmoseSectionStatus.push({
    shop: {{ shop.permanent_domain | json }},
    sectionId: {{ section.id | json }},
    sectionType: "comparison-table"
  });

  window.AmoseStatusLoaderInserted = window.AmoseStatusLoaderInserted || false;

  if (!window.AmoseStatusLoaderInserted) {
    window.AmoseStatusLoaderInserted = true;
    var script = document.createElement("script");
    script.src = {{ amose_status_script_url | json }};
    script.defer = true;
    document.head.appendChild(script);
  }
</script>
{%- endunless -%}

{% schema %}
{
  "name": "Amose Comparison Table",
  "tag": "section",
  "class": "amose-comparison-root",
  "settings": [
    { "type": "header", "content": "Layout" },
    {
      "type": "range",
      "id": "max_width",
      "min": 1000,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Max width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 52
    },
    { "type": "header", "content": "Content" },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Switch to Filtered Shower Water?"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "<p>Hard water can damage your hair and skin over time. See why filtered water makes a difference.</p>"
    },
    {
      "type": "text",
      "id": "left_column_heading",
      "label": "Left column heading",
      "default": "Filtered Showerhead"
    },
    {
      "type": "text",
      "id": "right_column_heading",
      "label": "Right column heading",
      "default": "Regular Showerheads"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Upgrade your shower"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    { "type": "header", "content": "Colors" },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Main text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Row divider color",
      "default": "#1e4d3a"
    },
    {
      "type": "color",
      "id": "highlight_bg",
      "label": "Center column background",
      "default": "#f4f1e8"
    },
    {
      "type": "color",
      "id": "check_bg",
      "label": "Check icon background",
      "default": "#1e4d3a"
    },
    {
      "type": "color",
      "id": "check_icon",
      "label": "Check icon color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "cross_bg",
      "label": "Cross icon background",
      "default": "rgba(0,0,0,0.3)"
    },
    {
      "type": "color",
      "id": "cross_icon",
      "label": "Cross icon color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#1e4d3a"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button text color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Comparison row",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "Feature",
          "default": "Removes chlorine"
        },
        {
          "type": "checkbox",
          "id": "left_included",
          "label": "Included in left column",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "right_included",
          "label": "Included in right column",
          "default": false
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Amose Comparison Table",
      "blocks": [
        { "type": "row", "settings": { "feature": "Removes chlorine", "left_included": true, "right_included": false } },
        { "type": "row", "settings": { "feature": "Reduces hard water minerals", "left_included": true, "right_included": false } },
        { "type": "row", "settings": { "feature": "Healthier hair", "left_included": true, "right_included": false } },
        { "type": "row", "settings": { "feature": "Softer skin", "left_included": true, "right_included": false } },
        { "type": "row", "settings": { "feature": "Less scalp dryness", "left_included": true, "right_included": false } },
        { "type": "row", "settings": { "feature": "Better water quality", "left_included": true, "right_included": false } }
      ]
    }
  ]
}
{% endschema %}
