{%- liquid
  assign s = section.settings
  assign selected_product = blank
  if s.product_handle != blank
    assign selected_product = all_products[s.product_handle]
  endif
  assign product_image = blank
  if selected_product and selected_product.featured_image
    assign product_image = selected_product.featured_image
  endif
  assign amose_install_origin = 'https://amosesection1-production.up.railway.app'
  assign amose_status_script_url = amose_install_origin | append: '/amose-section-status.js'
  assign amose_skip_install_mask = false
  if request.design_mode
    assign amose_skip_install_mask = true
  endif
  if theme.role == 'development'
    assign amose_skip_install_mask = true
  endif
-%}

{%- unless amose_skip_install_mask -%}
{%- comment -%} Install check: hide only after API says uninstalled (amose-section-status.js). {%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }}.amose-section-checking {
    display: none !important;
  }
{%- endstyle -%}
{%- endunless -%}

<section class="amose-contact-us" style="padding-top: {{ s.padding_top }}px; padding-bottom: {{ s.padding_bottom }}px; background: {{ s.section_bg }};">
  <div class="page-width" style="max-width: {{ s.max_width }}px; margin: 0 auto; padding: 0 20px; color: {{ s.text_color }};">
    <div style="display: grid; gap: 24px; grid-template-columns: 1fr;">
      <div style="display: grid; gap: 14px;">
        {% if s.heading != blank %}
          <h2 style="margin: 0; font-size: clamp(22px, 2.5vw, 30px); line-height: 1.15;">{{ s.heading | escape }}</h2>
        {% endif %}
        {% if s.subheading != blank %}
          <p class="amose-contact-us__subheading" style="margin: 0; color: {{ s.muted_text_color }}; font-size: 16px; line-height: 1.6;">
            {{ s.subheading | escape }}
          </p>
        {% endif %}
      </div>

      <div class="amose-contact-us__columns" style="display: grid; gap: 24px; grid-template-columns: 1fr; align-items: start;">
        <div class="amose-contact-us__left" style="display: grid; gap: 18px;">
          <div class="amose-contact-us__image-wrap" style="position: relative; border: 1px solid {{ s.border_color }}; border-radius: 14px; overflow: hidden; background: #f9fafb;">
            {% if s.info_image != blank %}
              {{ s.info_image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: s.heading, style: 'display:block;width:100%;height:100%;min-height:460px;object-fit:cover;' }}
            {% elsif product_image %}
              {{ product_image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: s.heading, style: 'display:block;width:100%;height:100%;min-height:460px;object-fit:cover;' }}
            {% else %}
              <div style="padding: 24px; color: {{ s.muted_text_color }};">Select a product or add an image in section settings.</div>
            {% endif %}
            <div
              style="
                position: absolute;
                left: 16px;
                right: 16px;
                bottom: 16px;
                background: {{ s.overlay_bg_color }};
                backdrop-filter: blur(2px);
                color: {{ s.overlay_text_color }};
                border-radius: 12px;
                padding: 15px;
              "
            >
              <div style="display:grid; gap: 12px;">
                <div>
                  <h3 class="amose-contact-us__overlay-title" style="margin: 0 0 6px; font-size: 17px; color: {{ s.overlay_text_color }};">Email support</h3>
                  <p class="amose-contact-us__overlay-text" style="margin: 0; line-height: 1.5; color: {{ s.overlay_text_color }};">
                    {{ s.email_label | escape }}:
                    <a href="mailto:{{ s.email | escape }}" style="color: {{ s.overlay_text_color }}; text-decoration: underline;">{{ s.email | escape }}</a>
                  </p>
                </div>
                <div>
                  <h3 class="amose-contact-us__overlay-title" style="margin: 0 0 6px; font-size: 17px; color: {{ s.overlay_text_color }};">Support hours</h3>
                  <p class="amose-contact-us__overlay-text" style="margin: 0; line-height: 1.5; color: {{ s.overlay_text_color }};">{{ s.hours | escape }}</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="amose-contact-us__form-wrap" style="border: 1px solid {{ s.border_color }}; border-radius: 14px; padding: 18px;">
          {% form 'contact', id: 'amose-contact-form' %}
            {% if form.posted_successfully? %}
              <p style="margin-top: 0; color: #166534;">{{ s.success_message | escape }}</p>
            {% endif %}
            {% if form.errors %}
              <div style="margin-top: 0; margin-bottom: 12px; color: #b91c1c;">{{ form.errors | default_errors }}</div>
            {% endif %}
            <div class="amose-contact-us__form-fields" style="display: grid; gap: 12px;">
              <input type="text" name="contact[name]" placeholder="Your name" style="padding: 12px; border: 1px solid {{ s.border_color }}; border-radius: 10px;">
              <input type="email" name="contact[email]" placeholder="Your email" style="padding: 12px; border: 1px solid {{ s.border_color }}; border-radius: 10px;">
              <input type="tel" name="contact[phone]" placeholder="Your phone" style="padding: 12px; border: 1px solid {{ s.border_color }}; border-radius: 10px;">
              <textarea class="amose-contact-us__message" name="contact[body]" rows="8" placeholder="How can we help?" style="padding: 12px; border: 1px solid {{ s.border_color }}; border-radius: 10px; min-height: 140px;"></textarea>
              <button type="submit" style="padding: 12px 18px; border: 0; border-radius: 10px; background: {{ s.button_bg }}; color: {{ s.button_text_color }}; cursor: pointer; font-size: 17px; font-weight: 600;">
                {{ s.button_label | escape }}
              </button>
            </div>
          {% endform %}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @media screen and (max-width: 989px) {
    .amose-contact-us .amose-contact-us__columns {
      display: flex !important;
      flex-direction: column !important;
      gap: 20px !important;
    }
    .amose-contact-us .amose-contact-us__form-wrap {
      order: 1;
      width: 100% !important;
      box-sizing: border-box;
    }
    .amose-contact-us .amose-contact-us__left {
      order: 2;
      width: 100% !important;
    }
    .amose-contact-us .amose-contact-us__image-wrap {
      aspect-ratio: 1 / 1;
      width: 100% !important;
    }
    .amose-contact-us .amose-contact-us__image-wrap img {
      width: 100% !important;
      height: 100% !important;
      min-height: 0 !important;
      object-fit: cover !important;
    }
    .amose-contact-us h2 {
      font-size: clamp(20px, 6.2vw, 24px) !important;
    }
    .amose-contact-us .amose-contact-us__subheading {
      font-size: 14px !important;
      line-height: 1.5 !important;
    }
    .amose-contact-us .amose-contact-us__overlay-title {
      font-size: 15px !important;
    }
    .amose-contact-us .amose-contact-us__overlay-text {
      font-size: 13px !important;
      line-height: 1.45 !important;
    }
    .amose-contact-us .amose-contact-us__form-wrap input,
    .amose-contact-us .amose-contact-us__form-wrap textarea {
      font-size: 14px;
    }
    .amose-contact-us .amose-contact-us__form-wrap button {
      font-size: 15px !important;
      padding: 11px 16px !important;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .amose-contact-us .amose-contact-us__columns {
      gap: 18px !important;
    }
  }

  @media screen and (min-width: 990px) {
    .amose-contact-us .amose-contact-us__columns {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) !important;
      align-items: stretch !important;
    }
    .amose-contact-us .amose-contact-us__left,
    .amose-contact-us .amose-contact-us__form-wrap,
    .amose-contact-us .amose-contact-us__image-wrap {
      height: 100%;
    }
    .amose-contact-us .amose-contact-us__image-wrap img {
      min-height: 100% !important;
    }
    .amose-contact-us .amose-contact-us__form-wrap {
      display: flex;
      flex-direction: column;
    }
    .amose-contact-us .amose-contact-us__form-fields {
      height: 100%;
    }
    .amose-contact-us .amose-contact-us__message {
      flex: 1 1 auto;
      min-height: 220px !important;
      resize: vertical;
    }
  }
</style>

{%- unless amose_skip_install_mask -%}
<script>
  window.__AmoseInstallCheckPageStart = window.__AmoseInstallCheckPageStart || Date.now();
  window.__AmoseInstallCheckOrigin = {{ amose_install_origin | json }};
  window.AmoseSectionStatus = window.AmoseSectionStatus || [];
  window.AmoseSectionStatus.push({
    shop: {{ shop.permanent_domain | json }},
    sectionId: {{ section.id | json }},
    sectionType: "contact-us"
  });

  window.AmoseStatusLoaderInserted = window.AmoseStatusLoaderInserted || false;

  if (!window.AmoseStatusLoaderInserted) {
    window.AmoseStatusLoaderInserted = true;
    var script = document.createElement("script");
    script.src = {{ amose_status_script_url | json }};
    script.defer = true;
    document.head.appendChild(script);
  }
</script>
{%- endunless -%}

{% schema %}
{
  "name": "Amose Contact Us",
  "tag": "section",
  "class": "amose-contact-us-root",
  "settings": [
    { "type": "range", "id": "max_width", "min": 700, "max": 1600, "step": 20, "unit": "px", "label": "Max width", "default": 1100 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 2, "unit": "px", "label": "Top padding", "default": 26 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 2, "unit": "px", "label": "Bottom padding", "default": 26 },
    { "type": "color", "id": "section_bg", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#111111" },
    { "type": "color", "id": "muted_text_color", "label": "Muted text color", "default": "#4b5563" },
    { "type": "color", "id": "border_color", "label": "Border color", "default": "#d1d5db" },
    { "type": "color", "id": "button_bg", "label": "Button background", "default": "#111111" },
    { "type": "color", "id": "button_text_color", "label": "Button text color", "default": "#ffffff" },
    { "type": "color_background", "id": "overlay_bg_color", "label": "Support overlay background", "default": "rgba(17,17,17,0.66)" },
    { "type": "color", "id": "overlay_text_color", "label": "Support overlay text color", "default": "#ffffff" },
    { "type": "text", "id": "product_handle", "label": "Product handle (auto-filled by app)", "default": "sample-product" },
    { "type": "image_picker", "id": "info_image", "label": "Left column image" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Contact us" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Need help with an order or a product question? Our support team is here for you." },
    { "type": "text", "id": "email_label", "label": "Email label", "default": "Support email" },
    { "type": "text", "id": "email", "label": "Support email", "default": "support@example.com" },
    { "type": "text", "id": "hours", "label": "Support hours", "default": "Monday to Friday, 9:00 AM - 6:00 PM" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Send message" },
    { "type": "text", "id": "success_message", "label": "Success message", "default": "Thanks for your message. We will reply as soon as possible." }
  ],
  "presets": [{ "name": "Amose Contact Us" }]
}
{% endschema %}
