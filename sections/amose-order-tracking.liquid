{%- liquid
  assign s = section.settings
  assign fallback_tracking_url = "https://parcelsapp.com/en/tracking/"
  assign tracking_base_url = s.tracking_url
  if tracking_base_url == blank
    assign tracking_base_url = fallback_tracking_url
  endif
  assign amose_install_origin = 'https://amosesection1-production.up.railway.app'
  assign amose_status_script_url = amose_install_origin | append: '/amose-section-status.js'
  assign amose_skip_install_mask = false
  if request.design_mode
    assign amose_skip_install_mask = true
  endif
  if theme.role == 'development'
    assign amose_skip_install_mask = true
  endif
-%}

{%- unless amose_skip_install_mask -%}
{%- comment -%} Install check: hide only after API says uninstalled (amose-section-status.js). {%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }}.amose-section-checking {
    display: none !important;
  }
{%- endstyle -%}
{%- endunless -%}

<section class="amose-order-tracking" style="padding-top: {{ s.padding_top }}px; padding-bottom: {{ s.padding_bottom }}px; background: {{ s.section_bg }};">
  <div class="page-width" style="max-width: {{ s.max_width }}px; margin: 0 auto; padding: 0 20px; color: {{ s.text_color }};">
    {% if s.heading != blank %}
      <h2 style="margin: 0 0 10px; font-size: clamp(28px, 4vw, 40px); line-height: 1.15;">{{ s.heading | escape }}</h2>
    {% endif %}
    {% if s.subheading != blank %}
      <p style="margin: 0 0 22px; color: {{ s.muted_text_color }}; font-size: 17px; line-height: 1.6;">
        {{ s.subheading | escape }}
      </p>
    {% endif %}

    <div style="border: 1px solid {{ s.border_color }}; border-radius: 14px; padding: 20px;">
      <p style="margin: 0 0 12px; color: {{ s.muted_text_color }};">{{ s.instructions | escape }}</p>
      <form id="amose-order-tracking-form-{{ section.id }}" action="#" method="get" target="_blank" rel="noopener">
        <div style="display: grid; gap: 12px; grid-template-columns: 1fr auto; align-items: center;">
          <input
            type="text"
            id="amose-order-tracking-input-{{ section.id }}"
            name="{{ s.tracking_param | escape }}"
            placeholder="{{ s.placeholder | escape }}"
            required
            style="padding: 12px; border: 1px solid {{ s.border_color }}; border-radius: 10px;"
          >
          <button
            type="submit"
            style="padding: 12px 18px; border: 0; border-radius: 10px; background: {{ s.button_bg }}; color: {{ s.button_text_color }}; cursor: pointer;"
          >
            {{ s.button_label | escape }}
          </button>
        </div>
      </form>
      <p style="margin: 14px 0 0; color: {{ s.muted_text_color }}; font-size: 13px; line-height: 1.6;">
        Supported carriers: China Post, USPS, Canada Post, Royal Mail, Deutsche Post, AliExpress, UPS, SHEIN, FedEx, Temu, eBay, Amazon.
      </p>
    </div>
  </div>
</section>

<script>
  (function () {
    var form = document.getElementById("amose-order-tracking-form-{{ section.id }}");
    var input = document.getElementById("amose-order-tracking-input-{{ section.id }}");
    if (!form || !input) return;

    form.addEventListener("submit", function (event) {
      event.preventDefault();
      var trackingNumber = String(input.value || "").trim();
      if (!trackingNumber) return;

      var baseUrl = "{{ tracking_base_url | escape }}";
      var paramName = "{{ s.tracking_param | escape }}";

      // Default behavior for ParcelsApp-style path URLs.
      var destination = baseUrl;
      if (/parcelsapp\.com/i.test(baseUrl)) {
        destination = baseUrl.replace(/\/+$/, "") + "/" + encodeURIComponent(trackingNumber);
      } else if (baseUrl.indexOf("?") === -1) {
        destination = baseUrl + "?" + encodeURIComponent(paramName) + "=" + encodeURIComponent(trackingNumber);
      } else {
        destination = baseUrl + "&" + encodeURIComponent(paramName) + "=" + encodeURIComponent(trackingNumber);
      }

      window.open(destination, "_blank", "noopener");
    });
  })();
</script>

{%- unless amose_skip_install_mask -%}
<script>
  window.__AmoseInstallCheckPageStart = window.__AmoseInstallCheckPageStart || Date.now();
  window.__AmoseInstallCheckOrigin = {{ amose_install_origin | json }};
  window.AmoseSectionStatus = window.AmoseSectionStatus || [];
  window.AmoseSectionStatus.push({
    shop: {{ shop.permanent_domain | json }},
    sectionId: {{ section.id | json }},
    sectionType: "order-tracking"
  });

  window.AmoseStatusLoaderInserted = window.AmoseStatusLoaderInserted || false;

  if (!window.AmoseStatusLoaderInserted) {
    window.AmoseStatusLoaderInserted = true;
    var script = document.createElement("script");
    script.src = {{ amose_status_script_url | json }};
    script.defer = true;
    document.head.appendChild(script);
  }
</script>
{%- endunless -%}

{% schema %}
{
  "name": "Amose Order Tracking",
  "tag": "section",
  "class": "amose-order-tracking-root",
  "settings": [
    { "type": "range", "id": "max_width", "min": 700, "max": 1600, "step": 20, "unit": "px", "label": "Max width", "default": 1000 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Top padding", "default": 56 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Bottom padding", "default": 56 },
    { "type": "color", "id": "section_bg", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#111111" },
    { "type": "color", "id": "muted_text_color", "label": "Muted text color", "default": "#4b5563" },
    { "type": "color", "id": "border_color", "label": "Border color", "default": "#d1d5db" },
    { "type": "color", "id": "button_bg", "label": "Button background", "default": "#111111" },
    { "type": "color", "id": "button_text_color", "label": "Button text color", "default": "#ffffff" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Track your order" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Enter your tracking number below to view the latest shipping status." },
    { "type": "text", "id": "instructions", "label": "Instructions", "default": "Use the tracking number from your shipping confirmation email." },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Tracking number" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Track order" },
    { "type": "url", "id": "tracking_url", "label": "Tracking page URL" },
    { "type": "text", "id": "tracking_param", "label": "Query parameter name", "default": "tracking_number" }
  ],
  "presets": [{ "name": "Amose Order Tracking" }]
}
{% endschema %}
