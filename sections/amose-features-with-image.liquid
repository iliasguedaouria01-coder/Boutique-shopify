{%- liquid
  assign s = section.settings
  assign amose_install_origin = 'https://amosesection1-production.up.railway.app'
  assign amose_status_script_url = amose_install_origin | append: '/amose-section-status.js'
  assign amose_skip_install_mask = false
  if request.design_mode
    assign amose_skip_install_mask = true
  endif
  if theme.role == 'development'
    assign amose_skip_install_mask = true
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }}.amose-features-image-root {
    --afi-bg: {{ s.section_bg }};
    --afi-heading: {{ s.heading_color }};
    --afi-title: {{ s.card_title_color }};
    --afi-body: {{ s.card_body_color }};
    --afi-radius: {{ s.image_radius }}px;
    --afi-gap: {{ s.card_gap }}px;
    background: var(--afi-bg);
    padding-top: {{ s.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ s.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }}.amose-features-image-root {
      padding-top: {{ s.padding_top }}px;
      padding-bottom: {{ s.padding_bottom }}px;
    }
  }

  #shopify-section-{{ section.id }} .amose-afi__wrap {
    max-width: {{ s.max_width }}px;
    margin: 0 auto;
    padding-left: clamp(16px, 3vw, 34px);
    padding-right: 0;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .amose-afi__wrap {
      padding-right: clamp(16px, 3vw, 34px);
    }
  }

  #shopify-section-{{ section.id }} .amose-afi__heading {
    margin: 0 0 clamp(16px, 2vw, 24px);
    text-align: center;
    color: var(--afi-heading);
    font-size: clamp(22px, 2.5vw, 30px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 700;
    max-width: 18ch;
    margin-left: auto;
    margin-right: auto;
  }

  #shopify-section-{{ section.id }} .amose-afi__rail {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(220px, 1fr);
    gap: var(--afi-gap);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  #shopify-section-{{ section.id }} .amose-afi__rail::-webkit-scrollbar {
    display: none;
  }

  #shopify-section-{{ section.id }} .amose-afi__card {
    scroll-snap-align: start;
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .amose-afi__media {
    width: 100%;
    aspect-ratio: {{ s.image_aspect_ratio }};
    border-radius: var(--afi-radius);
    overflow: hidden;
    background: #d1d5db;
  }

  #shopify-section-{{ section.id }} .amose-afi__media img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .amose-afi__title {
    margin: 10px 0 0;
    color: var(--afi-title);
    font-size: clamp(16px, 1.35vw, 18px);
    line-height: 1.25;
    letter-spacing: -0.02em;
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .amose-afi__text {
    margin: 6px 0 0;
    color: var(--afi-body);
    font-size: clamp(14px, 1.15vw, 16px);
    line-height: 1.55;
    max-width: 34ch;
  }
{%- endstyle -%}

{%- unless amose_skip_install_mask -%}
{%- style -%}
  #shopify-section-{{ section.id }}.amose-section-checking {
    display: none !important;
  }
{%- endstyle -%}
{%- endunless -%}

<section class="amose-afi__wrap">
  {% if s.heading != blank %}
    <h2 class="amose-afi__heading">{{ s.heading | escape }}</h2>
  {% endif %}

  <div class="amose-afi__rail">
    {% for block in section.blocks %}
      <article class="amose-afi__card" {{ block.shopify_attributes }}>
        <div class="amose-afi__media">
          {% if block.settings.image != blank %}
            <img
              src="{{ block.settings.image | image_url: width: 1200 }}"
              alt="{{ block.settings.title | default: 'Feature image' | escape }}"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
              loading="lazy"
            >
          {% else %}
            <div style="width:100%;height:100%;background:#d1d5db;"></div>
          {% endif %}
        </div>
        {% if block.settings.title != blank %}
          <h3 class="amose-afi__title">{{ block.settings.title | escape }}</h3>
        {% endif %}
        {% if block.settings.text != blank %}
          <p class="amose-afi__text">{{ block.settings.text | escape }}</p>
        {% endif %}
      </article>
    {% endfor %}
  </div>
</section>

{%- unless amose_skip_install_mask -%}
<script>
  window.__AmoseInstallCheckPageStart = window.__AmoseInstallCheckPageStart || Date.now();
  window.__AmoseInstallCheckOrigin = {{ amose_install_origin | json }};
  window.AmoseSectionStatus = window.AmoseSectionStatus || [];
  window.AmoseSectionStatus.push({
    shop: {{ shop.permanent_domain | json }},
    sectionId: {{ section.id | json }},
    sectionType: "features-with-image"
  });

  window.AmoseStatusLoaderInserted = window.AmoseStatusLoaderInserted || false;
  if (!window.AmoseStatusLoaderInserted) {
    window.AmoseStatusLoaderInserted = true;
    var script = document.createElement("script");
    script.src = {{ amose_status_script_url | json }};
    script.defer = true;
    document.head.appendChild(script);
  }
</script>
{%- endunless -%}

{% schema %}
{
  "name": "Features with image",
  "tag": "section",
  "class": "amose-features-image-root",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Strips sessions for better nasal flow" },
    { "type": "range", "id": "max_width", "min": 960, "max": 1800, "step": 20, "unit": "px", "label": "Max width", "default": 1320 },
    { "type": "select", "id": "image_aspect_ratio", "label": "Image format", "default": "1 / 1", "options": [
      { "value": "1 / 1", "label": "Square (1:1)" },
      { "value": "4 / 3", "label": "Landscape (4:3)" },
      { "value": "16 / 9", "label": "Landscape (16:9)" },
      { "value": "3 / 4", "label": "Portrait (3:4)" },
      { "value": "9 / 16", "label": "Vertical (9:16)" }
    ]},
    { "type": "range", "id": "image_radius", "min": 0, "max": 30, "step": 1, "unit": "px", "label": "Image corner radius", "default": 16 },
    { "type": "range", "id": "card_gap", "min": 8, "max": 32, "step": 1, "unit": "px", "label": "Card gap", "default": 16 },
    { "type": "color", "id": "section_bg", "label": "Section background", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#111827" },
    { "type": "color", "id": "card_title_color", "label": "Card title color", "default": "#111827" },
    { "type": "color", "id": "card_body_color", "label": "Card text color", "default": "#1f2937" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top", "default": 24 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 24 }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Snore Less, Sleep Better" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Apply before bed to open nasal passages, reduce snoring, and unlock deeper, more restorative sleep." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features with image",
      "blocks": [
        { "type": "feature", "settings": { "title": "Snore Less, Sleep Better", "text": "Apply before bed to open nasal passages, reduce snoring, and unlock deeper, more restorative sleep." } },
        { "type": "feature", "settings": { "title": "Power Your Workouts", "text": "Use pre-workout to improve airflow and stamina. Strips support better oxygen delivery so you can push harder, longer." } },
        { "type": "feature", "settings": { "title": "Calm Your System", "text": "Wear during breathwork or meditation to reduce heart rate, ease anxiety, and support parasympathetic recovery." } },
        { "type": "feature", "settings": { "title": "Recover While You Sleep", "text": "When congestion hits, non-medicated decongestion strips help improve nighttime airflow and support better rest." } }
      ]
    }
  ]
}
{% endschema %}
