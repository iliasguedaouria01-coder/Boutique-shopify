{%- liquid
  assign s = section.settings
  assign amose_install_origin = 'https://amosesection1-production.up.railway.app'
  assign amose_status_script_url = amose_install_origin | append: '/amose-section-status.js'
  assign amose_skip_install_mask = false
  if request.design_mode
    assign amose_skip_install_mask = true
  endif
  if theme.role == 'development'
    assign amose_skip_install_mask = true
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }}[class*="amose-"] {
    font-size: 16px;
  }
  #shopify-section-{{ section.id }}.amose-reviews-root {
    --amose-reviews-bg: {{ s.section_bg }};
    --amose-reviews-text: {{ s.text_color }};
    --amose-reviews-muted: {{ s.muted_color }};
    --amose-reviews-badge-bg: {{ s.badge_bg }};
    --amose-reviews-badge-text: {{ s.badge_text_color }};
    --amose-reviews-card-bg: {{ s.card_bg }};
    --amose-reviews-card-border: {{ s.card_border }};
    --amose-reviews-star: {{ s.star_color }};
    --amose-reviews-avatar-bg: {{ s.avatar_bg }};
    --amose-reviews-avatar-text: {{ s.avatar_text }};
    --amose-reviews-arrow-bg: {{ s.arrow_bg }};
    --amose-reviews-arrow-text: {{ s.arrow_text }};
    --amose-heading: clamp(22px, 2.5vw, 30px);
    --amose-body: clamp(15px, 1.2vw, 16px);
    padding-top: {{ s.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ s.padding_bottom | times: 0.75 | round: 0 }}px;
    background: var(--amose-reviews-bg);
    color: var(--amose-reviews-text);
    overflow: hidden;
    margin: 0 !important;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }}.amose-reviews-root {
      padding-top: {{ s.padding_top }}px;
      padding-bottom: {{ s.padding_bottom }}px;
    }

    #shopify-section-{{ section.id }} .amose-reviews__wrap {
      max-width: none;
      margin-right: 0;
    }

    #shopify-section-{{ section.id }} .amose-reviews__carousel-wrap {
      width: calc(100vw - clamp(16px, 4vw, 40px));
      max-width: calc(100vw - clamp(16px, 4vw, 40px));
    }
  }

  #shopify-section-{{ section.id }} .amose-reviews__wrap {
    max-width: {{ s.max_width }}px;
    margin: 0 auto;
    padding: 0 0 0 clamp(16px, 4vw, 40px);
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .amose-reviews__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: clamp(24px, 4vw, 32px);
  }

  #shopify-section-{{ section.id }} .amose-reviews__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border-radius: 999px;
    background: var(--amose-reviews-badge-bg);
    color: var(--amose-reviews-badge-text);
    font-size: 14px;
    line-height: 1.2;
    font-weight: 600;
    margin-bottom: 18px;
  }

  #shopify-section-{{ section.id }} .amose-reviews__badge-stars,
  #shopify-section-{{ section.id }} .amose-reviews__stars {
    letter-spacing: 0.16em;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .amose-reviews__badge-stars {
    color: var(--amose-reviews-badge-text);
  }

  #shopify-section-{{ section.id }} .amose-reviews__stars {
    color: var(--amose-reviews-star);
  }

  #shopify-section-{{ section.id }} .amose-reviews__title {
    margin: 0;
    font-size: var(--amose-heading);
    line-height: 1.05;
    letter-spacing: -0.03em;
    font-weight: 700;
    color: var(--amose-reviews-text);
  }

  #shopify-section-{{ section.id }} .amose-reviews__carousel-wrap {
    position: relative;
  }

  #shopify-section-{{ section.id }} .amose-reviews__carousel {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(280px, 86%);
    gap: 18px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    padding: 8px 0 12px;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    #shopify-section-{{ section.id }} .amose-reviews__carousel {
      grid-auto-columns: minmax(300px, 48%);
    }
  }

  #shopify-section-{{ section.id }} .amose-reviews__carousel::-webkit-scrollbar {
    display: none;
  }

  #shopify-section-{{ section.id }} .amose-reviews__card {
    scroll-snap-align: start;
    background: var(--amose-reviews-card-bg);
    border: 1px solid var(--amose-reviews-card-border);
    border-radius: 18px;
    padding: 22px 22px 18px;
    min-height: 210px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .amose-reviews__quote,
  #shopify-section-{{ section.id }} .amose-reviews__quote p {
    margin: 0;
    color: var(--amose-reviews-text);
    font-size: var(--amose-body);
    line-height: 1.7;
  }

  #shopify-section-{{ section.id }} .amose-reviews__meta {
    margin-top: 18px;
  }

  #shopify-section-{{ section.id }} .amose-reviews__verified {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--amose-reviews-muted);
    font-size: 14px;
    margin-bottom: 14px;
  }

  #shopify-section-{{ section.id }} .amose-reviews__verified svg {
    width: 15px;
    height: 15px;
    display: block;
  }

  #shopify-section-{{ section.id }} .amose-reviews__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  #shopify-section-{{ section.id }} .amose-reviews__author {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .amose-reviews__avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--amose-reviews-avatar-bg);
    color: var(--amose-reviews-avatar-text);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 16px;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .amose-reviews__name {
    display: block;
    font-size: 16px;
    font-weight: 700;
    line-height: 1.2;
    color: var(--amose-reviews-text);
  }

  #shopify-section-{{ section.id }} .amose-reviews__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border: 0;
    border-radius: 999px;
    background: var(--amose-reviews-arrow-bg);
    color: var(--amose-reviews-arrow-text);
    box-shadow: 0 10px 24px rgba(17, 24, 39, 0.14);
    display: none;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .amose-reviews__nav svg {
    width: 18px;
    height: 18px;
    display: block;
  }

  #shopify-section-{{ section.id }} .amose-reviews__nav--prev {
    left: -6px;
  }

  #shopify-section-{{ section.id }} .amose-reviews__nav--next {
    right: 28px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .amose-reviews__nav {
      display: inline-flex;
    }
  }
{%- endstyle -%}

{%- unless amose_skip_install_mask -%}
{%- comment -%} Install check: hide only after API says uninstalled (amose-section-status.js). {%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }}.amose-section-checking {
    display: none !important;
  }
{%- endstyle -%}
{%- endunless -%}

<div class="amose-reviews__wrap">
  <div class="amose-reviews__header">
    {% if s.badge_label != blank %}
      <div class="amose-reviews__badge">
        <span class="amose-reviews__badge-stars" aria-hidden="true">★★★★★</span>
        <span>{{ s.badge_label | escape }}</span>
      </div>
    {% endif %}
    {% if s.heading != blank %}
      <h2 class="amose-reviews__title">{{ s.heading | escape }}</h2>
    {% endif %}
  </div>

  <div class="amose-reviews__carousel-wrap" data-reviews-root>
    <button class="amose-reviews__nav amose-reviews__nav--prev" type="button" aria-label="Previous reviews" data-reviews-prev>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M15 18l-6-6 6-6"></path>
      </svg>
    </button>

    <div class="amose-reviews__carousel" data-reviews-track>
      {% for block in section.blocks %}
        {% if block.type == 'review' %}
          <article class="amose-reviews__card" {{ block.shopify_attributes }}>
            {% if block.settings.quote != blank %}
              <div class="amose-reviews__quote rte">{{ block.settings.quote }}</div>
            {% endif %}

            <div class="amose-reviews__meta">
              <div class="amose-reviews__verified">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M9.5924 3.20027C9.34888 3.4078 9.22711 3.51158 9.09706 3.59874C8.79896 3.79854 8.46417 3.93721 8.1121 4.00672C7.95851 4.03705 7.79903 4.04977 7.48008 4.07522C6.6787 4.13918 6.278 4.17115 5.94371 4.28923C5.17051 4.56233 4.56233 5.17051 4.28923 5.94371C4.17115 6.278 4.13918 6.6787 4.07522 7.48008C4.04977 7.79903 4.03705 7.95851 4.00672 8.1121C3.93721 8.46417 3.79854 8.79896 3.59874 9.09706C3.51158 9.22711 3.40781 9.34887 3.20027 9.5924C2.67883 10.2043 2.4181 10.5102 2.26522 10.8301C1.91159 11.57 1.91159 12.43 2.26522 13.1699C2.41811 13.4898 2.67883 13.7957 3.20027 14.4076C3.40778 14.6511 3.51158 14.7729 3.59874 14.9029C3.79854 15.201 3.93721 15.5358 4.00672 15.8879C4.03705 16.0415 4.04977 16.201 4.07522 16.5199C4.13918 17.3213 4.17115 17.722 4.28923 18.0563C4.56233 18.8295 5.17051 19.4377 5.94371 19.7108C6.278 19.8288 6.6787 19.8608 7.48008 19.9248C7.79903 19.9502 7.95851 19.963 8.1121 19.9933C8.46417 20.0628 8.79896 20.2015 9.09706 20.4013C9.22711 20.4884 9.34887 20.5922 9.5924 20.7997C10.2043 21.3212 10.5102 21.5819 10.8301 21.7348C11.57 22.0884 12.43 22.0884 13.1699 21.7348C13.4898 21.5819 13.7957 21.3212 14.4076 20.7997C14.6511 20.5922 14.7729 20.4884 14.9029 20.4013C15.201 20.2015 15.5358 20.0628 15.8879 19.9933C16.0415 19.963 16.201 19.9502 16.5199 19.9248C17.3213 19.8608 17.722 19.8288 18.0563 19.7108C18.8295 19.4377 19.4377 18.8295 19.7108 18.0563C19.8288 17.722 19.8608 17.3213 19.9248 16.5199C19.9502 16.201 19.963 16.0415 19.9933 15.8879C20.0628 15.5358 20.2015 15.201 20.4013 14.9029C20.4884 14.7729 20.5922 14.6511 20.7997 14.4076C21.3212 13.7957 21.5819 13.4898 21.7348 13.1699C22.0884 12.43 22.0884 11.57 21.7348 10.8301C21.5819 10.5102 21.3212 10.2043 20.7997 9.5924C20.5922 9.34887 20.4884 9.22711 20.4013 9.09706C20.2015 8.79896 20.0628 8.46417 19.9933 8.1121C19.963 7.95851 19.9502 7.79903 19.9248 7.48008C19.8608 6.6787 19.8288 6.278 19.7108 5.94371C19.4377 5.17051 18.8295 4.56233 18.0563 4.28923C17.722 4.17115 17.3213 4.13918 16.5199 4.07522C16.201 4.04977 16.0415 4.03705 15.8879 4.00672C15.5358 3.93721 15.201 3.79854 14.9029 3.59874C14.7729 3.51158 14.6511 3.40781 14.4076 3.20027C13.7957 2.67883 13.4898 2.41811 13.1699 2.26522C12.43 1.91159 11.57 1.91159 10.8301 2.26522C10.5102 2.4181 10.2043 2.67883 9.5924 3.20027ZM16.3735 9.86314C16.6913 9.5453 16.6913 9.03 16.3735 8.71216C16.0557 8.39433 15.5403 8.39433 15.2225 8.71216L10.3723 13.5624L8.77746 11.9676C8.45963 11.6498 7.94432 11.6498 7.62649 11.9676C7.30866 12.2854 7.30866 12.8007 7.62649 13.1186L9.79678 15.2889C10.1146 15.6067 10.6299 15.6067 10.9478 15.2889L16.3735 9.86314Z" fill="#1C274C"></path>
                </svg>
                <span>{{ block.settings.verified_label | default: 'Verified Rating' | escape }}</span>
              </div>

              <div class="amose-reviews__footer">
                <div class="amose-reviews__author">
                  <span class="amose-reviews__avatar">
                    {{ block.settings.name | strip | slice: 0, 1 | upcase }}
                  </span>
                  <div>
                    <span class="amose-reviews__name">{{ block.settings.name | escape }}</span>
                  </div>
                </div>
                <span class="amose-reviews__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
                  {% for i in (1..5) %}
                    {% if i <= block.settings.rating %}
                      ★
                    {% else %}
                      ☆
                    {% endif %}
                  {% endfor %}
                </span>
              </div>
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>

    <button class="amose-reviews__nav amose-reviews__nav--next" type="button" aria-label="Next reviews" data-reviews-next>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M9 18l6-6-6-6"></path>
      </svg>
    </button>
  </div>
</div>

<script>
  (function() {
    var root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root) return;

    var track = root.querySelector('[data-reviews-track]');
    var prev = root.querySelector('[data-reviews-prev]');
    var next = root.querySelector('[data-reviews-next]');
    if (!track || !prev || !next) return;

    function step() {
      var firstCard = track.querySelector('.amose-reviews__card');
      if (!firstCard) return track.clientWidth * 0.85;
      var styles = window.getComputedStyle(track);
      var gap = parseFloat(styles.columnGap || styles.gap || 0);
      return firstCard.getBoundingClientRect().width + gap;
    }

    prev.addEventListener('click', function() {
      track.scrollBy({ left: -step(), behavior: 'smooth' });
    });

    next.addEventListener('click', function() {
      track.scrollBy({ left: step(), behavior: 'smooth' });
    });
  })();
</script>

{%- unless amose_skip_install_mask -%}
<script>
  window.__AmoseInstallCheckPageStart = window.__AmoseInstallCheckPageStart || Date.now();
  window.__AmoseInstallCheckOrigin = {{ amose_install_origin | json }};
  window.AmoseSectionStatus = window.AmoseSectionStatus || [];
  window.AmoseSectionStatus.push({
    shop: {{ shop.permanent_domain | json }},
    sectionId: {{ section.id | json }},
    sectionType: "customer-reviews"
  });

  window.AmoseStatusLoaderInserted = window.AmoseStatusLoaderInserted || false;

  if (!window.AmoseStatusLoaderInserted) {
    window.AmoseStatusLoaderInserted = true;
    var script = document.createElement("script");
    script.src = {{ amose_status_script_url | json }};
    script.defer = true;
    document.head.appendChild(script);
  }
</script>
{%- endunless -%}

{% schema %}
