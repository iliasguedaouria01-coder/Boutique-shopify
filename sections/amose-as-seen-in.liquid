{%- liquid
  assign s = section.settings
  assign amose_install_origin = 'https://amosesection1-production.up.railway.app'
  assign amose_status_script_url = amose_install_origin | append: '/amose-section-status.js'
  assign amose_skip_install_mask = false
  if request.design_mode
    assign amose_skip_install_mask = true
  endif
  if theme.role == 'development'
    assign amose_skip_install_mask = true
  endif
  assign asi_radius = s.corner_radius | default: s.top_radius | default: 24
-%}

{%- style -%}
  #shopify-section-{{ section.id }}.amose-as-seen-in-root {
    --asi-bg: {{ s.section_bg | default: '#785aaf' }};
    --asi-text: {{ s.text_color | default: '#ffffff' }};
    --asi-logo-text: {{ s.logo_text_color | default: '#ffffff' }};
    --asi-gap: {{ s.logo_gap | default: 48 }}px;
    --asi-logo-height: {{ s.logo_height | default: 28 }}px;
    --asi-radius: {{ asi_radius }}px;
    background: transparent;
    color: var(--asi-text);
    padding-top: {{ s.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ s.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }}.amose-as-seen-in-root {
      padding-top: {{ s.padding_top }}px;
      padding-bottom: {{ s.padding_bottom }}px;
    }
  }

  #shopify-section-{{ section.id }} .amose-as-seen-in {
    max-width: {{ s.max_width | default: 1200 }}px;
    margin: 0 auto;
    padding: 0 20px;
    box-sizing: border-box;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .amose-as-seen-in {
      padding: 0 clamp(20px, 3.2vw, 30px);
    }
  }

  #shopify-section-{{ section.id }} .amose-as-seen-in__panel {
    background: var(--asi-bg);
    border-radius: var(--asi-radius);
    padding: clamp(20px, 4vw, 32px) clamp(18px, 3.5vw, 40px);
    box-sizing: border-box;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .amose-as-seen-in__eyebrow {
    margin: 0 0 clamp(12px, 2vw, 20px);
    font-size: {{ s.heading_size | default: 12 }}px;
    line-height: 1.2;
    letter-spacing: 0.14em;
    font-weight: {{ s.heading_weight | default: 600 }};
    text-transform: uppercase;
    color: var(--asi-text);
  }

  #shopify-section-{{ section.id }} .amose-as-seen-in__logos {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--asi-gap);
  }

  #shopify-section-{{ section.id }} .amose-as-seen-in__item {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: calc(var(--asi-logo-height) + 4px);
    flex: 0 1 auto;
  }

  #shopify-section-{{ section.id }} .amose-as-seen-in__item img {
    width: auto;
    height: auto;
    max-width: min(220px, 28vw);
    max-height: var(--asi-logo-height);
    object-fit: contain;
    display: block;
    {% unless s.logo_white_filter == false %}
      filter: brightness(0) invert(1);
    {% endunless %}
  }

  #shopify-section-{{ section.id }} .amose-as-seen-in__fallback-logo {
    margin: 0;
    color: var(--asi-logo-text);
    font-size: clamp(14px, 2.2vw, {{ s.logo_text_size | default: 28 }}px);
    line-height: 1;
    letter-spacing: 0.06em;
    font-weight: {{ s.logo_text_weight | default: 700 }};
    white-space: nowrap;
    font-family: inherit;
    text-transform: uppercase;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }}.amose-as-seen-in-root {
      --asi-gap: {{ s.mobile_logo_gap | default: 14 }}px;
      --asi-logo-height: {{ s.mobile_logo_height | default: 22 }}px;
    }

    #shopify-section-{{ section.id }} .amose-as-seen-in__panel {
      padding: clamp(18px, 4.5vw, 24px) clamp(14px, 4vw, 20px);
    }

    #shopify-section-{{ section.id }} .amose-as-seen-in__logos {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      justify-items: center;
      align-items: center;
      column-gap: var(--asi-gap);
      row-gap: clamp(10px, 2.5vw, 14px);
      max-width: 320px;
      margin: 0 auto;
    }

    #shopify-section-{{ section.id }} .amose-as-seen-in__item {
      width: 100%;
      min-height: calc(var(--asi-logo-height) + 2px);
    }

    #shopify-section-{{ section.id }} .amose-as-seen-in__fallback-logo {
      font-size: clamp(18px, 3.6vw, {{ s.logo_text_size | default: 28 }}px);
      letter-spacing: 0.04em;
    }

    #shopify-section-{{ section.id }} .amose-as-seen-in__item img {
      max-width: 100%;
      max-height: var(--asi-logo-height);
    }
  }
{%- endstyle -%}

{%- unless amose_skip_install_mask -%}
{%- style -%}
  #shopify-section-{{ section.id }}.amose-section-checking {
    display: none !important;
  }
{%- endstyle -%}
{%- endunless -%}

<div class="amose-as-seen-in">
  <div class="amose-as-seen-in__panel">
    {% if s.show_heading and s.heading != blank %}
      <p class="amose-as-seen-in__eyebrow">{{ s.heading | escape }}</p>
    {% endif %}

    <div class="amose-as-seen-in__logos" role="list" aria-label="{{ s.heading | default: 'As seen in' | escape }}">
      {% for block in section.blocks %}
        {% if block.type == 'logo' %}
          <div class="amose-as-seen-in__item" role="listitem" {{ block.shopify_attributes }}>
            {% if block.settings.logo_image != blank %}
              <img
                src="{{ block.settings.logo_image | image_url: width: 500 }}"
                alt="{{ block.settings.logo_alt | default: block.settings.logo_text | escape }}"
                loading="lazy"
                width="{{ block.settings.logo_image.width }}"
                height="{{ block.settings.logo_image.height }}"
              >
            {% elsif block.settings.logo_text != blank %}
              <p class="amose-as-seen-in__fallback-logo">{{ block.settings.logo_text | escape }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

{%- unless amose_skip_install_mask -%}
<script>
  window.__AmoseInstallCheckPageStart = window.__AmoseInstallCheckPageStart || Date.now();
  window.__AmoseInstallCheckOrigin = {{ amose_install_origin | json }};
  window.AmoseSectionStatus = window.AmoseSectionStatus || [];
  window.AmoseSectionStatus.push({
    shop: {{ shop.permanent_domain | json }},
    sectionId: {{ section.id | json }},
    sectionType: "as-seen-in"
  });

  window.AmoseStatusLoaderInserted = window.AmoseStatusLoaderInserted || false;

  if (!window.AmoseStatusLoaderInserted) {
    window.AmoseStatusLoaderInserted = true;
    var script = document.createElement("script");
    script.src = {{ amose_status_script_url | json }};
    script.defer = true;
    document.head.appendChild(script);
  }
</script>
{%- endunless -%}

{% schema %}
{
  "name": "As seen in",
  "tag": "section",
  "class": "amose-as-seen-in-root",
  "max_blocks": 8,
  "settings": [
    { "type": "range", "id": "max_width", "min": 1000, "max": 1600, "step": 20, "unit": "px", "label": "Max width", "default": 1200 },
    { "type": "header", "content": "Content" },
    { "type": "checkbox", "id": "show_heading", "label": "Show heading", "default": true },
    { "type": "text", "id": "heading", "label": "Heading", "default": "AS SEEN IN" },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 10, "max": 18, "step": 1, "unit": "px", "default": 12 },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "default": "600",
      "options": [
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    { "type": "header", "content": "Logos" },
    { "type": "range", "id": "logo_height", "min": 16, "max": 80, "step": 2, "unit": "px", "label": "Logo max height", "default": 28 },
    { "type": "range", "id": "logo_gap", "min": 12, "max": 100, "step": 2, "unit": "px", "label": "Gap between logos", "default": 48 },
    { "type": "range", "id": "mobile_logo_height", "min": 14, "max": 40, "step": 1, "unit": "px", "label": "Mobile logo max height", "default": 22 },
    { "type": "range", "id": "mobile_logo_gap", "min": 8, "max": 32, "step": 1, "unit": "px", "label": "Mobile logo gap", "default": 14 },
    { "type": "range", "id": "logo_text_size", "min": 14, "max": 40, "step": 1, "unit": "px", "label": "Fallback text size", "default": 28 },
    {
      "type": "select",
      "id": "logo_text_weight",
      "label": "Fallback text weight",
      "default": "700",
      "options": [
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    { "type": "checkbox", "id": "logo_white_filter", "label": "Make logo images white", "default": true },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "section_bg", "label": "Background", "default": "#785aaf" },
    { "type": "color", "id": "text_color", "label": "Heading color", "default": "#ffffff" },
    { "type": "color", "id": "logo_text_color", "label": "Logo text color", "default": "#ffffff" },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "corner_radius", "label": "Corner radius", "min": 0, "max": 48, "step": 2, "unit": "px", "default": 24 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Padding top", "default": 28 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Padding bottom", "default": 28 }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        { "type": "image_picker", "id": "logo_image", "label": "Logo image" },
        { "type": "text", "id": "logo_alt", "label": "Image alt text", "default": "Publication logo" },
        { "type": "text", "id": "logo_text", "label": "Fallback text", "default": "VOGUE" }
      ]
    }
  ],
  "presets": [
    {
      "name": "As seen in",
      "blocks": [
        { "type": "logo", "settings": { "logo_text": "ELLE", "logo_alt": "Elle logo" } },
        { "type": "logo", "settings": { "logo_text": "Forbes", "logo_alt": "Forbes logo" } },
        { "type": "logo", "settings": { "logo_text": "GQ", "logo_alt": "GQ logo" } },
        { "type": "logo", "settings": { "logo_text": "VOGUE", "logo_alt": "Vogue logo" } }
      ]
    }
  ]
}
{% endschema %}
