            { "value": "drop-simple", "label": "DropSimple" },
            { "value": "eyedropper-sample", "label": "EyedropperSample" },
            { "value": "heart", "label": "Heart" },
            { "value": "hand-heart", "label": "HandHeart" },
            { "value": "star", "label": "Star" },
            { "value": "star-four", "label": "StarFour" },
            { "value": "sparkle", "label": "Sparkle" },
            { "value": "brain", "label": "Brain" },
            { "value": "calendar", "label": "Calendar" },
            { "value": "check-circle", "label": "CheckCircle" },
            { "value": "drop-slash", "label": "DropSlash" },
            { "value": "fire", "label": "Fire" },
            { "value": "flower", "label": "Flower" },
            { "value": "hands-clapping", "label": "HandsClapping" },
            { "value": "magic-wand", "label": "MagicWand" },
            { "value": "plant", "label": "Plant" },
            { "value": "push-pin", "label": "PushPin" },
            { "value": "rocket-launch", "label": "RocketLaunch" },
            { "value": "scan-smiley", "label": "ScanSmiley" },
            { "value": "scroll", "label": "Scroll" },
            { "value": "seal-check", "label": "SealCheck" },
            { "value": "shield-check", "label": "ShieldCheck" },
            { "value": "shooting-star", "label": "ShootingStar" },
            { "value": "smiley-sticker", "label": "SmileySticker" },
            { "value": "tree", "label": "Tree" },
            { "value": "virus", "label": "Virus" },
            { "value": "waves", "label": "Waves" },
            { "value": "x-circle", "label": "XCircle" },
            { "value": "trophy", "label": "Trophy" },
            { "value": "user", "label": "User" },
            { "value": "users", "label": "Users" },
            { "value": "timer", "label": "Timer" },
            { "value": "thermometer", "label": "Thermometer" },
            { "value": "syringe", "label": "Syringe" },
            { "value": "spray-bottle", "label": "SprayBottle" },
            { "value": "speedometer", "label": "Speedometer" },
            { "value": "shower", "label": "Shower" },
            { "value": "shirt-folded", "label": "ShirtFolded" },
            { "value": "security-camera", "label": "SecurityCamera" },
            { "value": "ranking", "label": "Ranking" },
            { "value": "plus-circle", "label": "PlusCircle" },
            { "value": "pill", "label": "Pill" },
            { "value": "person", "label": "Person" },
            { "value": "paw-print", "label": "PawPrint" },
            { "value": "pants", "label": "Pants" },
            { "value": "paint-brush", "label": "PaintBrush" },
