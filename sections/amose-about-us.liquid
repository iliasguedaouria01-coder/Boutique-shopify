{%- liquid
  assign s = section.settings
  assign amose_install_origin = 'https://amosesection1-production.up.railway.app'
  assign amose_status_script_url = amose_install_origin | append: '/amose-section-status.js'
  assign amose_skip_install_mask = false
  if request.design_mode
    assign amose_skip_install_mask = true
  endif
  if theme.role == 'development'
    assign amose_skip_install_mask = true
  endif
-%}

{%- unless amose_skip_install_mask -%}
{%- comment -%} Install check: hide only after API says uninstalled (amose-section-status.js). {%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }}.amose-section-checking {
    display: none !important;
  }
{%- endstyle -%}
{%- endunless -%}

<section class="amose-about-us" style="padding-top: {{ s.padding_top }}px; padding-bottom: {{ s.padding_bottom }}px; background: {{ s.section_bg }};">
  <div class="page-width" style="max-width: {{ s.max_width }}px; margin: 0 auto; padding: 0 20px; color: {{ s.text_color }};">
    {% if s.eyebrow != blank %}
      <p style="margin: 0 0 10px; color: {{ s.muted_text_color }}; font-size: 14px; letter-spacing: 0.06em; text-transform: uppercase;">
        {{ s.eyebrow | escape }}
      </p>
    {% endif %}
    {% if s.heading != blank %}
      <h2 style="margin: 0 0 14px; font-size: clamp(28px, 4vw, 42px); line-height: 1.15;">{{ s.heading | escape }}</h2>
    {% endif %}
    {% if s.subheading != blank %}
      <p style="margin: 0 0 22px; color: {{ s.muted_text_color }}; font-size: 17px; line-height: 1.6;">
        {{ s.subheading | escape }}
      </p>
    {% endif %}
    {% if s.body != blank %}
      <div class="rte" style="font-size: 16px; line-height: 1.7; color: {{ s.text_color }};">
        {{ s.body }}
      </div>
    {% endif %}
  </div>
</section>

{%- unless amose_skip_install_mask -%}
<script>
  window.__AmoseInstallCheckPageStart = window.__AmoseInstallCheckPageStart || Date.now();
  window.__AmoseInstallCheckOrigin = {{ amose_install_origin | json }};
  window.AmoseSectionStatus = window.AmoseSectionStatus || [];
  window.AmoseSectionStatus.push({
    shop: {{ shop.permanent_domain | json }},
    sectionId: {{ section.id | json }},
    sectionType: "about-us"
  });

  window.AmoseStatusLoaderInserted = window.AmoseStatusLoaderInserted || false;

  if (!window.AmoseStatusLoaderInserted) {
    window.AmoseStatusLoaderInserted = true;
    var script = document.createElement("script");
    script.src = {{ amose_status_script_url | json }};
    script.defer = true;
    document.head.appendChild(script);
  }
</script>
{%- endunless -%}

{% schema %}
{
  "name": "Amose About Us",
  "tag": "section",
  "class": "amose-about-us-root",
  "settings": [
    { "type": "range", "id": "max_width", "min": 700, "max": 1600, "step": 20, "unit": "px", "label": "Max width", "default": 1200 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Top padding", "default": 56 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Bottom padding", "default": 56 },
    { "type": "color", "id": "section_bg", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#111111" },
    { "type": "color", "id": "muted_text_color", "label": "Muted text color", "default": "#4b5563" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "About us" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Built to help modern brands grow." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "We build practical products and customer experiences focused on quality, transparency, and long-term trust." },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Share your brand story, mission, and values here. Explain what makes your company different and why customers trust your products.</p><p>This section is fully editable from the theme editor.</p>" }
  ],
  "presets": [{ "name": "Amose About Us" }]
}
{% endschema %}
