{% comment %} Section layout style {% endcomment %}
{{ 'tpt-section.css' | asset_url | stylesheet_tag }}

{% comment %} Section configuration {% endcomment %}
{%- render 'tpt-section-setting', section: section -%}

{%- if section.index and section.settings.section_lazyload -%}
  <script src="{{ 'tpt-section-lazyload.js' | asset_url }}" defer="defer"></script>

  <tpt-section-lazyload data-url="?section_id={{ section.id }}">
    <div data-lazyload-element></div>
    <span class="tpt-section_loader"></span>
  </tpt-section-lazyload>
{%- else -%}
  {% comment %} Current section style {% endcomment %}
  {{ 'tpt-footer-1.css' | asset_url | stylesheet_tag }}

  <div class="tpt-section_container">
    <div class="tpt-section_content">
      {% comment %} Section header {% endcomment %}
      {%- render 'tpt-section-header', section: section -%}

      <div class="tpt-section-body">
        {% comment %} Section body {% endcomment %}
        <div class="tpt-footer-1" style="
          --payment-icon-width: {{ section.settings.payment_icon_width }}px; 
          --payment-icon-height: {{ section.settings.payment_icon_height }}px; 
          --payment-border-radius: {{ section.settings.payment_border_radius }}px; 
          --newsletter-icon-size: {{ section.settings.newsletter_icon_size }}px;
          --newsletter-input-border-color: {{ section.settings.newsletter_input_border_color.red }},{{ section.settings.newsletter_input_border_color.green }},{{ section.settings.newsletter_input_border_color.blue }}; 
          --newsletter-icon-color: {{ section.settings.newsletter_icon_color.red }},{{ section.settings.newsletter_icon_color.green }},{{ section.settings.newsletter_icon_color.blue }};"
        >
          <div class="tpt-footer-1_main">
            <!-- Menu Columns -->
            {% for block in section.blocks %}
              {% case block.type %}
                {% when 'menu_column' %}
                  <div class="tpt-footer-1_column tpt-footer-1_column-menu" {{ block.shopify_attributes }}>
                    {% if block.settings.menu_title != blank %}
                      <h4 class="tpt-footer-1_menu-title tpt-section__foreground--color">{{ block.settings.menu_title }}</h4>
                    {% endif %}
                    
                    {% if block.settings.menu != blank %}
                      <ul class="tpt-footer-1_menu-list">
                        {% for link in linklists[block.settings.menu].links %}
                          <li class="tpt-footer-1_menu-item">
                            <a href="{{ link.url }}" class="tpt-footer-1_menu-link tpt-section__foreground--color">
                              {{ link.title }}
                            </a>
                          </li>
                        {% endfor %}
                      </ul>
                    {% endif %}
                  </div>
              {% endcase %}
            {% endfor %}
            <!-- Logo and Newsletter Column -->
            <div class="tpt-footer-1_column tpt-footer-1_column-main">
              {% if section.settings.logo != blank %}
                <div class="tpt-footer-1_logo">
                  <a href="{{ routes.root_url }}">
                    {%- assign image_size = section.settings.logo_width | append: 'x' -%}
                    {{
                      section.settings.logo
                      | image_url: width: section.settings.logo_width
                      | image_tag:
                        alt: section.settings.logo.alt | default: shop.name,
                        loading: 'lazy',
                        width: section.settings.logo_width,
                        style: "height: auto; width: 100%;"
                    }}
                  </a>
                </div>
              {% endif %}

              {% if section.settings.show_newsletter %}
                <div class="tpt-footer-1_newsletter">
                  {% if section.settings.newsletter_heading != blank %}
                    <h4 class="tpt-footer-1_newsletter-title tpt-section__foreground--color">{{ section.settings.newsletter_heading }}</h4>
                  {% endif %}
                  
                  {%- form 'customer', id: 'ContactFooter', class: 'tpt-footer-1_newsletter-form' -%}
                    <input type="hidden" name="contact[tags]" value="newsletter">
                    <div class="tpt-footer-1_newsletter-fields">
                      <div class="tpt-field">
                        <input
                          id="ContactFooter-email"
                          type="email"
                          name="contact[email]"
                          class="tpt-input__email tpt-input_text"
                          value="{{ form.email }}"
                          aria-required="true"
                          autocorrect="off"
                          autocapitalize="off"
                          autocomplete="email"
                          placeholder="Email"
                          required
                        >
                        <label class="field__label" for="ContactFooter-email">
                          Email
                        </label>
                      </div>
                      <button type="submit" class="" name="commit">
                        <span>
                          <svg
                              viewBox="0 0 14 10"
                              fill="none"
                              aria-hidden="true"
                              focusable="false"
                              class="icon icon-arrow"
                              xmlns="http://www.w3.org/2000/svg"
                          >
                              <path fill-rule="evenodd" clip-rule="evenodd" d="M8.537.808a.5.5 0 01.817-.162l4 4a.5.5 0 010 .708l-4 4a.5.5 0 11-.708-.708L11.793 5.5H1a.5.5 0 010-1h10.793L8.646 1.354a.5.5 0 01-.109-.546z" fill="currentColor">
                          </svg>
                        </span>
                      </button>
                    </div>
                    {%- if form.errors -%}
                      <div class="tpt-form-error">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</div>
                    {%- endif -%}
                    {%- if form.posted_successfully? -%}
                      <div class="tpt-form-success">Thanks for subscribing</div>
                    {%- endif -%}
                  {%- endform -%}
                </div>
              {% endif %}

              {% comment %} Check if there are any social links to show {% endcomment %}
              {%- assign has_social_links = false -%}
              {% if section.settings.manual_social_config %}
                {% if section.settings.manual_facebook_link != blank or 
                      section.settings.manual_twitter_link != blank or 
                      section.settings.manual_instagram_link != blank or 
                      section.settings.manual_pinterest_link != blank or 
                      section.settings.manual_youtube_link != blank or 
                      section.settings.manual_tiktok_link != blank %}
                  {%- assign has_social_links = true -%}
                {% endif %}
              {% else %}
                {% if settings.social_facebook_link != blank or 
                      settings.social_twitter_link != blank or 
                      settings.social_instagram_link != blank or 
                      settings.social_pinterest_link != blank or 
                      settings.social_youtube_link != blank or 
                      settings.social_tiktok_link != blank %}
                  {%- assign has_social_links = true -%}
                {% endif %}
              {% endif %}

              {% if section.settings.social_heading != blank and section.settings.show_social and has_social_links %}
                <div class="tpt-footer-1_social">
                  <h4 class="tpt-footer-1_social-title tpt-section__foreground--color">{{ section.settings.social_heading }}</h4>
                  <ul class="tpt-footer-1_social-list">
                    {% if section.settings.manual_social_config %}
