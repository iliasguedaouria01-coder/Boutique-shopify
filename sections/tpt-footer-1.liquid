                          </a>
                        </li>
                      {%- endif -%}
                    {% endif %}
                  </ul>
                </div>
              {% endif %}
            </div>
          </div>

          <!-- Payment method badges -->
          {% if section.settings.show_payment_methods %}
            <div class="tpt-footer-1_bottom">

              <!-- Copyright -->
              <div class="tpt-footer-1_copyright tpt-section__foreground--color">
                  {% if section.settings.copyright_text != blank %}
                    {{ section.settings.copyright_text }}
                  {% else %}
                    &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}
                  {% endif %}
                </div>

              <div class="tpt-footer-1_payment">
                {% comment %} Only show payment heading if there are social links {% endcomment %}
                {% if section.settings.payment_heading != blank %}
                  <div class="tpt-footer-1_payment-title tpt-section__foreground--color">{{ section.settings.payment_heading }}</div>
                {% endif %}
                <div class="tpt-footer-1_payment-icons">
                  {% if section.settings.manual_payment_config %}
                    <!-- Manual Payment Icons -->
                    {% for block in section.blocks %}
                      {% case block.type %}
                        {% when 'payment_icon' %}
                          <span class="tpt-footer-1_payment-icon tpt-footer-1_payment-icon--manual" {{ block.shopify_attributes }}>
                            {% if block.settings.payment_image != blank %}
                              {{
                                block.settings.payment_image
                                | image_url: width: section.settings.payment_icon_width, height: section.settings.payment_icon_height
                                | image_tag:
                                  alt: block.settings.payment_name | default: 'Payment method',
                                  loading: 'lazy',
                                  width: section.settings.payment_icon_width,
                                  height: section.settings.payment_icon_height
                              }}
                            {% endif %}
                          </span>
                      {% endcase %}
                    {% endfor %}
                  {% else %}
                    <!-- Shop Payment Types -->
                    {% for type in shop.enabled_payment_types %}
                      <span class="tpt-footer-1_payment-icon">
                        {{ type | payment_type_svg_tag }}
                      </span>
                    {% endfor %}
                  {% endif %}
                </div>
              </div>
            </div>
          {% endif %}
        </div>
        {% comment %} End section body {% endcomment %}
      </div>

      {% comment %} Section footer {% endcomment %}
      {%- render 'tpt-section-footer', section: section -%}
    </div>
  </div>
{%- endif -%}{%- unless content_for_header contains 'tapita-section-script-tags' -%}{% style %}#shopify-section-{{ section.id }}{display: none !important;}{% endstyle %}{%- endunless -%}


