                      {% if section.settings.manual_facebook_link != blank %}
                        <li class="tpt-footer-1_social-item">
                          <a href="{{ section.settings.manual_facebook_link }}" class="tpt-footer-1_social-link" target="_blank" aria-label="Facebook">
