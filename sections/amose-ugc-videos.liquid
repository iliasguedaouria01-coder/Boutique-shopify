{%- liquid
  assign s = section.settings
  assign amose_install_origin = 'https://amosesection1-production.up.railway.app'
  assign amose_status_script_url = amose_install_origin | append: '/amose-section-status.js'
  assign amose_skip_install_mask = false
  if request.design_mode
    assign amose_skip_install_mask = true
  endif
  if theme.role == 'development'
    assign amose_skip_install_mask = true
  endif
  assign tp_stars_src = s.trustpilot_stars_image
  if tp_stars_src == blank
    assign tp_stars_src = 'https://i.imgur.com/EHjNmTM.png'
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }}.amose-ugc-videos-root {
    --ugc-bg: {{ s.section_bg }};
    --ugc-text: {{ s.text_color }};
    --ugc-muted: {{ s.muted_text_color }};
    --ugc-heading: clamp(22px, 2.5vw, 30px);
    --ugc-body: clamp(14px, 1.2vw, 16px);
    --ugc-text-align: {{ s.text_alignment | default: 'left' }};
    --ugc-aspect-ratio: {{ s.video_aspect_ratio | default: '9 / 16' }};
    --ugc-card-radius: {{ s.card_radius }}px;
    --ugc-video-radius: {{ s.video_radius | default: s.card_radius | default: 8 }}px;
    --ugc-gap: {{ s.card_gap }}px;
    background: var(--ugc-bg);
    color: var(--ugc-text);
    padding-top: {{ s.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ s.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }}.amose-ugc-videos-root {
      padding-top: {{ s.padding_top }}px;
      padding-bottom: {{ s.padding_bottom }}px;
    }
  }

  #shopify-section-{{ section.id }} .amose-ugc__wrap {
    max-width: {{ s.max_width }}px;
    margin: 0 auto;
    padding: 0 clamp(14px, 3vw, 24px);
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .amose-ugc__wrap {
      padding-right: 0;
    }
  }

  #shopify-section-{{ section.id }} .amose-ugc__header {
    margin-bottom: clamp(16px, 2.4vw, 26px);
    text-align: var(--ugc-text-align);
  }

  #shopify-section-{{ section.id }} .amose-ugc__heading {
    margin: 0;
    font-size: var(--ugc-heading);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .amose-ugc__kicker {
    margin: 0 0 10px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 14px;
    line-height: 1.2;
    color: var(--ugc-muted);
    font-weight: 500;
  }

  #shopify-section-{{ section.id }} .amose-ugc__stars {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    color: {{ s.star_color }};
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .amose-ugc__stars svg {
    width: 14px;
    height: 14px;
    fill: currentColor;
    display: block;
  }

  #shopify-section-{{ section.id }} .amose-ugc__stars--trustpilot {
    display: inline-flex;
    align-items: center;
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .amose-ugc__stars--trustpilot img {
    height: 16px;
    width: auto;
    display: block;
  }

  #shopify-section-{{ section.id }} .amose-ugc__sub {
    margin: 14px 0 0;
    color: var(--ugc-muted);
    max-width: 56ch;
    font-size: var(--ugc-body);
    line-height: 1.55;
  }

  #shopify-section-{{ section.id }} .amose-ugc__header[data-text-align='center'] .amose-ugc__sub {
    margin-left: auto;
    margin-right: auto;
  }

  #shopify-section-{{ section.id }} .amose-ugc__header[data-text-align='right'] .amose-ugc__sub {
    margin-left: auto;
    margin-right: 0;
  }

  #shopify-section-{{ section.id }} .amose-ugc__rail {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(146px, 1fr);
    gap: var(--ugc-gap);
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    padding-bottom: 4px;
    -webkit-overflow-scrolling: touch;
  }

  #shopify-section-{{ section.id }} .amose-ugc__rail::-webkit-scrollbar {
    height: 8px;
  }

  #shopify-section-{{ section.id }} .amose-ugc__rail::-webkit-scrollbar-thumb {
    background: #d1d5db;
    border-radius: 999px;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .amose-ugc__rail {
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    #shopify-section-{{ section.id }} .amose-ugc__rail::-webkit-scrollbar {
      display: none;
      width: 0;
      height: 0;
    }
  }

  @media (min-width: 990px) {
    #shopify-section-{{ section.id }} .amose-ugc__rail {
      grid-auto-columns: minmax(170px, 1fr);
    }
  }

  #shopify-section-{{ section.id }} .amose-ugc__item {
    position: relative;
    scroll-snap-align: start;
    border-radius: var(--ugc-video-radius);
    overflow: hidden;
    aspect-ratio: var(--ugc-aspect-ratio);
    background: #e5e7eb;
  }

  #shopify-section-{{ section.id }} .amose-ugc__media,
  #shopify-section-{{ section.id }} .amose-ugc__media video,
  #shopify-section-{{ section.id }} .amose-ugc__media img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .amose-ugc__play {
    position: absolute;
    right: 10px;
    bottom: 10px;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.5);
    background: rgba(0, 0, 0, 0.55);
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.16s ease, opacity 0.16s ease;
  }

  #shopify-section-{{ section.id }} .amose-ugc__play:hover {
    transform: translateY(-1px);
    opacity: 0.95;
  }

  #shopify-section-{{ section.id }} .amose-ugc__caption {
    position: absolute;
    top: 10px;
    left: 10px;
    right: 10px;
    margin: 0;
    color: #ffffff;
    font-size: 10px;
    line-height: 1.25;
    font-weight: 500;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.35);
    pointer-events: none;
    z-index: 3;
  }

  #shopify-section-{{ section.id }} .amose-ugc__item-modal {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.72);
    z-index: 4;
    padding: 0;
  }

  #shopify-section-{{ section.id }} .amose-ugc__item-modal.is-open {
    display: flex;
  }

  #shopify-section-{{ section.id }} .amose-ugc__modal-inner {
    width: 100%;
    height: 100%;
    border-radius: var(--ugc-video-radius);
    overflow: hidden;
    background: #000000;
    position: relative;
  }

  #shopify-section-{{ section.id }} .amose-ugc__item-modal video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .amose-ugc__close {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 34px;
    height: 34px;
    border-radius: 999px;
    border: 0;
    background: rgba(0, 0, 0, 0.55);
    color: #ffffff;
    font-size: 20px;
    line-height: 1;
    cursor: pointer;
  }
{%- endstyle -%}

{%- unless amose_skip_install_mask -%}
{%- style -%}
  #shopify-section-{{ section.id }}.amose-section-checking {
    display: none !important;
  }
{%- endstyle -%}
{%- endunless -%}

<section class="amose-ugc__wrap">
  <div class="amose-ugc__header" data-text-align="{{ s.text_alignment | default: 'left' }}">
    {% if s.kicker != blank %}
      <p class="amose-ugc__kicker">
        {% if s.rating_style == 'trustpilot' %}
          <span class="amose-ugc__stars amose-ugc__stars--trustpilot" aria-hidden="true">
            <img src="{{ tp_stars_src }}" alt="" loading="lazy" decoding="async">
          </span>
        {% else %}
          <span class="amose-ugc__stars" aria-hidden="true">
            {% for i in (1..5) %}
              <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                <path d="M12 2l2.9 6.6L22 9.2l-5 4.9 1.2 7L12 17.8 5.8 21l1.2-7-5-4.9 7.1-0.6z"></path>
              </svg>
            {% endfor %}
          </span>
        {% endif %}
        <span>{{ s.kicker }}</span>
      </p>
    {% endif %}
    <h2 class="amose-ugc__heading">
      {{ s.heading | escape }}
    </h2>
    {% if s.subheading != blank %}
      <p class="amose-ugc__sub">{{ s.subheading | escape }}</p>
    {% endif %}
  </div>

  <div class="amose-ugc__rail">
    {% for block in section.blocks %}
      <article class="amose-ugc__item" {{ block.shopify_attributes }}>
        <div class="amose-ugc__media">
          {% if block.settings.video_url != blank %}
            <video
              playsinline
              muted
              preload="auto"
              {% if block.settings.poster_image != blank %}
                poster="{{ block.settings.poster_image | image_url: width: 900 }}"
              {% endif %}
            >
              <source src="{{ block.settings.video_url | escape }}" type="video/mp4">
            </video>
          {% elsif block.settings.poster_image != blank %}
            <img
              src="{{ block.settings.poster_image | image_url: width: 900 }}"
              alt="UGC video"
              loading="lazy"
              width="{{ block.settings.poster_image.width }}"
              height="{{ block.settings.poster_image.height }}"
            >
          {% else %}
            <div style="width:100%;height:100%;background:#d1d5db;"></div>
          {% endif %}
        </div>
        {% if block.settings.video_url != blank %}
          <button
            class="amose-ugc__play"
            type="button"
            aria-label="Play video"
            data-ugc-video="{{ block.settings.video_url | escape }}"
          >
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
              <path d="M8 6v12l10-6z" fill="currentColor"></path>
            </svg>
          </button>
        {% endif %}
        {% if block.settings.caption != blank %}
          <p class="amose-ugc__caption">{{ block.settings.caption | escape }}</p>
        {% endif %}
        <div class="amose-ugc__item-modal" data-amose-ugc-item-modal>
          <div class="amose-ugc__modal-inner">
            <button type="button" class="amose-ugc__close" aria-label="Close video" data-amose-ugc-close>
              &times;
            </button>
            <video controls playsinline preload="metadata" data-amose-ugc-player></video>
          </div>
        </div>
      </article>
    {% endfor %}
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById("shopify-section-{{ section.id }}");
    if (!root) return;
    var activeModal = null;
    var activePlayer = null;
    var openVideo = function (src, modal, player) {
      if (!src) return;
      if (!modal || !player) return;
      if (activeModal && activePlayer) {
        activeModal.classList.remove("is-open");
        activePlayer.pause();
        activePlayer.removeAttribute("src");
        activePlayer.load();
      }
      player.src = src;
      modal.classList.add("is-open");
      activeModal = modal;
      activePlayer = player;
      try {
        player.play();
      } catch (e) {}
    };

    var closeVideo = function (modal, player) {
      if (!modal || !player) return;
      modal.classList.remove("is-open");
      player.pause();
      player.removeAttribute("src");
      player.load();
      if (activeModal === modal) activeModal = null;
      if (activePlayer === player) activePlayer = null;
    };

    root.querySelectorAll(".amose-ugc__item").forEach(function (item) {
      var btn = item.querySelector("[data-ugc-video]");
      var modal = item.querySelector("[data-amose-ugc-item-modal]");
      var player = item.querySelector("[data-amose-ugc-player]");
      var close = item.querySelector("[data-amose-ugc-close]");
      if (!btn || !modal || !player) return;
      btn.addEventListener("click", function () {
        openVideo(btn.getAttribute("data-ugc-video"), modal, player);
      });
      if (close) {
        close.addEventListener("click", function () {
          closeVideo(modal, player);
        });
      }
      modal.addEventListener("click", function (event) {
        if (event.target === modal) closeVideo(modal, player);
      });
    });
    document.addEventListener("keydown", function (event) {
      if (event.key === "Escape" && activeModal && activePlayer) {
        closeVideo(activeModal, activePlayer);
      }
    });
  })();
</script>

{%- unless amose_skip_install_mask -%}
<script>
  window.__AmoseInstallCheckPageStart = window.__AmoseInstallCheckPageStart || Date.now();
  window.__AmoseInstallCheckOrigin = {{ amose_install_origin | json }};
  window.AmoseSectionStatus = window.AmoseSectionStatus || [];
  window.AmoseSectionStatus.push({
    shop: {{ shop.permanent_domain | json }},
    sectionId: {{ section.id | json }},
    sectionType: "ugc-videos"
  });

  window.AmoseStatusLoaderInserted = window.AmoseStatusLoaderInserted || false;
  if (!window.AmoseStatusLoaderInserted) {
    window.AmoseStatusLoaderInserted = true;
    var script = document.createElement("script");
    script.src = {{ amose_status_script_url | json }};
    script.defer = true;
    document.head.appendChild(script);
  }
</script>
{%- endunless -%}

{% schema %}
{
  "name": "UGC Videos",
  "tag": "section",
  "class": "amose-ugc-videos-root",
  "max_blocks": 12,
  "settings": [
    {
      "type": "range",
      "id": "max_width",
      "min": 960,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Max width",
      "default": 1320
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Followers Think"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "4.7/5 | Viral Product"
    },
    {
      "type": "select",
      "id": "rating_style",
      "label": "Rating style",
      "default": "normal",
      "options": [
        { "value": "normal", "label": "Normal stars" },
        { "value": "trustpilot", "label": "Trustpilot-style stars" }
      ]
    },
    {
      "type": "text",
      "id": "trustpilot_stars_image",
      "label": "Trustpilot stars image URL",
      "info": "Leave blank to use the default Trustpilot stars image."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Find quick answers to the most common questions about our product."
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Heading/subheading alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "video_aspect_ratio",
      "label": "Video card format",
      "default": "9 / 16",
      "options": [
        { "value": "9 / 16", "label": "9:16 (Vertical)" },
        { "value": "4 / 7", "label": "4:7 (Extra vertical)" },
        { "value": "3 / 5", "label": "3:5 (Vertical)" },
        { "value": "2 / 3", "label": "2:3 (Portrait)" },
        { "value": "4 / 5", "label": "4:5 (Portrait)" }
      ]
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading color",
      "default": "#171717"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Subheading color",
      "default": "#5c5f62"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#5f46af"
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 6,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Card gap",
      "default": 10
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Card corner radius",
      "default": 8
    },
    {
      "type": "range",
      "id": "video_radius",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Video corner radius",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 28
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video card",
      "settings": [
        {
          "type": "image_picker",
          "id": "poster_image",
          "label": "Poster image"
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL (mp4)"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption",
          "default": "Real customer video"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "UGC Videos",
      "blocks": [
        { "type": "video", "settings": { "caption": "How I got rid of my double chin in only a few weeks" } },
        { "type": "video", "settings": { "caption": "Green light routine" } },
        { "type": "video", "settings": { "caption": "Daily check-in" } },
        { "type": "video", "settings": { "caption": "Red light therapy" } },
        { "type": "video", "settings": { "caption": "Night routine result" } }
      ]
    }
  ]
}
{% endschema %}
