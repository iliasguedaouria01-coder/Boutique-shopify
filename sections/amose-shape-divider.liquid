{%- liquid
  assign s = section.settings
  assign amose_install_origin = 'https://amosesection1-production.up.railway.app'
  assign amose_status_script_url = amose_install_origin | append: '/amose-section-status.js'
  assign amose_skip_install_mask = false
  if request.design_mode
    assign amose_skip_install_mask = true
  endif
  if theme.role == 'development'
    assign amose_skip_install_mask = true
  endif
  assign flip_x = 1
  assign flip_y = 1
  if s.flip_horizontal
    assign flip_x = -1
  endif
  if s.flip_vertical
    assign flip_y = -1
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }}[class*="amose-"] {
    font-size: 16px;
  }
  #shopify-section-{{ section.id }}.amose-shape-divider-root {
    margin: 0 !important;
    padding: 0 !important;
    line-height: 0;
    background: transparent;
  }

  #shopify-section-{{ section.id }} .amose-shape-divider {
    width: 100%;
    margin: 0;
    padding: 0;
    overflow: hidden;
    height: {{ s.height }}px;
  }

  #shopify-section-{{ section.id }} .amose-shape-divider__svg {
    width: 100%;
    height: 100%;
    display: block;
    color: {{ s.shape_color }};
    transform: scaleX({{ flip_x }}) scaleY({{ flip_y }});
    transform-origin: center;
  }
{%- endstyle -%}

{%- unless amose_skip_install_mask -%}
{%- comment -%} Install check: hide only after API says uninstalled (amose-section-status.js). {%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }}.amose-section-checking {
    display: none !important;
  }
{%- endstyle -%}
{%- endunless -%}

{%- capture shape_path -%}
  {%- case s.shape -%}
    {%- when "wave_soft" -%}
      M0,48 C120,84 240,12 360,48 C480,84 600,12 720,48 C840,84 960,12 1080,48 C1140,66 1170,72 1200,72 L1200,120 L0,120 Z
    {%- when "wave_deep" -%}
      M0,36 C120,108 240,-12 360,60 C480,120 600,0 720,60 C840,120 960,0 1080,60 C1140,78 1170,84 1200,84 L1200,120 L0,120 Z
    {%- when "wave_double" -%}
      M0,40 C90,72 150,8 240,40 C330,72 390,8 480,40 C570,72 630,8 720,40 C810,72 870,8 960,40 C1050,72 1110,8 1200,40 L1200,120 L0,120 Z
    {%- when "wave_sine" -%}
      M0,58 C60,22 140,22 200,58 C260,94 340,94 400,58 C460,22 540,22 600,58 C660,94 740,94 800,58 C860,22 940,22 1000,58 C1060,94 1140,94 1200,58 L1200,120 L0,120 Z
    {%- when "wave_peak" -%}
      M0,60 C100,102 200,18 300,60 C400,102 500,18 600,60 C700,102 800,18 900,60 C1000,102 1100,18 1200,60 L1200,120 L0,120 Z
    {%- when "diagonal_slant" -%}
      M0,22 L1200,86 L1200,120 L0,120 Z
    {%- when "zigzag" -%}
      M0,52 L75,20 L150,52 L225,20 L300,52 L375,20 L450,52 L525,20 L600,52 L675,20 L750,52 L825,20 L900,52 L975,20 L1050,52 L1125,20 L1200,52 L1200,120 L0,120 Z
    {%- when "curve_arc" -%}
      M0,84 C220,12 980,12 1200,84 L1200,120 L0,120 Z
    {%- when "step_notch" -%}
      M0,34 L160,34 L160,62 L320,62 L320,34 L480,34 L480,62 L640,62 L640,34 L800,34 L800,62 L960,62 L960,34 L1120,34 L1120,62 L1200,62 L1200,120 L0,120 Z
    {%- when "scallop" -%}
      M0,66 Q30,34 60,66 Q90,98 120,66 Q150,34 180,66 Q210,98 240,66 Q270,34 300,66 Q330,98 360,66 Q390,34 420,66 Q450,98 480,66 Q510,34 540,66 Q570,98 600,66 Q630,34 660,66 Q690,98 720,66 Q750,34 780,66 Q810,98 840,66 Q870,34 900,66 Q930,98 960,66 Q990,34 1020,66 Q1050,98 1080,66 Q1110,34 1140,66 Q1170,98 1200,66 L1200,120 L0,120 Z
    {%- else -%}
      M0,48 C120,84 240,12 360,48 C480,84 600,12 720,48 C840,84 960,12 1080,48 C1140,66 1170,72 1200,72 L1200,120 L0,120 Z
  {%- endcase -%}
{%- endcapture -%}

<div class="amose-shape-divider">
  <svg class="amose-shape-divider__svg" viewBox="0 0 1200 120" preserveAspectRatio="none" aria-hidden="true" focusable="false">
    <path d="{{ shape_path | strip }}" fill="currentColor"></path>
  </svg>
</div>

<script>
  (function() {
    var root = document.getElementById("shopify-section-{{ section.id }}");
    if (!root) return;
    var svg = root.querySelector(".amose-shape-divider__svg");
    if (!svg) return;
    if (!{{ s.adaptive_color | json }}) return;

    function pickBackgroundColor(el) {
      if (!el) return "";
      var bg = window.getComputedStyle(el).backgroundColor;
      if (!bg || bg === "rgba(0, 0, 0, 0)" || bg === "transparent") return "";
      return bg;
    }

    var source = "{{ s.adaptive_source }}";
    var picked = "";
    if (source === "previous") {
      picked = pickBackgroundColor(root.previousElementSibling);
    } else if (source === "next") {
      picked = pickBackgroundColor(root.nextElementSibling);
    } else {
      picked =
        pickBackgroundColor(root.previousElementSibling) ||
        pickBackgroundColor(root.nextElementSibling);
    }
    if (picked) svg.style.color = picked;
  })();
</script>

{%- unless amose_skip_install_mask -%}
<script>
  window.__AmoseInstallCheckPageStart = window.__AmoseInstallCheckPageStart || Date.now();
  window.__AmoseInstallCheckOrigin = {{ amose_install_origin | json }};
  window.AmoseSectionStatus = window.AmoseSectionStatus || [];
  window.AmoseSectionStatus.push({
    shop: {{ shop.permanent_domain | json }},
    sectionId: {{ section.id | json }},
    sectionType: "shape-divider"
  });

  window.AmoseStatusLoaderInserted = window.AmoseStatusLoaderInserted || false;

  if (!window.AmoseStatusLoaderInserted) {
    window.AmoseStatusLoaderInserted = true;
    var script = document.createElement("script");
    script.src = {{ amose_status_script_url | json }};
    script.defer = true;
    document.head.appendChild(script);
  }
</script>
{%- endunless -%}

{% schema %}
{
  "name": "Shape divider",
  "tag": "section",
  "class": "amose-shape-divider-root",
  "settings": [
    {
      "type": "select",
      "id": "shape",
      "label": "Shape",
      "options": [
        { "value": "wave_soft", "label": "Wave soft" },
        { "value": "wave_deep", "label": "Wave deep" },
        { "value": "wave_double", "label": "Wave double" },
        { "value": "wave_sine", "label": "Wave sine" },
        { "value": "wave_peak", "label": "Wave peak" },
        { "value": "diagonal_slant", "label": "Diagonal slant" },
        { "value": "zigzag", "label": "Zigzag" },
        { "value": "curve_arc", "label": "Curve arc" },
        { "value": "step_notch", "label": "Step notch" },
        { "value": "scallop", "label": "Scallop" }
      ],
      "default": "wave_soft"
    },
    {
      "type": "range",
      "id": "height",
      "min": 20,
      "max": 220,
      "step": 2,
      "unit": "px",
      "label": "Height",
      "default": 64
    },
    {
      "type": "color",
      "id": "shape_color",
      "label": "Shape color",
      "default": "#f3f3f3"
    },
    {
      "type": "checkbox",
      "id": "adaptive_color",
      "label": "Adapt color from adjacent section",
      "default": true
    },
    {
      "type": "select",
      "id": "adaptive_source",
      "label": "Adapt color from",
      "options": [
        { "value": "auto", "label": "Closest section (auto)" },
        { "value": "next", "label": "Next section" },
        { "value": "previous", "label": "Previous section" }
      ],
      "default": "auto"
    },
    {
      "type": "checkbox",
      "id": "flip_horizontal",
      "label": "Inverse left/right",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "flip_vertical",
      "label": "Inverse top/bottom",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Shape divider"
    }
  ]
}
{% endschema %}
