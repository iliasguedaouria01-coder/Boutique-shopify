{% comment %} Section layout style {% endcomment %}
{{ 'tpt-section.css' | asset_url | stylesheet_tag }}

{% comment %} Section configuration {% endcomment %}
{%- render 'tpt-section-setting', section: section -%}
<style>
  #shopify-section-{{ section.id }} .tpt-button__primary {
      border: {{ section.settings.outline_button_width }}px solid {{ section.settings.outline_button_color }} !important;
    }
</style>
{%- if section.index and section.settings.section_lazyload -%}
  <script src="{{ 'tpt-section-lazyload.js' | asset_url }}" defer="defer"></script>

  <tpt-section-lazyload data-url="?section_id={{ section.id }}">
    <div data-lazyload-element></div>
    <span class="tpt-section_loader"></span>
  </tpt-section-lazyload>
{%- else -%}

  {% comment %} Current section style {% endcomment %}
  {{ 'tpt-feature-collection-3.css' | asset_url | stylesheet_tag }}
  {{ 'tpt-swiper.min.css' | asset_url | stylesheet_tag }}
  {{ 'tpt-slider-control.css' | asset_url | stylesheet_tag }}

  <script src="{{ 'tpt-swiper.min.js' | asset_url }}" defer="defer"></script>
  {% assign products_limit = section.settings.products_limit %}


  {%- capture slider_options -%}
  {
    "slidesPerView": 3,
    {%- if section.settings.loop -%}
      "loop": true,
      {%- endif -%}

      {%- if section.settings.auto_play -%}
      "autoplay": {
        "delay": 2500,
        "disableOnInteraction": false
      },
      {%- endif -%}

      "pagination": {
        "type": "bullet"
      },

      "scrollbar": {
        "el": "#shopify-section-{{ section.id }} .swiper-scrollbar",
        "hide": false,
        "draggable": true
      },
      
      "breakpoints": {
        "0": {
          "slidesPerView": "auto",
          "spaceBetween": 10
        },
        "450": {
          "slidesPerView": "2",
          "spaceBetween": 10
        },  
        "768": {
          "slidesPerView": "3",
          "spaceBetween": 15
        },
        "1024": {
          "slidesPerView": "4",
          "spaceBetween": 20
        }
      }
    }
  {%- endcapture -%}
  {%- capture sizes -%}
    (min-width: {{ settings.page_width }}px) {{ settings.page_width }}px, (min-width: 768px) calc(100vw - 30px), (min-width: 320px) calc(100vw - 30px), 100vw
  {%- endcapture -%}
  <div class="tpt-section_container">
    <div class="tpt-section_content">
      <div class="tpt-feature-collection-3-container">
        {% comment %} Section header {% endcomment %}
        {%- render 'tpt-section-header', section: section -%}

        <div class="tpt-section-body">
          {% comment %} Section body {% endcomment %}
          <tpt-slider class="tpt-feature-collection-3-slider">
            <tpt-slider-options class="hidden">
              {{ slider_options }}
            </tpt-slider-options>
            <div class="tpt-product-tabs tpt-feature-collection-3">
              <div class="tpt-swiper-container">
                <div class="swiper">
                  <div class="swiper-wrapper">
                    {%- for product in section.settings.collection.products limit: products_limit -%}
                      <div class="swiper-slide">
                        {% comment %} {% render 'tpt-card-product',
                          card_product: product,
                          media_aspect_ratio: settings.product_image_ratio,
                          show_secondary_image: settings.product_show_secondary_image,
                          show_vendor: settings.product_show_vendor,
                          show_rating: settings.product_show_rating,
                          show_quick_add: settings.product_enable_quick_add,
                          section_id: section.id
                        %} {% endcomment %}
                        {% render 'tpt-card-product',
                          card_product: product,
                          media_aspect_ratio: section.settings.image_ratio,
                          sizes: sizes,
                          show_secondary_image: section.settings.show_secondary_image,
                          section_id: section.id
                        %}
                      </div>
                    {%- endfor -%}
                  </div>
                </div>

                {% comment %} <div class="swiper-button">
                  <div class="swiper-button-prev"></div>
                  <div class="swiper-button-next"></div>
                </div> {% endcomment %}
                <div class="swiper-scrollbar tpt-swiper-scrollbar"></div>
              </div>
            </div>
          </tpt-slider>
          
          {% comment %} End section body {% endcomment %}
        </div>
      </div>

      {% comment %} Section footer {% endcomment %}
      {%- render 'tpt-section-footer', section: section -%}
    </div>
  </div>
{%- endif -%}{%- unless content_for_header contains 'tapita-section-script-tags' -%}{% style %}#shopify-section-{{ section.id }}{display: none !important;}{% endstyle %}{%- endunless -%}


{% schema %}
{
  "name": "Tpt-Feature collection #3",
  "tag": "section",
  "class": "section tpt-section",
  "disabled_on": {
      "groups": [
          "header",
          "footer"
      ]
  },
  "settings": [
      {
          "type": "header",
          "content": "Section header"
      },
      {
          "type": "inline_richtext",
          "id": "heading",
          "default": "New Arrivals",
          "label": "Heading"
      },
      {
          "type": "select",
          "id": "heading_size",
          "label": "Heading size",
          "options": [
              {
                  "value": "h4",
                  "label": "Small"
              },
              {
                  "value": "h2",
                  "label": "Medium"
              },
              {
                  "value": "h0",
                  "label": "Large"
              }
          ],
          "default": "h2"
      },
      {
          "type": "inline_richtext",
          "id": "sub_heading",
          "label": "Sub-heading",
          "default": "FEATURE COLLECTION"
      },
      {
          "type": "richtext",
          "id": "description",
          "label": "Description"
      },
      {
          "type": "select",
          "id": "alignment",
          "label": "Alignment",
          "options": [
              {
                  "value": "default",
                  "label": "Default"
              },
              {
                  "value": "center",
                  "label": "Center"
              }
          ],
          "default": "center"
      },
      {
          "type": "text",
          "id": "top_button_label",
          "label": "Button label"
      },
      {
          "type": "url",
          "id": "top_button_link",
          "label": "Button link"
      },
      {
          "type": "header",
          "content": "Section body"
      },
      {
        "type": "collection",
        "id": "collection",
        "label": "Collection"
      },
      {
        "type": "number",
        "id": "products_limit",
        "label": "Products limit",
        "default": 6
      },
      {
        "type": "range",
        "id": "image_ratio",
        "min": 50,
        "max": 150,
        "step": 1,
        "label": "Image ratio",
        "default": 80
      },
      {
        "type": "checkbox",
        "id": "show_secondary_image",
        "label": "Show second image on hover",
        "default": true
      },

      {
          "type": "header",
          "content": "Section footer"
      },
      {
        "type": "text",
        "id": "bottom_button_label",
        "label": "Button label"
      },
      {
          "type": "url",
          "id": "bottom_button_link",
          "label": "Button link"
      },
      {
          "type": "header",
          "content": "Section layout"
      },
      {
          "type": "image_picker",
          "id": "background_image",
          "label": "Background image"
      },
      {
          "type": "checkbox",
          "id": "section_full_width",
          "label": "Section full width",
          "default": true
      },
      {
          "type": "range",
          "id": "section_max_width",
          "min": 1200,
          "max": 1900,
          "step": 20,
          "unit": "px",
          "label": "Section max width",
          "default": 1600
      },
      {
          "type": "checkbox",
          "id": "content_full_width",
          "label": "Content full width",
          "default": false
      },
      {
          "type": "range",
          "id": "content_max_width",
          "min": 800,
          "max": 1900,
          "step": 20,
          "unit": "px",
          "label": "Content max width",
          "default": 1440
      },
      {
          "type": "range",
          "id": "padding_desktop",
          "min": 0,
          "max": 100,
          "step": 2,
          "unit": "px",
          "label": "Padding desktop",
          "default": 0
      },
      {
          "type": "range",
          "id": "padding_tablet_mobile",
          "min": 0,
          "max": 40,
          "step": 1,
          "unit": "px",
          "label": "Padding tablet, mobile",
          "default": 0
      },
      {
          "type": "range",
          "id": "margin_desktop",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "px",
          "label": "Margin desktop",
          "default": 60
      },
      {
          "type": "range",
          "id": "margin_tablet_mobile",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "px",
          "label": "Margin tablet, mobile",
          "default": 40
      },
      {
          "type": "header",
          "content": "Section color"
      },
      {
          "type": "color",
          "id": "background_color",
          "label": "Background",
          "default": "#FFFFFF"
      },
      {
          "type": "color_background",
          "id": "background_gradient_color",
          "label": "Background gradient"
      },
      {
          "type": "color",
          "id": "title_color",
          "label": "Title",
          "default": "#000000"
      },
      {
          "type": "color",
          "id": "button_background_color",
          "label": "Button background",
          "default": "#000000"
      },
      {
          "type": "color",
          "id": "button_text_color",
          "label": "Button text",
          "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "outline_button_color",
        "label": "Outline button",
        "default": "#000000"
      },
      {
        "type": "range",
        "id": "outline_button_width",
        "label": "Outline thickness",
        "min": 0,
        "max": 10,
        "step": 1,
        "default": 0
      },
      {
        "type": "range",
        "id": "input_button_radius",
        "min": 0,
        "max": 50,
        "step": 1,
        "unit": "px",
        "label": "Button radius",
        "default": 0
      },
      {
          "type": "color",
          "id": "foreground_color",
          "label": "Foreground",
          "default": "#000000"
      },
      {
          "type": "header",
          "content": "Section optimize"
      },
      {
          "type": "checkbox",
          "id": "section_lazyload",
          "label": "Section lazyload",
          "default": false
      }
  ],
  "blocks": [
  ],
  "presets": [
    {"name": "Tpt-Feature collection #3"}
  ]
}  
{% endschema %}