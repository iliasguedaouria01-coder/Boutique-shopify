

{% comment %} Section layout style {% endcomment %}
{{ 'tpt-trust-badges-3.css' | asset_url | stylesheet_tag }}

{% assign original = section.settings.target %}
{% assign converted = original | replace: "-target", "-template" %}

{% style %}
  .{{ converted }}.tpt-trust-badges-3 {
    --badge-padding: {{ section.settings.badge_padding }}px;
    --badge-gap: {{ section.settings.badge_gap }}px;
    --icon-size: {{ section.settings.icon_size }}px;
    --title-font-size: {{ section.settings.title_font_size }}px;
    --subtitle-font-size: {{ section.settings.subtitle_font_size }}px;
    --title-color: {{ section.settings.title_color }};
    --subtitle-color: {{ section.settings.subtitle_color }};
    --background-color: {{ section.settings.background_color }};
    --border-radius: {{ section.settings.border_radius }}px;
    --border-width: {{ section.settings.border_width }}px;
    --border-color: {{ section.settings.border_color }};
    --border-style: {{ section.settings.border_style }};
    --shadow-color: {{ section.settings.shadow_color | color_to_rgb | replace: 'rgb(', '' | replace: ')', '' }};
    --shadow-opacity: {{ section.settings.shadow_opacity | divided_by: 100.0 }};
    --shadow-blur: {{ section.settings.shadow_blur }}px;
    --shadow-spread: {{ section.settings.shadow_spread }}px;
    --shadow-x: {{ section.settings.shadow_x }}px;
    --shadow-y: {{ section.settings.shadow_y }}px;
  }
{% endstyle %}

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const template = document.getElementById('{{ converted }}');
    const target = document.getElementById('{{ original }}');
    if (target && template) {
      target.appendChild(template.content.cloneNode(true));
    }
  });
</script>

{%- comment -%}
  Add this to target location:
  <div id="data-tpt-trust-badges-3-target"></div>
{%- endcomment -%}

<template id="{{ converted }}">
  <div class="tpt-trust-badges-3 {{ converted }}">
    <div class="tpt-trust-badges-3_container">
      <div class="tpt-trust-badges-3_list">
        {%- for block in section.blocks -%}
          <div class="tpt-trust-badges-3_item" {{ block.shopify_attributes }}>
            {%- if block.settings.badge_url != blank -%}
              <a href="{{ block.settings.badge_url }}" class="tpt-trust-badges-3_link"
                {%- assign mtm_link = block.settings.badge_url -%}
                {%- if mtm_link contains 'http' -%}
                  {% unless mtm_link contains shop.domain %} rel="nofollow" {% endunless %}
                {%- endif -%}
              >
            {%- endif -%}
            
            <div class="tpt-trust-badges-3_content">
              {%- if block.settings.badge_icon != blank -%}
                <div class="tpt-trust-badges-3_icon">
                  {%- assign image_alt = block.settings.badge_icon.alt | default: block.settings.badge_title -%}
                  {{
                    block.settings.badge_icon
                    | image_url: width: 120
                    | image_tag: alt: image_alt, loading: 'lazy'
                  }}
                </div>
              {%- endif -%}
              
              <div class="tpt-trust-badges-3_text">
                {%- if block.settings.badge_title != blank -%}
                  <div class="tpt-trust-badges-3_title">
                    {{ block.settings.badge_title }}
                  </div>
                {%- endif -%}
                
                {%- if block.settings.badge_subtitle != blank -%}
                  <div class="tpt-trust-badges-3_subtitle">
                    {{ block.settings.badge_subtitle }}
                  </div>
                {%- endif -%}
              </div>
            </div>
            
            {%- if block.settings.badge_url != blank -%}
              </a>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</template>{% style %}#shopify-section-{{ section.id }}{display: none !important;}{% endstyle %}


