{% doc %}
  @prompt
    pareil je veux une section conseil d'utilisation voici les infos : Les bagues ANCR sont conçues pour allier style et confort au quotidien.
    Pour profiter pleinement de votre bijou, veillez à l’ajuster avec délicatesse si le modèle est réglable et évitez les manipulations excessives.
    
    Chaque bague est pensée pour accompagner vos journées avec élégance, tout en restant agréable à porter.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-usage-tips-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-usage-tips-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
  }

  .ai-usage-tips-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.spacing_after_heading }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-usage-tips-content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-usage-tips-content-{{ ai_gen_id }} p {
    margin: 0 0 {{ block.settings.paragraph_spacing }}px;
  }

  .ai-usage-tips-content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-usage-tips-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.padding_vertical | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px;
    }

    .ai-usage-tips-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-usage-tips-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-usage-tips-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-usage-tips-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-usage-tips-heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if block.settings.content != blank %}
      <div class="ai-usage-tips-content-{{ ai_gen_id }}">
        {{ block.settings.content }}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Conseils d'utilisation",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Contenu"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Titre",
      "default": "Conseils d'utilisation"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Texte",
      "default": "<p>Les bagues ANCR sont conçues pour allier style et confort au quotidien. Pour profiter pleinement de votre bijou, veillez à l'ajuster avec délicatesse si le modèle est réglable et évitez les manipulations excessives.</p><p>Chaque bague est pensée pour accompagner vos journées avec élégance, tout en restant agréable à porter.</p>"
    },
    {
      "type": "header",
      "content": "Mise en page"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Largeur bureau",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Largeur maximale du contenu",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 800
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alignement du texte",
      "options": [
        {
          "value": "left",
          "label": "Gauche"
        },
        {
          "value": "center",
          "label": "Centre"
        },
        {
          "value": "right",
          "label": "Droite"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Espacement"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Espacement vertical",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Espacement horizontal",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "spacing_after_heading",
      "label": "Espacement après le titre",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "paragraph_spacing",
      "label": "Espacement entre paragraphes",
      "min": 5,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Couleur de fond",
      "default": "#f5f5f5"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Arrondi des coins",
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 10
    },
    {
      "type": "header",
      "content": "Typographie"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Couleur du titre",
      "default": "#0a1a2f"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Taille du titre",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur du texte",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Taille du texte",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    }
  ],
  "presets": [
    {
      "name": "Conseils d'utilisation"
    }
  ]
}
{% endschema %}