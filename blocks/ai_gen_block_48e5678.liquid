{% doc %}
  @prompt
    genere moi un meuilleur formulaire de contact
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-form-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-contact-form__container-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding }}px;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-contact-form__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.spacing }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-contact-form__description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    margin: 0 0 {{ block.settings.spacing }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-contact-form__fields-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.field_spacing }}px;
  }

  .ai-contact-form__row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.field_spacing }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-contact-form__row-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }

  .ai-contact-form__field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-contact-form__label-{{ ai_gen_id }} {
    color: {{ block.settings.label_color }};
    font-size: {{ block.settings.label_size }}px;
    font-weight: 500;
  }

  .ai-contact-form__input-{{ ai_gen_id }},
  .ai-contact-form__textarea-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.input_padding }}px;
    background-color: {{ block.settings.input_background }};
    color: {{ block.settings.input_text_color }};
    border: {{ block.settings.input_border_width }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: {{ block.settings.input_text_size }}px;
    transition: all 0.3s ease;
  }

  .ai-contact-form__input-{{ ai_gen_id }}:focus,
  .ai-contact-form__textarea-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.input_focus_border_color }};
    background-color: {{ block.settings.input_focus_background }};
  }

  .ai-contact-form__textarea-{{ ai_gen_id }} {
    min-height: 120px;
    resize: vertical;
  }

  .ai-contact-form__button-{{ ai_gen_id }} {
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 2 }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    width: 100%;
  }

  .ai-contact-form__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-contact-form__success-{{ ai_gen_id }} {
    padding: {{ block.settings.input_padding }}px;
    background-color: {{ block.settings.success_background }};
    color: {{ block.settings.success_text_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-bottom: {{ block.settings.field_spacing }}px;
    text-align: center;
  }

  .ai-contact-form__error-{{ ai_gen_id }} {
    padding: {{ block.settings.input_padding }}px;
    background-color: {{ block.settings.error_background }};
    color: {{ block.settings.error_text_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-bottom: {{ block.settings.field_spacing }}px;
  }

  .ai-contact-form__error-item-{{ ai_gen_id }} {
    margin: 4px 0;
  }
{% endstyle %}

<contact-form-{{ ai_gen_id }}
  class="ai-contact-form-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-contact-form__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-contact-form__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="ai-contact-form__description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
    {% endif %}

    {% form 'contact' %}
      {% if form.posted_successfully? %}
        <div
          class="ai-contact-form__success-{{ ai_gen_id }}"
          id="ai-contact-form-success-{{ ai_gen_id }}"
        >
          {{ block.settings.success_message }}
        </div>
      {% endif %}

      {% if form.errors %}
        <div
          class="ai-contact-form__error-{{ ai_gen_id }}"
          id="ai-contact-form-error-{{ ai_gen_id }}"
        >
          <strong>{{ block.settings.error_heading }}</strong>
          {% for field in form.errors %}
            <div class="ai-contact-form__error-item-{{ ai_gen_id }}">
              {{ form.errors.messages[field] }}
            </div>
          {% endfor %}
        </div>
      {% endif %}

      <div class="ai-contact-form__fields-{{ ai_gen_id }}">
        <div class="ai-contact-form__row-{{ ai_gen_id }}">
          <div class="ai-contact-form__field-{{ ai_gen_id }}">
            <label
              for="ai-contact-name-{{ ai_gen_id }}"
              class="ai-contact-form__label-{{ ai_gen_id }}"
            >
              {{ block.settings.name_label }}
              {% if block.settings.name_required %}*{% endif %}
            </label>
            <input
              type="text"
              id="ai-contact-name-{{ ai_gen_id }}"
              name="contact[{{ block.settings.name_label }}]"
              class="ai-contact-form__input-{{ ai_gen_id }}"
              placeholder="{{ block.settings.name_placeholder }}"
              {% if block.settings.name_required %}required{% endif %}
              {% if form.errors %}
                aria-describedby="ai-contact-form-error-{{ ai_gen_id }}"
              {% endif %}
            >
          </div>

          <div class="ai-contact-form__field-{{ ai_gen_id }}">
            <label
              for="ai-contact-email-{{ ai_gen_id }}"
              class="ai-contact-form__label-{{ ai_gen_id }}"
            >
              {{ block.settings.email_label }}*
            </label>
            <input
              type="email"
              id="ai-contact-email-{{ ai_gen_id }}"
              name="contact[email]"
              class="ai-contact-form__input-{{ ai_gen_id }}"
              placeholder="{{ block.settings.email_placeholder }}"
              autocomplete="email"
              required
              {% if form.errors %}
                aria-describedby="ai-contact-form-error-{{ ai_gen_id }}"
              {% endif %}
            >
          </div>
        </div>

        {% if block.settings.show_phone %}
          <div class="ai-contact-form__field-{{ ai_gen_id }}">
            <label
              for="ai-contact-phone-{{ ai_gen_id }}"
              class="ai-contact-form__label-{{ ai_gen_id }}"
            >
              {{ block.settings.phone_label }}
              {% if block.settings.phone_required %}*{% endif %}
            </label>
            <input
              type="tel"
              id="ai-contact-phone-{{ ai_gen_id }}"
              name="contact[{{ block.settings.phone_label }}]"
              class="ai-contact-form__input-{{ ai_gen_id }}"
              placeholder="{{ block.settings.phone_placeholder }}"
              autocomplete="tel"
              {% if block.settings.phone_required %}required{% endif %}
              {% if form.errors %}
                aria-describedby="ai-contact-form-error-{{ ai_gen_id }}"
              {% endif %}
            >
          </div>
        {% endif %}

        {% if block.settings.show_subject %}
          <div class="ai-contact-form__field-{{ ai_gen_id }}">
            <label
              for="ai-contact-subject-{{ ai_gen_id }}"
              class="ai-contact-form__label-{{ ai_gen_id }}"
            >
              {{ block.settings.subject_label }}
              {% if block.settings.subject_required %}*{% endif %}
            </label>
            <input
              type="text"
              id="ai-contact-subject-{{ ai_gen_id }}"
              name="contact[{{ block.settings.subject_label }}]"
              class="ai-contact-form__input-{{ ai_gen_id }}"
              placeholder="{{ block.settings.subject_placeholder }}"
              {% if block.settings.subject_required %}required{% endif %}
              {% if form.errors %}
                aria-describedby="ai-contact-form-error-{{ ai_gen_id }}"
              {% endif %}
            >
          </div>
        {% endif %}

        <div class="ai-contact-form__field-{{ ai_gen_id }}">
          <label
            for="ai-contact-message-{{ ai_gen_id }}"
            class="ai-contact-form__label-{{ ai_gen_id }}"
          >
            {{ block.settings.message_label }}*
          </label>
          <textarea
            id="ai-contact-message-{{ ai_gen_id }}"
            name="contact[body]"
            class="ai-contact-form__textarea-{{ ai_gen_id }}"
            placeholder="{{ block.settings.message_placeholder }}"
            required
            {% if form.errors %}
              aria-describedby="ai-contact-form-error-{{ ai_gen_id }}"
            {% endif %}
          ></textarea>
        </div>

        <button
          type="submit"
          class="ai-contact-form__button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_text }}
        </button>
      </div>
    {% endform %}
  </div>
</contact-form-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const form = this.querySelector('form');
        const successMessage = this.querySelector('#ai-contact-form-success-{{ ai_gen_id }}');
        
        if (successMessage) {
          setTimeout(() => {
            successMessage.style.opacity = '0';
            setTimeout(() => {
              successMessage.remove();
            }, 300);
          }, 5000);
        }
      }
    }

    customElements.define('contact-form-{{ ai_gen_id }}', ContactForm{{ ai_gen_id }});
  })();
</script>

