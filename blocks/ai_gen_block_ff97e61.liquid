      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Taille du texte",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "footer_text_size",
      "label": "Taille du texte de conclusion",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    }
  ],
  "presets": [
    {
      "name": "Conseils d'entretien"
    }
  ]
}
{% endschema %}